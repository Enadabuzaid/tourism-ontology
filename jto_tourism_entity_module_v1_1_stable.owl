  <rdf:Description rdf:about="http://www.jordantourism.org/ontology#FamilyFriendlyJordan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.jordantourism.org/ontology#ChildFriendly"/>
    <rdfs:comment xml:lang="en">Jordan is very family-friendly. Children are welcomed and adored. Many hotels offer kids clubs, family rooms, and child-friendly pools. Attractions like Petra, Wadi Rum, and the Dead Sea are suitable for all ages.</rdfs:comment>
