<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.jordantourism.org/ontology#"
     xml:base="http://www.jordantourism.org/ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:shacl="http://www.w3.org/ns/shacl#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.jordantourism.org/ontology">
        <owl:imports rdf:resource="file:/Users/enadabuzaid/Desktop/Thesis/ontology/jto_core_shapes_v1_1.ttl"/>
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <owl:imports rdf:resource="http://www.w3.org/2006/time"/>
        <dc:creator>Enad Abu Zaid</dc:creator>
        <dc:description xml:lang="en">This module defines the core TourismEntity classes including Place, Event, and Route hierarchies for the Jordan Tourism Ontology. It covers competency questions CQ-001 to CQ-300 related to tourism entities.</dc:description>
        <dc:description xml:lang="ar">هذه الوحدة تحدد فئات الكيانات السياحية الأساسية بما في ذلك التسلسلات الهرمية للأماكن والأحداث والمسارات لأنطولوجيا السياحة الأردنية.</dc:description>
        <dc:title xml:lang="en">Jordan Tourism Ontology (JTO) - TourismEntity Module</dc:title>
        <dc:title xml:lang="ar">أنطولوجيا السياحة الأردنية - وحدة الكيانات السياحية</dc:title>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-17</dcterms:created>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-17</dcterms:modified>
        <rdfs:comment xml:lang="en">Module: TourismEntity (Place + Event + Route)</rdfs:comment>
        <owl:versionInfo>2.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.jordantourism.org/ontology#altLabelAR -->

    <owl:AnnotationProperty rdf:about="http://www.jordantourism.org/ontology#altLabelAR">
        <rdfs:comment xml:lang="en">Alternative name in Arabic for entity disambiguation</rdfs:comment>
        <rdfs:label xml:lang="en">Arabic Alternative Label</rdfs:label>
        <rdfs:label xml:lang="ar">التسمية البديلة بالعربية</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#altLabel"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.jordantourism.org/ontology#altLabelEN -->

    <owl:AnnotationProperty rdf:about="http://www.jordantourism.org/ontology#altLabelEN">
        <rdfs:comment xml:lang="en">Alternative name in English for entity disambiguation</rdfs:comment>
        <rdfs:label xml:lang="en">English Alternative Label</rdfs:label>
        <rdfs:label xml:lang="ar">التسمية البديلة بالإنجليزية</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#altLabel"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.jordantourism.org/ontology#cqReference -->

    <owl:AnnotationProperty rdf:about="http://www.jordantourism.org/ontology#cqReference">
        <rdfs:comment xml:lang="en">References the competency question(s) this class addresses</rdfs:comment>
        <rdfs:label xml:lang="en">Competency Question Reference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://www.jordantourism.org/ontology#lastUpdated -->

    <owl:AnnotationProperty rdf:about="http://www.jordantourism.org/ontology#lastUpdated">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/modified"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.jordantourism.org/ontology#wikidataID -->

    <owl:AnnotationProperty rdf:about="http://www.jordantourism.org/ontology#wikidataID">
        <rdfs:comment xml:lang="en">Links to Wikidata entity for disambiguation</rdfs:comment>
        <rdfs:label xml:lang="en">Wikidata ID</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#time -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#time"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.jordantourism.org/ontology#acceptsPayment -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#acceptsPayment">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Service"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#PaymentMethod"/>
        <rdfs:comment xml:lang="en">Links a service to accepted payment methods.</rdfs:comment>
        <rdfs:label xml:lang="en">accepts payment</rdfs:label>
        <rdfs:label xml:lang="ar">يقبل الدفع</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#affectedByHoliday -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#affectedByHoliday">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#ReligiousHoliday"/>
        <rdfs:comment xml:lang="en">Indicates that a place&apos;s services or hours are affected by a religious holiday.</rdfs:comment>
        <rdfs:label xml:lang="en">affected by holiday</rdfs:label>
        <rdfs:label xml:lang="ar">يتأثر بالعطلة</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#affectedByPractice -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#affectedByPractice">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#ReligiousPractice"/>
        <rdfs:comment xml:lang="en">Links a place or service to religious/cultural practices that affect it.</rdfs:comment>
        <rdfs:label xml:lang="en">affected by practice</rdfs:label>
        <rdfs:label xml:lang="ar">يتأثر بممارسة</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#availableAt -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#availableAt">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Activity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:comment xml:lang="en">Links an activity to the location where it can be done.</rdfs:comment>
        <rdfs:label xml:lang="en">available at</rdfs:label>
        <rdfs:label xml:lang="ar">متاح في</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#combinableWith -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#combinableWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Activity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Activity"/>
        <rdfs:comment xml:lang="en">Links activities that can be done together.</rdfs:comment>
        <rdfs:label xml:lang="en">combinable with</rdfs:label>
        <rdfs:label xml:lang="ar">يمكن دمجه مع</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#connects -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#connects">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Route"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:comment xml:lang="en">Indicates that a route connects two or more places.</rdfs:comment>
        <rdfs:label xml:lang="en">connects</rdfs:label>
        <rdfs:label xml:lang="ar">يربط</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#connectsTo -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#connectsTo">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#BorderCrossing"/>
        <rdfs:comment xml:lang="en">Links a border crossing to the destination country.</rdfs:comment>
        <rdfs:label xml:lang="en">connects to</rdfs:label>
        <rdfs:label xml:lang="ar">يتصل بـ</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#contains -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#contains">
        <owl:inverseOf rdf:resource="http://www.jordantourism.org/ontology#locatedIn"/>
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Destination"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:label xml:lang="en">contains</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#endsAt -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#endsAt">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Route"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:label xml:lang="en">ends at</rdfs:label>
        <rdfs:label xml:lang="ar">ينتهي عند</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#facilityLocatedAt -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#facilityLocatedAt">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Facility"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:comment xml:lang="en">Links a facility to its physical location.</rdfs:comment>
        <rdfs:label xml:lang="en">facility located at</rdfs:label>
        <rdfs:label xml:lang="ar">المرفق يقع في</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#featuredInFilm -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#featuredInFilm">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#FilmLocation"/>
        <rdfs:comment xml:lang="en">Links a film location to the movie it appeared in.</rdfs:comment>
        <rdfs:label xml:lang="en">featured in film</rdfs:label>
        <rdfs:label xml:lang="ar">ظهر في فيلم</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#filmedIn -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#filmedIn">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Movie"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <cqReference>CQ-281</cqReference>
        <rdfs:label xml:lang="en">filmed in</rdfs:label>
        <rdfs:label xml:lang="ar">صُوِّر في</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasAccessibilityFeature -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasAccessibilityFeature">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#AccessibilityFeature"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#AccessibleFacility"/>
        <cqReference>CQ-005, CQ-076</cqReference>
        <rdfs:comment xml:lang="en">Links a facility to its accessibility features.</rdfs:comment>
        <rdfs:label xml:lang="en">has accessibility feature</rdfs:label>
        <rdfs:label xml:lang="ar">لديه ميزة إمكانية الوصول</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على ميزة إمكانية الوصول</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasCrowdLevel -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasCrowdLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.jordantourism.org/ontology#hasRealTimeData"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#CrowdLevel"/>
        <cqReference>CQ-300</cqReference>
        <rdfs:label xml:lang="en">has crowd level</rdfs:label>
        <rdfs:label xml:lang="ar">لديه مستوى ازدحام</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasCulturalSignificance -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasCulturalSignificance">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#CulturalConcept"/>
        <rdfs:comment xml:lang="en">Links an attraction to its cultural significance.</rdfs:comment>
        <rdfs:label xml:lang="en">has cultural significance</rdfs:label>
        <rdfs:label xml:lang="ar">له أهمية ثقافية</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasDressCode -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasDressCode">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#DressCode"/>
        <rdfs:comment xml:lang="en">Links a place to its dress code requirements.</rdfs:comment>
        <rdfs:label xml:lang="en">has dress code</rdfs:label>
        <rdfs:label xml:lang="ar">له قواعد لباس</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasEmergencyContact -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasEmergencyContact">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#EmergencyContact"/>
        <cqReference>CQ-145</cqReference>
        <rdfs:label xml:lang="en">has emergency contact</rdfs:label>
        <rdfs:label xml:lang="ar">لديه اتصال طوارئ</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasEvent -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasEvent">
        <owl:inverseOf rdf:resource="http://www.jordantourism.org/ontology#occursAt"/>
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Event"/>
        <rdfs:comment xml:lang="en">Links a place to events that occur there.</rdfs:comment>
        <rdfs:label xml:lang="en">has event</rdfs:label>
        <rdfs:label xml:lang="ar">لديه حدث</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasFacility -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasFacility">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Facility"/>
        <rdfs:comment xml:lang="en">Links an attraction or accommodation to its facilities.</rdfs:comment>
        <rdfs:label xml:lang="en">has facility</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على مرفق</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasFamilySuitability -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasFamilySuitability">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#FamilySuitability"/>
        <rdfs:comment xml:lang="en">Links an attraction or accommodation to its family suitability.</rdfs:comment>
        <rdfs:label xml:lang="en">has family suitability</rdfs:label>
        <rdfs:label xml:lang="ar">له ملاءمة عائلية</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasForecast -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasForecast">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#ForecastPoint"/>
        <rdfs:label xml:lang="en">has forecast</rdfs:label>
        <rdfs:label xml:lang="ar">لديه توقع</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasGenderPolicy -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasGenderPolicy">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#GenderConsideration"/>
        <rdfs:comment xml:lang="en">Links a facility to its gender-specific policies.</rdfs:comment>
        <rdfs:label xml:lang="en">has gender policy</rdfs:label>
        <rdfs:label xml:lang="ar">له سياسة جنسانية</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasGeometry -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasGeometry">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
        <rdfs:label xml:lang="ar">لديه هندسة</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasGuide -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasGuide">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Activity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Guide"/>
        <cqReference>CQ-114</cqReference>
        <rdfs:label xml:lang="en">has guide</rdfs:label>
        <rdfs:label xml:lang="ar">لديه مرشد</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasLightPollutionLevel -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasLightPollutionLevel">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#LightPollutionLevel"/>
        <cqReference>CQ-276</cqReference>
        <rdfs:label xml:lang="en">has light pollution level</rdfs:label>
        <rdfs:label xml:lang="ar">لديه مستوى تلوث ضوئي</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasLocation -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasLocation">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Location"/>
        <rdfs:comment xml:lang="en">Future-ready property: link a TourismEntity to a Location individual (e.g., a GeoSPARQL Feature/Geometry). Current v1 data may still use latitude/longitude directly.</rdfs:comment>
        <rdfs:label xml:lang="en">has location</rdfs:label>
        <rdfs:label xml:lang="ar">له موقع</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasMobilityOption -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasMobilityOption">
        <rdfs:subPropertyOf rdf:resource="http://www.jordantourism.org/ontology#hasAccessibilityFeature"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#MobilityOption"/>
        <cqReference>CQ-226</cqReference>
        <rdfs:label xml:lang="en">has mobility option</rdfs:label>
        <rdfs:label xml:lang="ar">لديه خيار تنقل</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasNaturalHazard -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasNaturalHazard">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#Place"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#NaturalHazard"/>
        <cqReference>CQ-267</cqReference>
        <rdfs:label xml:lang="en">has natural hazard</rdfs:label>
        <rdfs:label xml:lang="ar">لديه خطر طبيعي</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasObservation -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasObservation">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Observation"/>
        <rdfs:label xml:lang="en">has observation</rdfs:label>
        <rdfs:label xml:lang="ar">لديه ملاحظة</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasPolicy -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasPolicy">
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#Policy"/>
        <rdfs:comment xml:lang="en">Links an attraction to applicable policies.</rdfs:comment>
        <rdfs:label xml:lang="en">has policy</rdfs:label>
        <rdfs:label xml:lang="ar">له سياسة</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.jordantourism.org/ontology#hasPrediction -->

    <owl:ObjectProperty rdf:about="http://www.jordantourism.org/ontology#hasPrediction">
        <rdfs:domain rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
        <rdfs:range rdf:resource="http://www.jordantourism.org/ontology#PredictionModel"/>
