    <!-- http://www.jordantourism.org/ontology#RamadanBehavior -->

    <owl:NamedIndividual rdf:about="http://www.jordantourism.org/ontology#RamadanBehavior">
        <rdf:type rdf:resource="http://www.jordantourism.org/ontology#RamadanEtiquette"/>
        <rdfs:comment xml:lang="en">During Ramadan daylight hours: avoid eating, drinking, or smoking in public. Dress more conservatively. Be patient with slower services. Experience iftar (breaking fast) meals. Enjoy vibrant nightlife after sunset.</rdfs:comment>
        <rdfs:label xml:lang="en">Ramadan Behavior Guidelines</rdfs:label>
        <rdfs:label xml:lang="ar">إرشادات سلوك رمضان</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.jordantourism.org/ontology#RamadanInJordan -->

    <owl:NamedIndividual rdf:about="http://www.jordantourism.org/ontology#RamadanInJordan">
        <rdf:type rdf:resource="http://www.jordantourism.org/ontology#RamadanObservance"/>
        <ramadanHoursEnd rdf:datatype="http://www.w3.org/2001/XMLSchema#time">15:00:00</ramadanHoursEnd>
        <ramadanHoursStart rdf:datatype="http://www.w3.org/2001/XMLSchema#time">09:00:00</ramadanHoursStart>
        <rdfs:comment xml:lang="en">During Ramadan, many restaurants close during daylight hours. Tourist hotels typically still serve food to non-Muslim guests discreetly. Public eating, drinking, and smoking should be avoided out of respect.</rdfs:comment>
        <rdfs:label xml:lang="en">Ramadan in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">رمضان في الأردن</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.jordantourism.org/ontology#RamadanVisitorGuide -->

    <owl:NamedIndividual rdf:about="http://www.jordantourism.org/ontology#RamadanVisitorGuide">
        <rdf:type rdf:resource="http://www.jordantourism.org/ontology#RamadanEtiquette"/>
        <culturalTip>Ramadan is a special time to experience Jordan - consider attending an iftar meal.</culturalTip>
        <etiquetteDescription>During Ramadan, avoid eating, drinking, or smoking in public during fasting hours. Many restaurants close until iftar. Attractions may have reduced hours.</etiquetteDescription>
        <rdfs:label xml:lang="en">Ramadan Visitor Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل الزائر في رمضان</rdfs:label>
    </owl:NamedIndividual>
    


