  <rdf:Description rdf:about="http://www.jordantourism.org/ontology#BedouinHospitalityExperience">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.jordantourism.org/ontology#BedouinTradition"/>
    <rdfs:comment xml:lang="en">Traditional Bedouin hospitality in Wadi Rum and desert areas. Includes Arabic coffee ceremony, zarb (underground BBQ), storytelling, and sleeping in goat-hair tents. Deep-rooted tradition of welcoming strangers.</rdfs:comment>
    <rdfs:label xml:lang="en">Bedouin Hospitality Experience</rdfs:label>
    <rdfs:label xml:lang="ar">تجربة الضيافة البدوية</rdfs:label>
    <jto:officialName xml:lang="en">Bedouin Hospitality Experience</jto:officialName>
    <jto:officialName xml:lang="ar">تجربة الضيافة البدوية</jto:officialName>
  </rdf:Description>
