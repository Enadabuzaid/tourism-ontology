    <!-- http://www.jordantourism.org/ontology#TourismEntityCoreShape -->

    <rdf:Description rdf:about="http://www.jordantourism.org/ontology#TourismEntityCoreShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <shacl:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">180</shacl:maxInclusive>
                <shacl:message>TourismEntity must have longitude as xsd:decimal between -180 and 180.</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-180</shacl:minInclusive>
                <shacl:path rdf:resource="http://www.jordantourism.org/ontology#longitude"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
                <shacl:message>Every TourismEntity must have at least one officialName with a language tag (e.g., @en, @ar).</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://www.jordantourism.org/ontology#officialName"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <shacl:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">90</shacl:maxInclusive>
                <shacl:message>TourismEntity must have latitude as xsd:decimal between -90 and 90.</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-90</shacl:minInclusive>
                <shacl:path rdf:resource="http://www.jordantourism.org/ontology#latitude"/>
            </rdf:Description>
        </shacl:property>
        <shacl:targetClass rdf:resource="http://www.jordantourism.org/ontology#TourismEntity"/>
    </rdf:Description>
    


