        <rdfs:label xml:lang="ar">التوفر الفوري</rdfs:label>
        <rdfs:comment xml:lang="en">Real-time availability information for bookings.</rdfs:comment>
        <jto:cqReference>CQ-299</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HotelAvailability">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeAvailability"/>
        <rdfs:label xml:lang="en">Hotel Availability</rdfs:label>
        <rdfs:label xml:lang="ar">توفر الفنادق</rdfs:label>
