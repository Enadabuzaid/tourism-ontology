    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- RELIGIOUS PRACTICE HIERARCHY                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;ReligiousPractice">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Religious Practice</rdfs:label>
        <rdfs:label xml:lang="ar">ممارسة دينية</rdfs:label>
        <rdfs:comment xml:lang="en">Religious practices and observances that may affect tourism activities and schedules.</rdfs:comment>
        <jto:cqReference>CQ-035, CQ-036, CQ-037</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;IslamicPractice">
        <rdfs:subClassOf rdf:resource="&jto;ReligiousPractice"/>
        <rdfs:label xml:lang="en">Islamic Practice</rdfs:label>
        <rdfs:label xml:lang="ar">ممارسة إسلامية</rdfs:label>
        <rdfs:comment xml:lang="en">Islamic religious practices observed in Jordan.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;RamadanObservance">
        <rdfs:subClassOf rdf:resource="&jto;IslamicPractice"/>
        <rdfs:label xml:lang="en">Ramadan Observance</rdfs:label>
        <rdfs:label xml:lang="ar">شهر رمضان</rdfs:label>
        <jto:altLabelAR>صيام رمضان</jto:altLabelAR>
        <rdfs:comment xml:lang="en">The holy month of Ramadan with fasting from dawn to sunset. Affects restaurant hours, public eating etiquette, and attraction schedules.</rdfs:comment>
        <jto:cqReference>CQ-035, CQ-036</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DailyPrayer">
        <rdfs:subClassOf rdf:resource="&jto;IslamicPractice"/>
        <rdfs:label xml:lang="en">Daily Prayer</rdfs:label>
        <rdfs:label xml:lang="ar">الصلوات الخمس</rdfs:label>
        <jto:altLabelAR>الصلاة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Five daily prayers observed by Muslims. May affect business hours briefly.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;FridayPrayer">
        <rdfs:subClassOf rdf:resource="&jto;IslamicPractice"/>
        <rdfs:label xml:lang="en">Friday Prayer</rdfs:label>
        <rdfs:label xml:lang="ar">صلاة الجمعة</rdfs:label>
        <rdfs:comment xml:lang="en">Congregational Friday prayer. Many businesses close during midday Friday.</rdfs:comment>
        <jto:cqReference>CQ-037</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;EidCelebration">
        <rdfs:subClassOf rdf:resource="&jto;IslamicPractice"/>
        <rdfs:label xml:lang="en">Eid Celebration</rdfs:label>
        <rdfs:label xml:lang="ar">عيد</rdfs:label>
        <rdfs:comment xml:lang="en">Islamic holidays (Eid al-Fitr, Eid al-Adha) with special celebrations and closures.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;EidAlFitr">
        <rdfs:subClassOf rdf:resource="&jto;EidCelebration"/>
        <rdfs:label xml:lang="en">Eid al-Fitr</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الفطر</rdfs:label>
        <rdfs:comment xml:lang="en">Festival marking the end of Ramadan. 3-4 day holiday with family gatherings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;EidAlAdha">
        <rdfs:subClassOf rdf:resource="&jto;EidCelebration"/>
        <rdfs:label xml:lang="en">Eid al-Adha</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الأضحى</rdfs:label>
        <jto:altLabelAR>عيد الكبير</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Festival of Sacrifice. 4-5 day holiday, coincides with Hajj pilgrimage.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChristianPractice">
        <rdfs:subClassOf rdf:resource="&jto;ReligiousPractice"/>
        <rdfs:label xml:lang="en">Christian Practice</rdfs:label>
        <rdfs:label xml:lang="ar">ممارسة مسيحية</rdfs:label>
        <rdfs:comment xml:lang="en">Christian religious practices observed by Jordan's Christian community.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;EasterCelebration">
        <rdfs:subClassOf rdf:resource="&jto;ChristianPractice"/>
        <rdfs:label xml:lang="en">Easter Celebration</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الفصح</rdfs:label>
        <rdfs:comment xml:lang="en">Easter celebrations, especially significant at baptism sites.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChristmasCelebration">
        <rdfs:subClassOf rdf:resource="&jto;ChristianPractice"/>
        <rdfs:label xml:lang="en">Christmas Celebration</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الميلاد</rdfs:label>
        <rdfs:comment xml:lang="en">Christmas celebrations in Jordan's Christian communities.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- DIETARY REQUIREMENT HIERARCHY                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;DietaryRequirement">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Dietary Requirement</rdfs:label>
        <rdfs:label xml:lang="ar">متطلبات غذائية</rdfs:label>
        <rdfs:comment xml:lang="en">Dietary restrictions and preferences based on religious or personal beliefs.</rdfs:comment>
        <jto:cqReference>CQ-040, CQ-041, CQ-042</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HalalRequirement">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Halal Requirement</rdfs:label>
        <rdfs:label xml:lang="ar">حلال</rdfs:label>
        <rdfs:comment xml:lang="en">Islamic dietary law requiring permissible food preparation. Most restaurants in Jordan are halal by default.</rdfs:comment>
        <jto:cqReference>CQ-040</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HaramFood">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Haram Food</rdfs:label>
        <rdfs:label xml:lang="ar">حرام</rdfs:label>
        <rdfs:comment xml:lang="en">Foods prohibited in Islam (pork, alcohol for consumption).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;VegetarianDiet">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Vegetarian Diet</rdfs:label>
        <rdfs:label xml:lang="ar">نظام غذائي نباتي</rdfs:label>
        <rdfs:comment xml:lang="en">Diet excluding meat. Traditional Jordanian cuisine has many vegetarian options (hummus, falafel, moutabel).</rdfs:comment>
        <jto:cqReference>CQ-041</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;VeganDiet">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Vegan Diet</rdfs:label>
        <rdfs:label xml:lang="ar">نظام غذائي نباتي صرف</rdfs:label>
        <rdfs:comment xml:lang="en">Diet excluding all animal products.</rdfs:comment>
        <jto:cqReference>CQ-042</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;KosherRequirement">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Kosher Requirement</rdfs:label>
        <rdfs:label xml:lang="ar">كوشر</rdfs:label>
        <rdfs:comment xml:lang="en">Jewish dietary law. Limited availability in Jordan.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;GlutenFree">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Gluten-Free Diet</rdfs:label>
        <rdfs:label xml:lang="ar">خالي من الغلوتين</rdfs:label>
        <rdfs:comment xml:lang="en">Diet avoiding gluten-containing foods.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;AlcoholConsumption">
        <rdfs:subClassOf rdf:resource="&jto;DietaryRequirement"/>
        <rdfs:label xml:lang="en">Alcohol Consumption</rdfs:label>
        <rdfs:label xml:lang="ar">استهلاك الكحول</rdfs:label>
        <rdfs:comment xml:lang="en">Alcohol is available in Jordan at licensed hotels, restaurants, and shops, though not widely consumed publicly.</rdfs:comment>
        <jto:cqReference>CQ-263</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- DRESS CODE HIERARCHY                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;DressCode">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Dress Code</rdfs:label>
        <rdfs:label xml:lang="ar">قواعد اللباس</rdfs:label>
        <rdfs:comment xml:lang="en">Clothing requirements or recommendations for specific locations or occasions.</rdfs:comment>
        <jto:cqReference>CQ-043, CQ-044, CQ-045</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ModestDress">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Modest Dress</rdfs:label>
        <rdfs:label xml:lang="ar">لباس محتشم</rdfs:label>
        <rdfs:comment xml:lang="en">Conservative clothing covering shoulders and knees. Recommended for religious sites and traditional areas.</rdfs:comment>
        <jto:cqReference>CQ-043</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;MosqueDressCode">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Mosque Dress Code</rdfs:label>
        <rdfs:label xml:lang="ar">لباس المسجد</rdfs:label>
        <rdfs:comment xml:lang="en">Specific dress requirements for visiting mosques: remove shoes, women cover hair, long sleeves and pants/skirts.</rdfs:comment>
        <jto:cqReference>CQ-044</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChurchDressCode">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Church Dress Code</rdfs:label>
        <rdfs:label xml:lang="ar">لباس الكنيسة</rdfs:label>
        <rdfs:comment xml:lang="en">Modest dress for visiting churches and Christian holy sites.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BeachDressCode">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Beach Dress Code</rdfs:label>
        <rdfs:label xml:lang="ar">لباس الشاطئ</rdfs:label>
        <rdfs:comment xml:lang="en">Swimming attire acceptable at hotel pools and private beaches. Public beaches require more modest swimwear.</rdfs:comment>
        <jto:cqReference>CQ-045</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HeadCovering">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Head Covering</rdfs:label>
        <rdfs:label xml:lang="ar">غطاء الرأس</rdfs:label>
        <jto:altLabelAR>حجاب</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Head covering for women, required at mosques and recommended at some religious sites.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ShoeRemoval">
        <rdfs:subClassOf rdf:resource="&jto;DressCode"/>
        <rdfs:label xml:lang="en">Shoe Removal</rdfs:label>
        <rdfs:label xml:lang="ar">خلع الأحذية</rdfs:label>
        <rdfs:comment xml:lang="en">Removing shoes before entering mosques and some traditional homes.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL ETIQUETTE HIERARCHY                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;CulturalEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Cultural Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب ثقافية</rdfs:label>
        <rdfs:comment xml:lang="en">Social customs and behavioral norms in Jordanian culture.</rdfs:comment>
        <jto:cqReference>CQ-046, CQ-047, CQ-048, CQ-049</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;GreetingEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Greeting Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب التحية</rdfs:label>
        <rdfs:comment xml:lang="en">Proper greetings: 'As-salamu alaykum' (peace be upon you), handshakes between same gender, avoid physical contact between opposite genders unless initiated.</rdfs:comment>
        <jto:cqReference>CQ-046</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HospitalityCustom">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Hospitality Custom</rdfs:label>
        <rdfs:label xml:lang="ar">عادات الضيافة</rdfs:label>
        <jto:altLabelAR>كرم الضيافة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Jordanian hospitality traditions: accepting offered coffee/tea, removing shoes when entering homes, bringing small gifts.</rdfs:comment>
        <jto:cqReference>CQ-047</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;TippingCustom">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Tipping Custom</rdfs:label>
        <rdfs:label xml:lang="ar">عادات البقشيش</rdfs:label>
        <rdfs:comment xml:lang="en">Tipping practices: 10% at restaurants, small tips for guides, drivers, and hotel staff.</rdfs:comment>
        <jto:cqReference>CQ-048</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BargainingCustom">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Bargaining Custom</rdfs:label>
        <rdfs:label xml:lang="ar">عادات المساومة</rdfs:label>
        <jto:altLabelAR>الفصال</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Negotiating prices at souks and markets is expected and part of the shopping experience.</rdfs:comment>
        <jto:cqReference>CQ-049</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;PhotographyEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Photography Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب التصوير</rdfs:label>
        <rdfs:comment xml:lang="en">Ask permission before photographing people, especially women. Some military/government buildings prohibited.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DiningEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Dining Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب الطعام</rdfs:label>
        <rdfs:comment xml:lang="en">Eat with right hand, accept food offerings, say 'Bismillah' before eating.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;RamadanEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalEtiquette"/>
        <rdfs:label xml:lang="en">Ramadan Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب رمضان</rdfs:label>
        <rdfs:comment xml:lang="en">During Ramadan: avoid eating, drinking, smoking in public during daylight; dress more conservatively.</rdfs:comment>
        <jto:cqReference>CQ-036</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- GENDER CONSIDERATION HIERARCHY                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;GenderConsideration">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Gender Consideration</rdfs:label>
        <rdfs:label xml:lang="ar">اعتبارات الجنس</rdfs:label>
        <rdfs:comment xml:lang="en">Gender-specific cultural norms and facilities in Jordan.</rdfs:comment>
        <jto:cqReference>CQ-234, CQ-235</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WomenOnlySpace">
        <rdfs:subClassOf rdf:resource="&jto;GenderConsideration"/>
        <rdfs:label xml:lang="en">Women-Only Space</rdfs:label>
        <rdfs:label xml:lang="ar">مساحة للنساء فقط</rdfs:label>
        <rdfs:comment xml:lang="en">Designated areas for women only (spas, gym hours, taxi services).</rdfs:comment>
        <jto:cqReference>CQ-234</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;FamilySection">
        <rdfs:subClassOf rdf:resource="&jto;GenderConsideration"/>
        <rdfs:label xml:lang="en">Family Section</rdfs:label>
        <rdfs:label xml:lang="ar">قسم العائلات</rdfs:label>
        <rdfs:comment xml:lang="en">Designated family areas in restaurants and public spaces, separate from singles sections.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;GenderInteraction">
        <rdfs:subClassOf rdf:resource="&jto;GenderConsideration"/>
        <rdfs:label xml:lang="en">Gender Interaction Norms</rdfs:label>
        <rdfs:label xml:lang="ar">قواعد التعامل بين الجنسين</rdfs:label>
        <rdfs:comment xml:lang="en">Social norms for interaction between genders: limited physical contact, conservative behavior in public.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;WomenTravelerSafety">
        <rdfs:subClassOf rdf:resource="&jto;GenderConsideration"/>
        <rdfs:label xml:lang="en">Women Traveler Safety</rdfs:label>
        <rdfs:label xml:lang="ar">سلامة المسافرات</rdfs:label>
        <rdfs:comment xml:lang="en">Safety considerations and tips for solo women travelers in Jordan.</rdfs:comment>
        <jto:cqReference>CQ-235</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- TRADITIONAL PRACTICE HIERARCHY                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;TraditionalPractice">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Traditional Practice</rdfs:label>
        <rdfs:label xml:lang="ar">ممارسة تقليدية</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Jordanian and Bedouin cultural practices.</rdfs:comment>
        <jto:cqReference>CQ-130, CQ-131, CQ-132</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BedouinTradition">
        <rdfs:subClassOf rdf:resource="&jto;TraditionalPractice"/>
        <rdfs:label xml:lang="en">Bedouin Tradition</rdfs:label>
        <rdfs:label xml:lang="ar">تقاليد بدوية</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Bedouin customs and hospitality practices.</rdfs:comment>
        <jto:cqReference>CQ-130</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArabicCoffeeCeremony">
        <rdfs:subClassOf rdf:resource="&jto;TraditionalPractice"/>
        <rdfs:label xml:lang="en">Arabic Coffee Ceremony</rdfs:label>
        <rdfs:label xml:lang="ar">تقديم القهوة العربية</rdfs:label>
        <jto:altLabelAR>قهوة سادة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Traditional serving of Arabic coffee (qahwa) with cardamom. Accept with right hand, shake cup when finished.</rdfs:comment>
        <jto:cqReference>CQ-131</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;MansafTradition">
        <rdfs:subClassOf rdf:resource="&jto;TraditionalPractice"/>
        <rdfs:label xml:lang="en">Mansaf Tradition</rdfs:label>
        <rdfs:label xml:lang="ar">تقاليد المنسف</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional serving and eating of mansaf, Jordan's national dish. Eaten with right hand from communal platter.</rdfs:comment>
        <jto:cqReference>CQ-132</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HennaTradition">
        <rdfs:subClassOf rdf:resource="&jto;TraditionalPractice"/>
        <rdfs:label xml:lang="en">Henna Tradition</rdfs:label>
        <rdfs:label xml:lang="ar">تقاليد الحناء</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional henna art for celebrations and weddings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;TribalCustom">
        <rdfs:subClassOf rdf:resource="&jto;TraditionalPractice"/>
        <rdfs:label xml:lang="en">Tribal Custom</rdfs:label>
        <rdfs:label xml:lang="ar">عادات قبلية</rdfs:label>
        <rdfs:comment xml:lang="en">Tribal traditions still observed in many Jordanian communities.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- LANGUAGE CONSIDERATION HIERARCHY                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;LanguageConsideration">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Language Consideration</rdfs:label>
        <rdfs:label xml:lang="ar">اعتبارات لغوية</rdfs:label>
        <rdfs:comment xml:lang="en">Language-related cultural aspects for tourists.</rdfs:comment>
        <jto:cqReference>CQ-070, CQ-071</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArabicPhrase">
        <rdfs:subClassOf rdf:resource="&jto;LanguageConsideration"/>
        <rdfs:label xml:lang="en">Arabic Phrase</rdfs:label>
        <rdfs:label xml:lang="ar">عبارة عربية</rdfs:label>
        <rdfs:comment xml:lang="en">Common Arabic phrases useful for tourists.</rdfs:comment>
        <jto:cqReference>CQ-070</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;JordanianDialect">
        <rdfs:subClassOf rdf:resource="&jto;LanguageConsideration"/>
        <rdfs:label xml:lang="en">Jordanian Dialect</rdfs:label>
        <rdfs:label xml:lang="ar">اللهجة الأردنية</rdfs:label>
        <rdfs:comment xml:lang="en">Local Jordanian Arabic dialect variations from Modern Standard Arabic.</rdfs:comment>
        <jto:cqReference>CQ-071</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BilingualSupport">
        <rdfs:subClassOf rdf:resource="&jto;LanguageConsideration"/>
        <rdfs:label xml:lang="en">Bilingual Support</rdfs:label>
        <rdfs:label xml:lang="ar">دعم ثنائي اللغة</rdfs:label>
        <rdfs:comment xml:lang="en">Availability of English/Arabic bilingual services and signage.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL SENSITIVITY HIERARCHY                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;CulturalSensitivity">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Cultural Sensitivity</rdfs:label>
        <rdfs:label xml:lang="ar">حساسية ثقافية</rdfs:label>
        <rdfs:comment xml:lang="en">Topics and behaviors requiring cultural awareness and sensitivity.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;PoliticalSensitivity">
        <rdfs:subClassOf rdf:resource="&jto;CulturalSensitivity"/>
        <rdfs:label xml:lang="en">Political Sensitivity</rdfs:label>
        <rdfs:label xml:lang="ar">حساسية سياسية</rdfs:label>
        <rdfs:comment xml:lang="en">Topics to approach with care: regional politics, royal family respect.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ReligiousSensitivity">
        <rdfs:subClassOf rdf:resource="&jto;CulturalSensitivity"/>
        <rdfs:label xml:lang="en">Religious Sensitivity</rdfs:label>
        <rdfs:label xml:lang="ar">حساسية دينية</rdfs:label>
        <rdfs:comment xml:lang="en">Respect for Islamic practices and religious sites of all faiths.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- FAMILY SUITABILITY HIERARCHY                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;FamilySuitability">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Family Suitability</rdfs:label>
        <rdfs:label xml:lang="ar">ملاءمة للعائلات</rdfs:label>
        <rdfs:comment xml:lang="en">Family-friendliness considerations for attractions and accommodations.</rdfs:comment>
        <jto:cqReference>CQ-005, CQ-006, CQ-007</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChildFriendly">
        <rdfs:subClassOf rdf:resource="&jto;FamilySuitability"/>
        <rdfs:label xml:lang="en">Child Friendly</rdfs:label>
        <rdfs:label xml:lang="ar">مناسب للأطفال</rdfs:label>
        <rdfs:comment xml:lang="en">Suitable for children with appropriate facilities and activities.</rdfs:comment>
        <jto:cqReference>CQ-005</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;AdultsOnly">
        <rdfs:subClassOf rdf:resource="&jto;FamilySuitability"/>
        <rdfs:label xml:lang="en">Adults Only</rdfs:label>
        <rdfs:label xml:lang="ar">للبالغين فقط</rdfs:label>
        <rdfs:comment xml:lang="en">Restricted to adult guests only.</rdfs:comment>
        <jto:cqReference>CQ-007</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;AllAges">
        <rdfs:subClassOf rdf:resource="&jto;FamilySuitability"/>
        <rdfs:label xml:lang="en">All Ages</rdfs:label>
        <rdfs:label xml:lang="ar">لجميع الأعمار</rdfs:label>
        <rdfs:comment xml:lang="en">Suitable for visitors of all ages.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- NATIONAL CELEBRATION HIERARCHY                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;NationalCelebration">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">National Celebration</rdfs:label>
        <rdfs:label xml:lang="ar">احتفال وطني</rdfs:label>
        <rdfs:comment xml:lang="en">Jordanian national holidays and celebrations.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;IndependenceDay">
        <rdfs:subClassOf rdf:resource="&jto;NationalCelebration"/>
        <rdfs:label xml:lang="en">Independence Day</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الاستقلال</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan's Independence Day on May 25th.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;KingsDay">
        <rdfs:subClassOf rdf:resource="&jto;NationalCelebration"/>
        <rdfs:label xml:lang="en">King's Birthday</rdfs:label>
        <rdfs:label xml:lang="ar">عيد ميلاد الملك</rdfs:label>
        <rdfs:comment xml:lang="en">King Abdullah II's birthday celebrated on January 30th.</rdfs:comment>
    </owl:Class>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL CONCEPT OBJECT PROPERTIES                                           -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:ObjectProperty rdf:about="&jto;requiresDressCode">
        <rdfs:label xml:lang="en">requires dress code</rdfs:label>
        <rdfs:label xml:lang="ar">يتطلب لباس</rdfs:label>
        <rdfs:comment xml:lang="en">Links a place to its dress code requirements.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;DressCode"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;supportsDietaryRequirement">
        <rdfs:label xml:lang="en">supports dietary requirement</rdfs:label>
        <rdfs:label xml:lang="ar">يدعم متطلبات غذائية</rdfs:label>
        <rdfs:comment xml:lang="en">Links a food venue to dietary requirements it accommodates.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;FoodVenue"/>
        <rdfs:range rdf:resource="&jto;DietaryRequirement"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;affectedByPractice">
        <rdfs:label xml:lang="en">affected by practice</rdfs:label>
        <rdfs:label xml:lang="ar">يتأثر بممارسة</rdfs:label>
        <rdfs:comment xml:lang="en">Links a place or service to religious/cultural practices that affect it.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;ReligiousPractice"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasFamilySuitability">
        <rdfs:label xml:lang="en">has family suitability</rdfs:label>
        <rdfs:label xml:lang="ar">له ملاءمة عائلية</rdfs:label>
        <rdfs:comment xml:lang="en">Links an attraction or accommodation to its family suitability.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;FamilySuitability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;observesEtiquette">
        <rdfs:label xml:lang="en">observes etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">يلتزم بالآداب</rdfs:label>
        <rdfs:comment xml:lang="en">Links a place or activity to relevant cultural etiquette.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;CulturalEtiquette"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasGenderPolicy">
        <rdfs:label xml:lang="en">has gender policy</rdfs:label>
        <rdfs:label xml:lang="ar">له سياسة جنسانية</rdfs:label>
        <rdfs:comment xml:lang="en">Links a facility to its gender-specific policies.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;GenderConsideration"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;preservesTradition">
        <rdfs:label xml:lang="en">preserves tradition</rdfs:label>
        <rdfs:label xml:lang="ar">يحافظ على تقليد</rdfs:label>
        <rdfs:comment xml:lang="en">Links a place or activity to traditional practices it preserves.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;TraditionalPractice"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;requiresSensitivity">
        <rdfs:label xml:lang="en">requires sensitivity</rdfs:label>
        <rdfs:label xml:lang="ar">يتطلب حساسية</rdfs:label>
        <rdfs:comment xml:lang="en">Links a topic or location to cultural sensitivities.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;CulturalSensitivity"/>
    </owl:ObjectProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL CONCEPT DATA PROPERTIES                                             -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:DatatypeProperty rdf:about="&jto;ramadanHoursStart">
        <rdfs:label xml:lang="en">Ramadan hours start</rdfs:label>
        <rdfs:label xml:lang="ar">بداية ساعات رمضان</rdfs:label>
        <rdfs:comment xml:lang="en">Modified opening hours during Ramadan.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;ramadanHoursEnd">
        <rdfs:label xml:lang="en">Ramadan hours end</rdfs:label>
        <rdfs:label xml:lang="ar">نهاية ساعات رمضان</rdfs:label>
        <rdfs:comment xml:lang="en">Modified closing hours during Ramadan.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;fridayClosureStart">
        <rdfs:label xml:lang="en">Friday closure start</rdfs:label>
        <rdfs:label xml:lang="ar">بداية إغلاق الجمعة</rdfs:label>
        <rdfs:comment xml:lang="en">Start time of Friday prayer closure.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;fridayClosureEnd">
        <rdfs:label xml:lang="en">Friday closure end</rdfs:label>
        <rdfs:label xml:lang="ar">نهاية إغلاق الجمعة</rdfs:label>
        <rdfs:comment xml:lang="en">End time of Friday prayer closure.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isHalalDefault">
        <rdfs:label xml:lang="en">is halal by default</rdfs:label>
        <rdfs:label xml:lang="ar">حلال افتراضياً</rdfs:label>
        <rdfs:comment xml:lang="en">Whether a food venue is halal by default (most are in Jordan).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;dressCodeRequired">
        <rdfs:label xml:lang="en">dress code required</rdfs:label>
        <rdfs:label xml:lang="ar">اللباس مطلوب</rdfs:label>
        <rdfs:comment xml:lang="en">Whether a specific dress code is required (not just recommended).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;headscarfProvided">
        <rdfs:label xml:lang="en">headscarf provided</rdfs:label>
        <rdfs:label xml:lang="ar">يوفر غطاء رأس</rdfs:label>
        <rdfs:comment xml:lang="en">Whether headscarves are provided for visitors at religious sites.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;recommendedTipPercent">
        <rdfs:label xml:lang="en">recommended tip percent</rdfs:label>
        <rdfs:label xml:lang="ar">نسبة البقشيش الموصى بها</rdfs:label>
        <rdfs:comment xml:lang="en">Recommended tipping percentage for a service type.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;bargainingExpected">
        <rdfs:label xml:lang="en">bargaining expected</rdfs:label>
        <rdfs:label xml:lang="ar">المساومة متوقعة</rdfs:label>
        <rdfs:comment xml:lang="en">Whether bargaining is expected at this shopping venue.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;minimumAge">
        <rdfs:label xml:lang="en">minimum age</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأدنى للعمر</rdfs:label>
        <rdfs:comment xml:lang="en">Minimum age requirement for an activity or venue.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;womenOnlyHours">
        <rdfs:label xml:lang="en">women only hours</rdfs:label>
        <rdfs:label xml:lang="ar">ساعات للنساء فقط</rdfs:label>
        <rdfs:comment xml:lang="en">Specific hours designated for women only.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;arabicPhraseText">
        <rdfs:label xml:lang="en">Arabic phrase text</rdfs:label>
        <rdfs:label xml:lang="ar">نص العبارة العربية</rdfs:label>
        <rdfs:comment xml:lang="en">The Arabic text of a useful phrase.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;arabicPhrasePronunciation">
        <rdfs:label xml:lang="en">Arabic phrase pronunciation</rdfs:label>
        <rdfs:label xml:lang="ar">نطق العبارة العربية</rdfs:label>
        <rdfs:comment xml:lang="en">Transliterated pronunciation guide for Arabic phrase.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;arabicPhraseMeaning">
        <rdfs:label xml:lang="en">Arabic phrase meaning</rdfs:label>
        <rdfs:label xml:lang="ar">معنى العبارة العربية</rdfs:label>
        <rdfs:comment xml:lang="en">English meaning of the Arabic phrase.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL CONCEPT INDIVIDUALS                                                 -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Religious Practice Individuals                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;RamadanInJordan">
        <rdf:type rdf:resource="&jto;RamadanObservance"/>
        <rdfs:label xml:lang="en">Ramadan in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">رمضان في الأردن</rdfs:label>
        <jto:ramadanHoursStart rdf:datatype="&xsd;time">09:00:00</jto:ramadanHoursStart>
        <jto:ramadanHoursEnd rdf:datatype="&xsd;time">15:00:00</jto:ramadanHoursEnd>
        <rdfs:comment xml:lang="en">During Ramadan, many restaurants close during daylight hours. Tourist hotels typically still serve food to non-Muslim guests discreetly. Public eating, drinking, and smoking should be avoided out of respect.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;FridayPrayerTime">
        <rdf:type rdf:resource="&jto;FridayPrayer"/>
        <rdfs:label xml:lang="en">Friday Prayer Time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت صلاة الجمعة</rdfs:label>
        <jto:fridayClosureStart rdf:datatype="&xsd;time">12:00:00</jto:fridayClosureStart>
        <jto:fridayClosureEnd rdf:datatype="&xsd;time">14:00:00</jto:fridayClosureEnd>
        <rdfs:comment xml:lang="en">Many businesses close for Friday prayers between noon and 2 PM. Tourist sites usually remain open.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;EidAlFitrJordan">
        <rdf:type rdf:resource="&jto;EidAlFitr"/>
        <rdfs:label xml:lang="en">Eid al-Fitr in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الفطر في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">3-4 day national holiday. Government offices and many businesses close. Tourist sites may have modified hours. Festive atmosphere with family gatherings.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;EidAlAdhaJordan">
        <rdf:type rdf:resource="&jto;EidAlAdha"/>
        <rdfs:label xml:lang="en">Eid al-Adha in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الأضحى في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">4-5 day national holiday. Important for family visits. Meat dishes are shared with less fortunate. Tourist attractions may have modified hours.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Dietary Requirement Individuals                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;HalalInJordan">
        <rdf:type rdf:resource="&jto;HalalRequirement"/>
        <rdfs:label xml:lang="en">Halal Food in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">الطعام الحلال في الأردن</rdfs:label>
        <jto:isHalalDefault rdf:datatype="&xsd;boolean">true</jto:isHalalDefault>
        <rdfs:comment xml:lang="en">Virtually all restaurants in Jordan serve halal food by default. Non-halal options (pork) are only found in some international hotel restaurants catering to tourists.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;VegetarianInJordan">
        <rdf:type rdf:resource="&jto;VegetarianDiet"/>
        <rdfs:label xml:lang="en">Vegetarian Options in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">الخيارات النباتية في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Jordanian cuisine offers many vegetarian options: hummus, falafel, moutabel, fattoush, tabbouleh, mujaddara. Most restaurants accommodate vegetarians easily.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;AlcoholInJordan">
        <rdf:type rdf:resource="&jto;AlcoholConsumption"/>
        <rdfs:label xml:lang="en">Alcohol in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">الكحول في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Alcohol is legal and available at licensed hotels, restaurants, bars, and liquor stores. Not served during Ramadan in public venues. Public intoxication is frowned upon.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Dress Code Individuals                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;ModestDressJordan">
        <rdf:type rdf:resource="&jto;ModestDress"/>
        <rdfs:label xml:lang="en">Modest Dress in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">اللباس المحتشم في الأردن</rdfs:label>
        <jto:dressCodeRequired rdf:datatype="&xsd;boolean">false</jto:dressCodeRequired>
        <rdfs:comment xml:lang="en">While not legally required, modest dress (covering shoulders and knees) is recommended, especially in traditional areas, markets, and outside tourist zones. More relaxed in Amman and tourist areas.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;MosqueVisitDressCode">
        <rdf:type rdf:resource="&jto;MosqueDressCode"/>
        <rdfs:label xml:lang="en">Mosque Visit Dress Code</rdfs:label>
        <rdfs:label xml:lang="ar">لباس زيارة المسجد</rdfs:label>
        <jto:dressCodeRequired rdf:datatype="&xsd;boolean">true</jto:dressCodeRequired>
        <jto:headscarfProvided rdf:datatype="&xsd;boolean">true</jto:headscarfProvided>
        <rdfs:comment xml:lang="en">Required: Remove shoes, women must cover hair (scarves often provided), long sleeves and pants/long skirts for all. Visit between prayer times.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DeadSeaSwimwear">
        <rdf:type rdf:resource="&jto;BeachDressCode"/>
        <rdfs:label xml:lang="en">Dead Sea Swimwear Guidelines</rdfs:label>
        <rdfs:label xml:lang="ar">إرشادات ملابس البحر الميت</rdfs:label>
        <rdfs:comment xml:lang="en">At private hotel beaches, regular swimwear is acceptable. At public beaches, more modest swimwear is recommended. Full swimsuits are increasingly common for local women.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Cultural Etiquette Individuals                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;JordanianGreetings">
        <rdf:type rdf:resource="&jto;GreetingEtiquette"/>
        <rdfs:label xml:lang="en">Jordanian Greetings</rdfs:label>
        <rdfs:label xml:lang="ar">التحيات الأردنية</rdfs:label>
        <rdfs:comment xml:lang="en">Standard greeting: 'As-salamu alaykum' (peace be upon you), reply 'Wa alaykum as-salam'. Handshakes common between same gender. Wait for woman to extend hand first. Cheek kisses among friends (same gender).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanianHospitality">
        <rdf:type rdf:resource="&jto;HospitalityCustom"/>
        <rdfs:label xml:lang="en">Jordanian Hospitality</rdfs:label>
        <rdfs:label xml:lang="ar">الضيافة الأردنية</rdfs:label>
        <rdfs:comment xml:lang="en">Hospitality is central to Jordanian culture. Accept offered tea/coffee (at least one cup). Remove shoes when entering homes. Bring small gifts when visiting. Refuse food/drink politely 2-3 times before accepting.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;TippingInJordan">
        <rdf:type rdf:resource="&jto;TippingCustom"/>
        <rdfs:label xml:lang="en">Tipping in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">البقشيش في الأردن</rdfs:label>
        <jto:recommendedTipPercent rdf:datatype="&xsd;integer">10</jto:recommendedTipPercent>
        <rdfs:comment xml:lang="en">Restaurants: 10% if service not included. Hotels: 1-2 JOD for porters. Guides: 5-10 JOD per day. Taxi: round up fare. Tour drivers: 3-5 JOD per day.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;BargainingInSouks">
        <rdf:type rdf:resource="&jto;BargainingCustom"/>
        <rdfs:label xml:lang="en">Bargaining in Jordanian Souks</rdfs:label>
        <rdfs:label xml:lang="ar">المساومة في الأسواق الأردنية</rdfs:label>
        <jto:bargainingExpected rdf:datatype="&xsd;boolean">true</jto:bargainingExpected>
        <rdfs:comment xml:lang="en">Bargaining expected in souks and markets. Start at 50-60% of asking price. Be friendly and patient. Walk away if price too high - often brings lower offer. Fixed prices in malls and supermarkets.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;RamadanBehavior">
        <rdf:type rdf:resource="&jto;RamadanEtiquette"/>
        <rdfs:label xml:lang="en">Ramadan Behavior Guidelines</rdfs:label>
        <rdfs:label xml:lang="ar">إرشادات سلوك رمضان</rdfs:label>
        <rdfs:comment xml:lang="en">During Ramadan daylight hours: avoid eating, drinking, or smoking in public. Dress more conservatively. Be patient with slower services. Experience iftar (breaking fast) meals. Enjoy vibrant nightlife after sunset.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Traditional Practice Individuals                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;BedouinHospitalityExperience">
        <rdf:type rdf:resource="&jto;BedouinTradition"/>
        <rdfs:label xml:lang="en">Bedouin Hospitality Experience</rdfs:label>
        <rdfs:label xml:lang="ar">تجربة الضيافة البدوية</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Bedouin hospitality in Wadi Rum and desert areas. Includes Arabic coffee ceremony, zarb (underground BBQ), storytelling, and sleeping in goat-hair tents. Deep-rooted tradition of welcoming strangers.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;ArabicCoffeeRitual">
        <rdf:type rdf:resource="&jto;ArabicCoffeeCeremony"/>
        <rdfs:label xml:lang="en">Arabic Coffee Ritual</rdfs:label>
        <rdfs:label xml:lang="ar">طقوس القهوة العربية</rdfs:label>
        <rdfs:comment xml:lang="en">Coffee (qahwa) with cardamom served in small cups. Accept with right hand. Host pours small amounts repeatedly. Shake cup side-to-side when finished. Refusing first cup is impolite.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;MansafEating">
        <rdf:type rdf:resource="&jto;MansafTradition"/>
        <rdfs:label xml:lang="en">Mansaf Eating Tradition</rdfs:label>
        <rdfs:label xml:lang="ar">تقاليد أكل المنسف</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan's national dish: lamb in fermented yogurt (jameed) on rice. Traditionally eaten standing around communal platter, using right hand to form rice balls. Meat is distributed by host.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Arabic Phrase Individuals                                                    -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;PhraseSalam">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">Greeting: As-salamu alaykum</rdfs:label>
        <rdfs:label xml:lang="ar">السلام عليكم</rdfs:label>
        <jto:arabicPhraseText>السلام عليكم</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>as-sa-LAA-mu a-LAY-kum</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>Peace be upon you (standard greeting)</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PhraseShukran">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">Thank you: Shukran</rdfs:label>
        <rdfs:label xml:lang="ar">شكراً</rdfs:label>
        <jto:arabicPhraseText>شكراً</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>SHUK-ran</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>Thank you</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PhraseInshallah">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">God willing: Inshallah</rdfs:label>
        <rdfs:label xml:lang="ar">إن شاء الله</rdfs:label>
        <jto:arabicPhraseText>إن شاء الله</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>in-SHAA-la</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>God willing / hopefully (used for future events)</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PhraseAhlanWaSahlan">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">Welcome: Ahlan wa sahlan</rdfs:label>
        <rdfs:label xml:lang="ar">أهلاً وسهلاً</rdfs:label>
        <jto:arabicPhraseText>أهلاً وسهلاً</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>AH-lan wa SAH-lan</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>Welcome / You're welcome</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PhraseYalla">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">Let's go: Yalla</rdfs:label>
        <rdfs:label xml:lang="ar">يلا</rdfs:label>
        <jto:arabicPhraseText>يلا</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>YAL-la</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>Let's go / Come on / Hurry up</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PhraseBikam">
        <rdf:type rdf:resource="&jto;ArabicPhrase"/>
        <rdfs:label xml:lang="en">How much: Bikam</rdfs:label>
        <rdfs:label xml:lang="ar">بكم</rdfs:label>
        <jto:arabicPhraseText>بكم؟</jto:arabicPhraseText>
        <jto:arabicPhrasePronunciation>bi-KAM</jto:arabicPhrasePronunciation>
        <jto:arabicPhraseMeaning>How much? (for price)</jto:arabicPhraseMeaning>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Gender Consideration Individuals                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;WomenOnlyServicesJordan">
        <rdf:type rdf:resource="&jto;WomenOnlySpace"/>
        <rdfs:label xml:lang="en">Women-Only Services in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">خدمات للنساء فقط في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Available women-only services include: Pink Taxi (women drivers), women-only gym hours at some hotels, women's sections in hammams, and female tour guides upon request.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;SoloWomenTravelersJordan">
        <rdf:type rdf:resource="&jto;WomenTravelerSafety"/>
        <rdfs:label xml:lang="en">Solo Women Travelers in Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">المسافرات المنفردات في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan is considered one of the safest Middle Eastern countries for solo women travelers. Tips: dress modestly, use registered taxis, stay in reputable hotels, avoid isolated areas at night.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Family Suitability Individuals                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;FamilyFriendlyJordan">
        <rdf:type rdf:resource="&jto;ChildFriendly"/>
        <rdfs:label xml:lang="en">Family-Friendly Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">الأردن صديق للعائلات</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan is very family-friendly. Children are welcomed and adored. Many hotels offer kids clubs, family rooms, and child-friendly pools. Attractions like Petra, Wadi Rum, and the Dead Sea are suitable for all ages.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- National Celebration Individuals                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;JordanIndependenceDay">
        <rdf:type rdf:resource="&jto;IndependenceDay"/>
        <rdfs:label xml:lang="en">Jordan Independence Day</rdfs:label>
        <rdfs:label xml:lang="ar">عيد استقلال الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Celebrated on May 25th. Public holiday with parades and celebrations. Government offices closed. Tourist sites usually remain open.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- SAFETY RATING HIERARCHY ⭐ THESIS INNOVATION                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;SafetyRating">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Safety Rating</rdfs:label>
        <rdfs:label xml:lang="ar">تصنيف السلامة</rdfs:label>
        <rdfs:comment xml:lang="en">Safety classification for tourism areas and activities.</rdfs:comment>
        <jto:cqReference>CQ-231</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HighSafety">
        <rdfs:subClassOf rdf:resource="&jto;SafetyRating"/>
        <rdfs:label xml:lang="en">High Safety</rdfs:label>
        <rdfs:label xml:lang="ar">سلامة عالية</rdfs:label>
        <rdfs:comment xml:lang="en">Area or activity with excellent safety record.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ModerateSafety">
        <rdfs:subClassOf rdf:resource="&jto;SafetyRating"/>
        <rdfs:label xml:lang="en">Moderate Safety</rdfs:label>
        <rdfs:label xml:lang="ar">سلامة معتدلة</rdfs:label>
        <rdfs:comment xml:lang="en">Area requiring normal precautions.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;CautionAdvised">
        <rdfs:subClassOf rdf:resource="&jto;SafetyRating"/>
        <rdfs:label xml:lang="en">Caution Advised</rdfs:label>
        <rdfs:label xml:lang="ar">يُنصح بالحذر</rdfs:label>
        <rdfs:comment xml:lang="en">Area requiring extra caution or awareness.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL GUIDANCE HIERARCHY ⭐                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;CulturalGuidance">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Cultural Guidance</rdfs:label>
        <rdfs:label xml:lang="ar">إرشاد ثقافي</rdfs:label>
        <rdfs:comment xml:lang="en">Guidance and recommendations for culturally appropriate behavior.</rdfs:comment>
        <jto:cqReference>CQ-231, CQ-232</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BehaviorGuidance">
        <rdfs:subClassOf rdf:resource="&jto;CulturalGuidance"/>
        <rdfs:label xml:lang="en">Behavior Guidance</rdfs:label>
        <rdfs:label xml:lang="ar">إرشاد السلوك</rdfs:label>
        <rdfs:comment xml:lang="en">General behavioral recommendations for visitors.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;GenderConsideration">
        <rdfs:subClassOf rdf:resource="&jto;CulturalGuidance"/>
        <rdfs:label xml:lang="en">Gender Consideration</rdfs:label>
        <rdfs:label xml:lang="ar">اعتبارات الجنس</rdfs:label>
        <rdfs:comment xml:lang="en">Gender-specific guidelines and considerations for travelers.</rdfs:comment>
        <jto:cqReference>CQ-232, CQ-234, CQ-235</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WomenTravelerGuidance">
        <rdfs:subClassOf rdf:resource="&jto;GenderConsideration"/>
        <rdfs:label xml:lang="en">Women Traveler Guidance</rdfs:label>
        <rdfs:label xml:lang="ar">إرشادات للمسافرات</rdfs:label>
        <rdfs:comment xml:lang="en">Specific guidance and resources for female travelers.</rdfs:comment>
        <jto:cqReference>CQ-234, CQ-235</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;SoloTravelerGuidance">
        <rdfs:subClassOf rdf:resource="&jto;CulturalGuidance"/>
        <rdfs:label xml:lang="en">Solo Traveler Guidance</rdfs:label>
