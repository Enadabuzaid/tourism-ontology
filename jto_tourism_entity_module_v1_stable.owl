        <rdfs:label xml:lang="ar">آداب المسجد</rdfs:label>
        <rdfs:comment xml:lang="en">Behavioral expectations when visiting mosques, including dress code, shoe removal, and prayer times.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChurchEtiquette">
