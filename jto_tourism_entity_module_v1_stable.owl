    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- FACILITY OBJECT PROPERTIES                                                   -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:ObjectProperty rdf:about="&jto;hasFacility">
        <rdfs:label xml:lang="en">has facility</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على مرفق</rdfs:label>
        <rdfs:comment xml:lang="en">Links an attraction or accommodation to its facilities.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;Facility"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;facilityLocatedAt">
        <rdfs:label xml:lang="en">facility located at</rdfs:label>
        <rdfs:label xml:lang="ar">المرفق يقع في</rdfs:label>
        <rdfs:comment xml:lang="en">Links a facility to its physical location.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Facility"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;servesCuisine">
        <rdfs:label xml:lang="en">serves cuisine</rdfs:label>
        <rdfs:label xml:lang="ar">يقدم مطبخ</rdfs:label>
        <rdfs:comment xml:lang="en">Links a food venue to the cuisine type it serves.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;FoodVenue"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;sellsProduct">
        <rdfs:label xml:lang="en">sells product</rdfs:label>
        <rdfs:label xml:lang="ar">يبيع منتج</rdfs:label>
        <rdfs:comment xml:lang="en">Links a shopping venue to products it sells.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;ShoppingVenue"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;connectsTo">
        <rdfs:label xml:lang="en">connects to</rdfs:label>
        <rdfs:label xml:lang="ar">يتصل بـ</rdfs:label>
        <rdfs:comment xml:lang="en">Links a border crossing to the destination country.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;BorderCrossing"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasAccessibilityFeature">
        <rdfs:label xml:lang="en">has accessibility feature</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على ميزة إمكانية الوصول</rdfs:label>
        <rdfs:comment xml:lang="en">Links a facility to its accessibility features.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;AccessibleFacility"/>
    </owl:ObjectProperty>

