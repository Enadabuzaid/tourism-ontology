    </owl:Class>

    <owl:Class rdf:about="&jto;TourAvailability">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeAvailability"/>
        <rdfs:label xml:lang="en">Tour Availability</rdfs:label>
        <rdfs:label xml:lang="ar">توفر الجولات</rdfs:label>
        <rdfs:comment xml:lang="en">Real-time tour slot availability.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;TicketAvailability">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeAvailability"/>
        <rdfs:label xml:lang="en">Ticket Availability</rdfs:label>
        <rdfs:label xml:lang="ar">توفر التذاكر</rdfs:label>
        <rdfs:comment xml:lang="en">Real-time ticket availability for attractions and events.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Traffic Data                                                                 -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;TrafficData">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeData"/>
        <rdfs:label xml:lang="en">Traffic Data</rdfs:label>
        <rdfs:label xml:lang="ar">بيانات المرور</rdfs:label>
        <rdfs:comment xml:lang="en">Real-time traffic and road condition information.</rdfs:comment>
        <jto:cqReference>CQ-298</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;TrafficAlert">
