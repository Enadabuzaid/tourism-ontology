        <rdfs:label xml:lang="ar">مشاهدة درب التبانة</rdfs:label>
        <rdfs:comment xml:lang="en">Best during summer months (April-October) in Wadi Rum.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;MeteorShower">
        <rdfs:subClassOf rdf:resource="&jto;AstronomyEvent"/>
        <rdfs:label xml:lang="en">Meteor Shower</rdfs:label>
        <rdfs:label xml:lang="ar">زخة شهب</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;LunarEclipse">
