        <rdfs:label xml:lang="ar">حدث فلكي</rdfs:label>
        <rdfs:comment xml:lang="en">Celestial events ideal for stargazing tourism in Jordan's dark sky locations.</rdfs:comment>
        <jto:cqReference>CQ-277</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;MilkyWayViewing">
