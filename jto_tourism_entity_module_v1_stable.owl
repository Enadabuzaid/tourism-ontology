        <rdfs:domain rdf:resource="&jto;Resort"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;distanceToCenter">
        <rdfs:label xml:lang="en">distance to center</rdfs:label>
        <rdfs:label xml:lang="ar">المسافة إلى المركز</rdfs:label>
        <rdfs:comment xml:lang="en">Distance to city center or main attraction in kilometers.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isEcoCertified">
        <rdfs:label xml:lang="en">is eco-certified</rdfs:label>
        <rdfs:label xml:lang="ar">حاصل على شهادة بيئية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;EcoLodge"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;hasSolarPower">
        <rdfs:label xml:lang="en">has solar power</rdfs:label>
        <rdfs:label xml:lang="ar">يعمل بالطاقة الشمسية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;EcoLodge"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;maxOccupancy">
        <rdfs:label xml:lang="en">maximum occupancy</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأقصى للإشغال</rdfs:label>
        <rdfs:domain rdf:resource="&jto;RoomType"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;acceptsCreditCards">
        <rdfs:label xml:lang="en">accepts credit cards</rdfs:label>
        <rdfs:label xml:lang="ar">يقبل بطاقات الائتمان</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;bookingURL">
        <rdfs:label xml:lang="en">booking URL</rdfs:label>
        <rdfs:label xml:lang="ar">رابط الحجز</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;anyURI"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;phoneNumber">
