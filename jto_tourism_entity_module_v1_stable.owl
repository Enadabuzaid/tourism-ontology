        <rdfs:label xml:lang="ar">آداب البقشيش</rdfs:label>
        <jto:altLabelAR>إكرامية</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Guidelines for tipping in restaurants, hotels, and tourism services.</rdfs:comment>
        <jto:cqReference>CQ-085</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BargainingEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;SocialEtiquette"/>
