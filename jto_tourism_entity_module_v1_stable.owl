        <rdfs:label xml:lang="ar">نوع الغرفة</rdfs:label>
        <rdfs:comment xml:lang="en">Classification of accommodation rooms by size, features, and capacity.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;SingleRoom">
        <rdfs:subClassOf rdf:resource="&jto;RoomType"/>
        <rdfs:label xml:lang="en">Single Room</rdfs:label>
        <rdfs:label xml:lang="ar">غرفة فردية</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;DoubleRoom">
