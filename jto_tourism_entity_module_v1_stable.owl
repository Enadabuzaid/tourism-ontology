        <rdfs:label xml:lang="ar">طريقة الدفع</rdfs:label>
        <rdfs:comment xml:lang="en">Accepted payment methods at tourism establishments.</rdfs:comment>
        <jto:cqReference>CQ-148</jto:cqReference>
