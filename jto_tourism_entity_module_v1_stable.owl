    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 6: CULTURAL CONCEPT HIERARCHY                                         -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- THESIS INNOVATION: Cultural concepts as first-class ontological entities     -->
    <!-- Enables explicit reasoning about cultural constraints and requirements       -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- CulturalConcept (Root Class)                                                 -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;CulturalConcept">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Cultural Concept</rdfs:label>
        <rdfs:label xml:lang="ar">مفهوم ثقافي</rdfs:label>
        <rdfs:comment xml:lang="en">Abstract cultural concepts that influence tourism experiences in Jordan. This class enables explicit semantic reasoning about cultural requirements, constraints, and sensitivities - a key thesis innovation treating culture as first-class ontological entities.</rdfs:comment>
        <rdfs:comment xml:lang="ar">المفاهيم الثقافية المجردة التي تؤثر على تجارب السياحة في الأردن.</rdfs:comment>
        <jto:cqReference>CQ-007, CQ-085, CQ-087, CQ-231, CQ-235</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- CULTURAL PRACTICE HIERARCHY ⭐ THESIS INNOVATION                             -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;CulturalPractice">
        <rdfs:subClassOf rdf:resource="&jto;CulturalConcept"/>
        <rdfs:label xml:lang="en">Cultural Practice</rdfs:label>
        <rdfs:label xml:lang="ar">ممارسة ثقافية</rdfs:label>
        <jto:altLabelAR>عادة ثقافية</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Traditional practices, customs, and behavioral norms in Jordanian culture.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Social Etiquette                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;SocialEtiquette">
        <rdfs:subClassOf rdf:resource="&jto;CulturalPractice"/>
        <rdfs:label xml:lang="en">Social Etiquette</rdfs:label>
        <rdfs:label xml:lang="ar">آداب اجتماعية</rdfs:label>
        <rdfs:comment xml:lang="en">Social customs and behavioral expectations in Jordanian society.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Greeting">
        <rdfs:subClassOf rdf:resource="&jto;SocialEtiquette"/>
        <rdfs:label xml:lang="en">Greeting</rdfs:label>
        <rdfs:label xml:lang="ar">تحية</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional greeting customs and phrases.</rdfs:comment>
        <jto:cqReference>CQ-060</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArabicGreeting">
        <rdfs:subClassOf rdf:resource="&jto;Greeting"/>
        <rdfs:label xml:lang="en">Arabic Greeting</rdfs:label>
        <rdfs:label xml:lang="ar">تحية عربية</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Arabic greetings used in Jordan.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;TippingEtiquette">
