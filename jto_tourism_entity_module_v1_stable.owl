        <rdfs:label xml:lang="ar">حدث محافظة على البيئة</rdfs:label>
        <rdfs:comment xml:lang="en">Environmental volunteer events for eco-conscious tourists.</rdfs:comment>
        <jto:cqReference>CQ-203</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BeachCleanup">
        <rdfs:subClassOf rdf:resource="&jto;ConservationEvent"/>
        <rdfs:label xml:lang="en">Beach Cleanup</rdfs:label>
        <rdfs:label xml:lang="ar">تنظيف الشاطئ</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;ReefConservation">
        <rdfs:subClassOf rdf:resource="&jto;ConservationEvent"/>
