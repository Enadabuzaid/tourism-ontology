        <rdfs:label xml:lang="ar">فعالية بناء الفريق</rdfs:label>
        <rdfs:comment xml:lang="en">Corporate activity designed for team bonding, often held at unique venues.</rdfs:comment>
        <jto:cqReference>CQ-210</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;OutdoorCorporateEvent">
        <rdfs:subClassOf rdf:resource="&jto;CorporateEvent"/>
        <rdfs:label xml:lang="en">Outdoor Corporate Event</rdfs:label>
        <rdfs:label xml:lang="ar">حدث مؤسسي في الهواء الطلق</rdfs:label>
        <rdfs:comment xml:lang="en">Corporate event held in outdoor venues like Wadi Rum or Dead Sea.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Astronomy Event Hierarchy                                                    -->
