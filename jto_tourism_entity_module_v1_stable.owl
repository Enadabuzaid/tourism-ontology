        <rdfs:label xml:lang="ar">سبا طبي</rdfs:label>
        <rdfs:comment xml:lang="en">Spa facility offering medical treatments and therapies.</rdfs:comment>
        <jto:cqReference>CQ-077</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaMedicalSpa">
        <rdfs:subClassOf rdf:resource="&jto;MedicalSpa"/>
