        <rdfs:label xml:lang="ar">آداب المساومة</rdfs:label>
        <rdfs:comment xml:lang="en">Guidelines for haggling in traditional markets and souks.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Religious Etiquette Hierarchy                                                -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;ReligiousEtiquette">
