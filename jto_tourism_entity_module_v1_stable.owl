        <rdfs:label xml:lang="ar">خدمة المرشد السياحي</rdfs:label>
        <jto:altLabelAR>خدمات الإرشاد</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Professional tour guide services.</rdfs:comment>
        <jto:cqReference>CQ-114, CQ-127</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;LocalGuide">
        <rdfs:subClassOf rdf:resource="&jto;GuideService"/>
        <rdfs:label xml:lang="en">Local Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد محلي</rdfs:label>
        <rdfs:comment xml:lang="en">Licensed local tour guide with regional expertise.</rdfs:comment>
        <jto:cqReference>CQ-114</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BedouinGuide">
        <rdfs:subClassOf rdf:resource="&jto;GuideService"/>
        <rdfs:label xml:lang="en">Bedouin Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد بدوي</rdfs:label>
        <rdfs:comment xml:lang="en">Bedouin guide with deep knowledge of desert terrain and traditions.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مرشد بدوي ذو معرفة عميقة بالتضاريس الصحراوية والتقاليد.</rdfs:comment>
        <jto:cqReference>CQ-114</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;FemaleTourGuide">
        <rdfs:subClassOf rdf:resource="&jto;GuideService"/>
        <rdfs:label xml:lang="en">Female Tour Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشدة سياحية</rdfs:label>
        <rdfs:comment xml:lang="en">Female tour guide, preferred by some travelers.</rdfs:comment>
        <jto:cqReference>CQ-235</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;MultilingualGuide">
        <rdfs:subClassOf rdf:resource="&jto;GuideService"/>
        <rdfs:label xml:lang="en">Multilingual Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد متعدد اللغات</rdfs:label>
        <rdfs:comment xml:lang="en">Tour guide fluent in multiple languages.</rdfs:comment>
        <jto:cqReference>CQ-127</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;SpecializedGuide">
        <rdfs:subClassOf rdf:resource="&jto;GuideService"/>
        <rdfs:label xml:lang="en">Specialized Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد متخصص</rdfs:label>
        <rdfs:comment xml:lang="en">Guide with specialized expertise (archaeology, nature, etc.).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArchaeologyGuide">
        <rdfs:subClassOf rdf:resource="&jto;SpecializedGuide"/>
        <rdfs:label xml:lang="en">Archaeology Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد آثار</rdfs:label>
        <rdfs:comment xml:lang="en">Guide specialized in archaeological sites and history.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;NatureGuide">
        <rdfs:subClassOf rdf:resource="&jto;SpecializedGuide"/>
        <rdfs:label xml:lang="en">Nature Guide</rdfs:label>
        <rdfs:label xml:lang="ar">مرشد طبيعة</rdfs:label>
        <rdfs:comment xml:lang="en">Guide specialized in nature reserves and wildlife.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- FINANCIAL SERVICE HIERARCHY                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;FinancialService">
        <rdfs:subClassOf rdf:resource="&jto;Service"/>
