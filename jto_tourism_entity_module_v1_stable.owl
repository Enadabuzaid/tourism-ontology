        <rdfs:label xml:lang="ar">مرفق</rdfs:label>
        <jto:altLabelAR>منشأة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Physical facilities and infrastructure available to tourists in Jordan.</rdfs:comment>
        <rdfs:comment xml:lang="ar">المرافق المادية والبنية التحتية المتاحة للسياح في الأردن.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- MEDICAL FACILITY HIERARCHY                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;MedicalFacility">
        <rdfs:subClassOf rdf:resource="&jto;Facility"/>
        <rdfs:label xml:lang="en">Medical Facility</rdfs:label>
        <rdfs:label xml:lang="ar">مرفق طبي</rdfs:label>
        <rdfs:comment xml:lang="en">Healthcare facilities for medical treatment and emergencies.</rdfs:comment>
        <jto:cqReference>CQ-053, CQ-228</jto:cqReference>
    </owl:Class>

    <!-- Multiple inheritance: Hospital is also a MedicalFacility -->
    <owl:Class rdf:about="&jto;Hospital">
        <rdfs:subClassOf rdf:resource="&jto;MedicalFacility"/>
        <jto:cqReference>CQ-053</jto:cqReference>
    </owl:Class>

    <!-- Multiple inheritance: Clinic is also a MedicalFacility -->
    <owl:Class rdf:about="&jto;Clinic">
        <rdfs:subClassOf rdf:resource="&jto;MedicalFacility"/>
    </owl:Class>

    <!-- Multiple inheritance: Pharmacy is also a MedicalFacility -->
    <owl:Class rdf:about="&jto;Pharmacy">
        <rdfs:subClassOf rdf:resource="&jto;MedicalFacility"/>
        <jto:cqReference>CQ-054</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;TwentyFourHourPharmacy">
