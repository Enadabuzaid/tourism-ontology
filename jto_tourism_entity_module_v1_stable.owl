    <!-- Common Phrases -->
    <owl:NamedIndividual rdf:about="&jto;ShukranPhrase">
        <rdf:type rdf:resource="&jto;CommonPhrase"/>
        <rdfs:label xml:lang="en">Shukran</rdfs:label>
        <rdfs:label xml:lang="ar">شكراً</rdfs:label>
        <jto:arabicPhrase>شكراً</jto:arabicPhrase>
        <jto:englishTranslation>Thank you</jto:englishTranslation>
        <jto:pronunciation>SHUK-ran</jto:pronunciation>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;AfwanPhrase">
        <rdf:type rdf:resource="&jto;CommonPhrase"/>
        <rdfs:label xml:lang="en">Afwan</rdfs:label>
        <rdfs:label xml:lang="ar">عفواً</rdfs:label>
        <jto:arabicPhrase>عفواً</jto:arabicPhrase>
        <jto:englishTranslation>You're welcome / Excuse me</jto:englishTranslation>
        <jto:pronunciation>AF-wan</jto:pronunciation>
    </owl:NamedIndividual>

    <!-- Civilizations -->
    <owl:NamedIndividual rdf:about="&jto;NabataeanCivilization">
        <rdf:type rdf:resource="&jto;Nabataean"/>
        <rdfs:label xml:lang="en">Nabataean Kingdom</rdfs:label>
        <rdfs:label xml:lang="ar">مملكة الأنباط</rdfs:label>
        <jto:historicalPeriodStart>4th century BCE</jto:historicalPeriodStart>
        <jto:historicalPeriodEnd>106 CE</jto:historicalPeriodEnd>
        <rdfs:comment xml:lang="en">Ancient Arab civilization that built Petra and controlled trade routes.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;RomanDecapolis">
        <rdf:type rdf:resource="&jto;Roman"/>
        <rdfs:label xml:lang="en">Roman Decapolis</rdfs:label>
        <rdfs:label xml:lang="ar">المدن العشر الرومانية</rdfs:label>
        <jto:historicalPeriodStart>63 BCE</jto:historicalPeriodStart>
        <jto:historicalPeriodEnd>324 CE</jto:historicalPeriodEnd>
        <rdfs:comment xml:lang="en">Roman era cities including Jerash (Gerasa) and Philadelphia (Amman).</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Wildlife -->
    <owl:NamedIndividual rdf:about="&jto;NubianIbexDana">
        <rdf:type rdf:resource="&jto;Ibex"/>
        <rdfs:label xml:lang="en">Nubian Ibex (Dana)</rdfs:label>
        <rdfs:label xml:lang="ar">الوعل النوبي - ضانا</rdfs:label>
        <jto:speciesScientificName>Capra nubiana</jto:speciesScientificName>
        <jto:conservationStatus>Vulnerable</jto:conservationStatus>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DesertScorpion">
        <rdf:type rdf:resource="&jto;Scorpion"/>
        <rdfs:label xml:lang="en">Yellow Desert Scorpion</rdfs:label>
        <rdfs:label xml:lang="ar">العقرب الصفراء</rdfs:label>
        <jto:speciesScientificName>Leiurus quinquestriatus</jto:speciesScientificName>
        <jto:dangerLevel>High - venomous</jto:dangerLevel>
        <rdfs:comment xml:lang="en">Found in desert areas. Check shoes and bedding when camping.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Policies -->
    <owl:NamedIndividual rdf:about="&jto;JordanDroneRegulations">
        <rdf:type rdf:resource="&jto;DroneWithCARCPermit"/>
        <rdfs:label xml:lang="en">Jordan Drone Regulations</rdfs:label>
        <rdfs:label xml:lang="ar">لوائح الطائرات بدون طيار في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Drones require CARC permit. Prohibited near airports, military, royal palaces, and Petra.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanAlcoholRules">
        <rdf:type rdf:resource="&jto;AlcoholPolicy"/>
        <rdfs:label xml:lang="en">Jordan Alcohol Policy</rdfs:label>
        <rdfs:label xml:lang="ar">سياسة الكحول في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Alcohol is legal at licensed venues. Drinking age 18. May be restricted during Ramadan.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Safety -->
    <owl:NamedIndividual rdf:about="&jto;JordanOverallSafety">
        <rdf:type rdf:resource="&jto;HighSafety"/>
        <rdfs:label xml:lang="en">Jordan Overall Safety</rdfs:label>
        <rdfs:label xml:lang="ar">السلامة العامة في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan is one of the safest countries in the Middle East for tourists.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Women Travelers -->
    <owl:NamedIndividual rdf:about="&jto;WomenTravelersGuide">
        <rdf:type rdf:resource="&jto;WomenTravelerGuidance"/>
        <rdfs:label xml:lang="en">Women Travelers Jordan Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل المسافرات في الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan is generally safe for women. Dress modestly outside tourist areas. Harassment is rare.</rdfs:comment>
    </owl:NamedIndividual>

