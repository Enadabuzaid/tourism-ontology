        <rdfs:label xml:lang="ar">يسمح بالحيوانات الأليفة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;hasPrivateBeachAccess">
