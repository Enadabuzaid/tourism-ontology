        <rdfs:label xml:lang="ar">نصيحة ثقافية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;CulturalConcept"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;tippingPercentage">
        <rdfs:label xml:lang="en">tipping percentage</rdfs:label>
        <rdfs:label xml:lang="ar">نسبة البقشيش</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TippingEtiquette"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;dishDescription">
        <rdfs:label xml:lang="en">dish description</rdfs:label>
        <rdfs:label xml:lang="ar">وصف الطبق</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TraditionalDish"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isVegetarian">
        <rdfs:label xml:lang="en">is vegetarian</rdfs:label>
        <rdfs:label xml:lang="ar">نباتي</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TraditionalDish"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isVegan">
        <rdfs:label xml:lang="en">is vegan</rdfs:label>
        <rdfs:label xml:lang="ar">نباتي صرف</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TraditionalDish"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;craftOrigin">
        <rdfs:label xml:lang="en">craft origin</rdfs:label>
        <rdfs:label xml:lang="ar">أصل الحرفة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TraditionalCraft"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;ramadanHoursModified">
        <rdfs:label xml:lang="en">Ramadan hours modified</rdfs:label>
        <rdfs:label xml:lang="ar">ساعات رمضان معدلة</rdfs:label>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;ramadanOpeningTime">
        <rdfs:label xml:lang="en">Ramadan opening time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت فتح رمضان</rdfs:label>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;ramadanClosingTime">
        <rdfs:label xml:lang="en">Ramadan closing time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت إغلاق رمضان</rdfs:label>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 6 ADDITIONAL INDIVIDUALS                                              -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Arabic Greetings                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;SalamGreeting">
        <rdf:type rdf:resource="&jto;ArabicGreeting"/>
        <rdfs:label xml:lang="en">As-salamu alaykum</rdfs:label>
        <rdfs:label xml:lang="ar">السلام عليكم</rdfs:label>
        <jto:arabicPhrase>السلام عليكم</jto:arabicPhrase>
        <jto:englishTranslation>Peace be upon you</jto:englishTranslation>
        <jto:pronunciation>as-sa-LA-mu a-LAY-kum</jto:pronunciation>
        <jto:culturalTip>Traditional Islamic greeting, respond with 'Wa alaykum as-salam'</jto:culturalTip>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;MarhabaGreeting">
        <rdf:type rdf:resource="&jto;ArabicGreeting"/>
        <rdfs:label xml:lang="en">Marhaba</rdfs:label>
        <rdfs:label xml:lang="ar">مرحبا</rdfs:label>
        <jto:arabicPhrase>مرحبا</jto:arabicPhrase>
        <jto:englishTranslation>Hello/Welcome</jto:englishTranslation>
        <jto:pronunciation>MAR-ha-ba</jto:pronunciation>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;AhlanWaSahlanGreeting">
        <rdf:type rdf:resource="&jto;ArabicGreeting"/>
        <rdfs:label xml:lang="en">Ahlan wa Sahlan</rdfs:label>
        <rdfs:label xml:lang="ar">أهلاً وسهلاً</rdfs:label>
        <jto:arabicPhrase>أهلاً وسهلاً</jto:arabicPhrase>
        <jto:englishTranslation>Welcome (You are among family)</jto:englishTranslation>
        <jto:pronunciation>AH-lan wa SAH-lan</jto:pronunciation>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Tipping Guide                                                                -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;JordanTippingGuide">
        <rdf:type rdf:resource="&jto;TippingEtiquette"/>
        <rdfs:label xml:lang="en">Jordan Tipping Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل البقشيش في الأردن</rdfs:label>
        <jto:tippingPercentage rdf:datatype="&xsd;integer">10</jto:tippingPercentage>
        <jto:etiquetteDescription>10% tip at restaurants is customary. Tip guides 5-10 JOD per day, drivers 3-5 JOD.</jto:etiquetteDescription>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Hospitality Custom                                                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;JordanianHospitality">
        <rdf:type rdf:resource="&jto;HospitalityCustom"/>
        <rdfs:label xml:lang="en">Jordanian Hospitality</rdfs:label>
        <rdfs:label xml:lang="ar">الضيافة الأردنية</rdfs:label>
        <jto:etiquetteDescription>Jordanians are known for exceptional hospitality. Accept offered coffee/tea as refusal may offend. Remove shoes when entering homes.</jto:etiquetteDescription>
        <jto:culturalTip>It's polite to bring a small gift when visiting a Jordanian home.</jto:culturalTip>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Religious Etiquette Individuals                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;RamadanVisitorGuide">
        <rdf:type rdf:resource="&jto;RamadanEtiquette"/>
        <rdfs:label xml:lang="en">Ramadan Visitor Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل الزائر في رمضان</rdfs:label>
        <jto:etiquetteDescription>During Ramadan, avoid eating, drinking, or smoking in public during fasting hours. Many restaurants close until iftar. Attractions may have reduced hours.</jto:etiquetteDescription>
        <jto:culturalTip>Ramadan is a special time to experience Jordan - consider attending an iftar meal.</jto:culturalTip>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;MosqueVisitorGuide">
        <rdf:type rdf:resource="&jto;MosqueEtiquette"/>
        <rdfs:label xml:lang="en">Mosque Visitor Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل زيارة المسجد</rdfs:label>
        <jto:etiquetteDescription>Remove shoes before entering. Women must cover hair, arms, and legs. Avoid visiting during prayer times. Photography may be restricted.</jto:etiquetteDescription>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Dress Code Individuals                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;JordanModestDressGuide">
        <rdf:type rdf:resource="&jto;ModestDress"/>
        <rdfs:label xml:lang="en">Jordan Modest Dress Guide</rdfs:label>
        <rdfs:label xml:lang="ar">دليل اللباس المحتشم في الأردن</rdfs:label>
        <jto:etiquetteDescription>In public areas, shoulders and knees should be covered. This applies more strictly in rural areas and less in tourist hotels.</jto:etiquetteDescription>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;ReligiousSiteDress">
        <rdf:type rdf:resource="&jto;ReligiousSiteDressCode"/>
        <rdfs:label xml:lang="en">Religious Site Dress Requirements</rdfs:label>
        <rdfs:label xml:lang="ar">متطلبات اللباس للمواقع الدينية</rdfs:label>
        <jto:etiquetteDescription>Mosques: Women cover hair and wear long sleeves/skirts. Churches: Similar modest dress. Head coverings often available at sites.</jto:etiquetteDescription>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Traditional Dish Individuals                                                 -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;MansafDish">
        <rdf:type rdf:resource="&jto;Mansaf"/>
        <rdfs:label xml:lang="en">Mansaf</rdfs:label>
        <rdfs:label xml:lang="ar">منسف</rdfs:label>
        <jto:dishDescription>Jordan's national dish - lamb cooked in fermented dried yogurt (jameed) served over rice and flatbread.</jto:dishDescription>
        <jto:isVegetarian rdf:datatype="&xsd;boolean">false</jto:isVegetarian>
        <jto:culturalTip>Traditionally eaten with the right hand. The host may offer choice pieces to honored guests.</jto:culturalTip>
        <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q693198"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;ZarbDish">
        <rdf:type rdf:resource="&jto;Zarb"/>
        <rdfs:label xml:lang="en">Zarb</rdfs:label>
        <rdfs:label xml:lang="ar">زرب</rdfs:label>
        <jto:altLabelEN>Bedouin BBQ</jto:altLabelEN>
        <jto:dishDescription>Traditional Bedouin dish - meat and vegetables slow-cooked underground in a sand pit.</jto:dishDescription>
        <jto:isVegetarian rdf:datatype="&xsd;boolean">false</jto:isVegetarian>
        <jto:culturalTip>Best experienced in Wadi Rum with Bedouin hosts.</jto:culturalTip>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;KunafaDish">
        <rdf:type rdf:resource="&jto;Kunafa"/>
        <rdfs:label xml:lang="en">Kunafa</rdfs:label>
        <rdfs:label xml:lang="ar">كنافة</rdfs:label>
        <jto:altLabelEN>Kanafeh</jto:altLabelEN>
        <jto:dishDescription>Sweet cheese pastry soaked in sugar syrup, topped with crushed pistachios.</jto:dishDescription>
        <jto:isVegetarian rdf:datatype="&xsd;boolean">true</jto:isVegetarian>
        <jto:culturalTip>Try at Habibah Sweets in downtown Amman - considered the best in Jordan.</jto:culturalTip>
        <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q729387"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;FalafelDish">
        <rdf:type rdf:resource="&jto;TraditionalDish"/>
        <rdfs:label xml:lang="en">Falafel</rdfs:label>
        <rdfs:label xml:lang="ar">فلافل</rdfs:label>
        <jto:dishDescription>Deep-fried balls of ground chickpeas with herbs, served in pita bread.</jto:dishDescription>
        <jto:isVegetarian rdf:datatype="&xsd;boolean">true</jto:isVegetarian>
        <jto:isVegan rdf:datatype="&xsd;boolean">true</jto:isVegan>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;HummusDish">
        <rdf:type rdf:resource="&jto;TraditionalDish"/>
        <rdfs:label xml:lang="en">Hummus</rdfs:label>
        <rdfs:label xml:lang="ar">حمص</rdfs:label>
        <jto:dishDescription>Creamy chickpea dip with tahini, lemon, and garlic.</jto:dishDescription>
        <jto:isVegetarian rdf:datatype="&xsd;boolean">true</jto:isVegetarian>
        <jto:isVegan rdf:datatype="&xsd;boolean">true</jto:isVegan>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;ArabicCoffee">
        <rdf:type rdf:resource="&jto;TraditionalDish"/>
        <rdfs:label xml:lang="en">Arabic Coffee</rdfs:label>
        <rdfs:label xml:lang="ar">قهوة عربية</rdfs:label>
        <jto:dishDescription>Cardamom-spiced coffee served in small cups, a symbol of hospitality.</jto:dishDescription>
        <jto:culturalTip>Accept with right hand. Shake cup side to side when finished.</jto:culturalTip>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Traditional Craft Individuals                                                -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;MadabaMosaics">
        <rdf:type rdf:resource="&jto;MosaicArt"/>
        <rdfs:label xml:lang="en">Madaba Mosaics</rdfs:label>
        <rdfs:label xml:lang="ar">فسيفساء مأدبا</rdfs:label>
        <jto:craftOrigin>Madaba</jto:craftOrigin>
        <rdfs:comment xml:lang="en">Byzantine-era mosaic tradition continued by local artisans, including the famous 6th-century Madaba Map.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PetraSandBottles">
        <rdf:type rdf:resource="&jto;SandBottleArt"/>
        <rdfs:label xml:lang="en">Petra Sand Bottle Art</rdfs:label>
        <rdfs:label xml:lang="ar">فن زجاجات الرمل في البتراء</rdfs:label>
        <jto:craftOrigin>Petra</jto:craftOrigin>
        <rdfs:comment xml:lang="en">Colorful layered sand art in bottles, depicting desert scenes and camels.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;BedouinSaduWeaving">
        <rdf:type rdf:resource="&jto;BedouinWeaving"/>
        <rdfs:label xml:lang="en">Bedouin Sadu Weaving</rdfs:label>
        <rdfs:label xml:lang="ar">نسيج السدو البدوي</rdfs:label>
        <jto:craftOrigin>Wadi Rum</jto:craftOrigin>
        <rdfs:comment xml:lang="en">Traditional Bedouin textile weaving using geometric patterns.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Civilization Individuals                                                     -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;NabataeanCiv">
        <rdf:type rdf:resource="&jto;Nabataean"/>
        <rdfs:label xml:lang="en">Nabataean Kingdom</rdfs:label>
        <rdfs:label xml:lang="ar">مملكة الأنباط</rdfs:label>
        <jto:historicalPeriodStart>4th century BCE</jto:historicalPeriodStart>
        <jto:historicalPeriodEnd>106 CE</jto:historicalPeriodEnd>
        <rdfs:comment xml:lang="en">Ancient Arab civilization that built Petra and controlled trade routes.</rdfs:comment>
        <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q170587"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;RomanJordan">
        <rdf:type rdf:resource="&jto;Roman"/>
        <rdfs:label xml:lang="en">Roman Jordan (Decapolis)</rdfs:label>
        <rdfs:label xml:lang="ar">الأردن الروماني</rdfs:label>
        <jto:historicalPeriodStart>63 BCE</jto:historicalPeriodStart>
        <jto:historicalPeriodEnd>324 CE</jto:historicalPeriodEnd>
        <rdfs:comment xml:lang="en">Roman era including the Decapolis cities like Jerash (Gerasa) and Philadelphia (Amman).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;UmayyadJordan">
        <rdf:type rdf:resource="&jto;IslamicCivilization"/>
        <rdfs:label xml:lang="en">Umayyad Jordan</rdfs:label>
        <rdfs:label xml:lang="ar">الأردن الأموي</rdfs:label>
        <jto:historicalPeriodStart>661 CE</jto:historicalPeriodStart>
        <jto:historicalPeriodEnd>750 CE</jto:historicalPeriodEnd>
        <rdfs:comment xml:lang="en">Umayyad Caliphate era, known for desert castles (Qasr Amra, Qasr Kharana).</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Wildlife Individuals                                                         -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;NubianIbex">
        <rdf:type rdf:resource="&jto;Ibex"/>
        <rdfs:label xml:lang="en">Nubian Ibex</rdfs:label>
        <rdfs:label xml:lang="ar">الوعل النوبي</rdfs:label>
        <jto:speciesScientificName>Capra nubiana</jto:speciesScientificName>
        <jto:conservationStatus>Vulnerable</jto:conservationStatus>
        <rdfs:comment xml:lang="en">Mountain goat found in Dana Biosphere Reserve and Wadi Mujib.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;ArabianOryxShaumari">
        <rdf:type rdf:resource="&jto;ArabianOryx"/>
        <rdfs:label xml:lang="en">Arabian Oryx</rdfs:label>
        <rdfs:label xml:lang="ar">المها العربي</rdfs:label>
        <jto:speciesScientificName>Oryx leucoryx</jto:speciesScientificName>
        <jto:conservationStatus>Vulnerable (reintroduced)</jto:conservationStatus>
        <rdfs:comment xml:lang="en">National animal of Jordan, successfully reintroduced to Shaumari Reserve.</rdfs:comment>
        <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q181508"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DesertScorpionSpecies">
        <rdf:type rdf:resource="&jto;Scorpion"/>
        <rdfs:label xml:lang="en">Yellow Scorpion</rdfs:label>
        <rdfs:label xml:lang="ar">العقرب الصفراء</rdfs:label>
        <jto:speciesScientificName>Leiurus quinquestriatus</jto:speciesScientificName>
        <jto:dangerLevel>High - venomous</jto:dangerLevel>
        <rdfs:comment xml:lang="en">Found in desert areas. Shake out shoes and check bedding when camping.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PalestineViper">
        <rdf:type rdf:resource="&jto;Snake"/>
        <rdfs:label xml:lang="en">Palestine Viper</rdfs:label>
        <rdfs:label xml:lang="ar">الأفعى الفلسطينية</rdfs:label>
        <jto:speciesScientificName>Daboia palaestinae</jto:speciesScientificName>
        <jto:dangerLevel>High - venomous</jto:dangerLevel>
        <rdfs:comment xml:lang="en">Venomous snake found in rocky areas. Stay on trails and watch where you step.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Photography Policy Individuals                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;PetraPhotographyRules">
        <rdf:type rdf:resource="&jto;PhotographyRestricted"/>
        <rdfs:label xml:lang="en">Petra Photography Rules</rdfs:label>
        <rdfs:label xml:lang="ar">قواعد التصوير في البتراء</rdfs:label>
        <rdfs:comment xml:lang="en">Personal photography allowed. Commercial/professional requires permit. Tripods allowed but may be restricted at Treasury during peak times.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ════════════════════════════════════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- MODULE 7: ACCESSIBILITY FEATURE HIERARCHY                                        -->
    <!-- CQ-005, CQ-076, CQ-116, CQ-117, CQ-226, CQ-227, CQ-286 to CQ-290                -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- ════════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────────── -->
    <!-- AccessibilityFeature (Root Class)                                                -->
    <!-- ─────────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;AccessibilityFeature">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Accessibility Feature</rdfs:label>
        <rdfs:label xml:lang="ar">ميزة إمكانية الوصول</rdfs:label>
        <rdfs:comment xml:lang="en">Features that enable access for people with disabilities, elderly visitors, and families with children.</rdfs:comment>
        <jto:cqReference>CQ-005, CQ-076, CQ-286 to CQ-290</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- PHYSICAL ACCESSIBILITY HIERARCHY                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;PhysicalAccessibility">
        <rdfs:subClassOf rdf:resource="&jto;AccessibilityFeature"/>
        <rdfs:label xml:lang="en">Physical Accessibility</rdfs:label>
        <rdfs:label xml:lang="ar">إمكانية الوصول الجسدي</rdfs:label>
        <rdfs:comment xml:lang="en">Physical infrastructure for mobility-impaired visitors.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;WheelchairAccessible">
        <rdfs:subClassOf rdf:resource="&jto;PhysicalAccessibility"/>
        <rdfs:label xml:lang="en">Wheelchair Accessible</rdfs:label>
        <rdfs:label xml:lang="ar">ملائم للكراسي المتحركة</rdfs:label>
        <rdfs:comment xml:lang="en">Facility or area accessible by wheelchair.</rdfs:comment>
        <jto:cqReference>CQ-005, CQ-076</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WheelchairRamp">
        <rdfs:subClassOf rdf:resource="&jto;PhysicalAccessibility"/>
        <rdfs:label xml:lang="en">Wheelchair Ramp</rdfs:label>
        <rdfs:label xml:lang="ar">منحدر للكراسي المتحركة</rdfs:label>
        <rdfs:comment xml:lang="en">Ramp for wheelchair access.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Elevator">
        <rdfs:subClassOf rdf:resource="&jto;PhysicalAccessibility"/>
        <rdfs:label xml:lang="en">Elevator</rdfs:label>
        <rdfs:label xml:lang="ar">مصعد</rdfs:label>
        <rdfs:comment xml:lang="en">Elevator for multi-level access.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;AccessiblePath">
