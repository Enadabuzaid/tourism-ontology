        <rdfs:label xml:lang="ar">مساج</rdfs:label>
        <jto:altLabelAR>تدليك</jto:altLabelAR>
    </owl:Class>

    <owl:Class rdf:about="&jto;HotSpring">
        <rdfs:subClassOf rdf:resource="&jto;WellnessActivity"/>
