        <rdfs:label xml:lang="ar">الدفع ببطاقة الائتمان</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;MobilePayment">
        <rdfs:subClassOf rdf:resource="&jto;PaymentMethod"/>
