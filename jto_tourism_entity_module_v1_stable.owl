    <!-- ════════════════════════════════════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- MODULE 8: BUSINESS INTELLIGENCE HIERARCHY ⭐ THESIS INNOVATION                   -->
    <!-- CQ-008, CQ-009, CQ-088 to CQ-100, CQ-146, CQ-151 to CQ-155, CQ-276, CQ-296-300  -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- ════════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────────── -->
    <!-- BusinessIntelligence (Root Class) ⭐ THESIS INNOVATION                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;BusinessIntelligence">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Business Intelligence</rdfs:label>
        <rdfs:label xml:lang="ar">ذكاء الأعمال</rdfs:label>
        <rdfs:comment xml:lang="en">Business intelligence data and analytics as first-class ontological entities. This enables semantic querying of real-time data, predictions, and analytics - a key thesis innovation treating BI as queryable semantic concepts rather than external API calls.</rdfs:comment>
        <jto:cqReference>CQ-008, CQ-009, CQ-296 to CQ-300</jto:cqReference>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- REAL-TIME DATA HIERARCHY ⭐                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;RealTimeData">
        <rdfs:subClassOf rdf:resource="&jto;BusinessIntelligence"/>
        <rdfs:label xml:lang="en">Real-Time Data</rdfs:label>
        <rdfs:label xml:lang="ar">بيانات فورية</rdfs:label>
        <rdfs:comment xml:lang="en">Real-time operational data for tourism sites.</rdfs:comment>
        <jto:cqReference>CQ-296</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Wait Time                                                                    -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;WaitTime">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeData"/>
        <rdfs:label xml:lang="en">Wait Time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت الانتظار</rdfs:label>
        <rdfs:comment xml:lang="en">Wait time information for attractions and services.</rdfs:comment>
        <jto:cqReference>CQ-296</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CurrentWaitTime">
        <rdfs:subClassOf rdf:resource="&jto;WaitTime"/>
        <rdfs:label xml:lang="en">Current Wait Time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت الانتظار الحالي</rdfs:label>
        <rdfs:comment xml:lang="en">Current real-time wait time at an attraction.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;PredictedWaitTime">
        <rdfs:subClassOf rdf:resource="&jto;WaitTime"/>
        <rdfs:label xml:lang="en">Predicted Wait Time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت الانتظار المتوقع</rdfs:label>
        <rdfs:comment xml:lang="en">Predicted wait time based on historical patterns.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Crowd Level ⭐                                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;CrowdLevel">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeData"/>
        <rdfs:label xml:lang="en">Crowd Level</rdfs:label>
        <rdfs:label xml:lang="ar">مستوى الازدحام</rdfs:label>
        <rdfs:comment xml:lang="en">Crowd density and busyness levels at attractions.</rdfs:comment>
        <jto:cqReference>CQ-300</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CurrentCrowdLevel">
        <rdfs:subClassOf rdf:resource="&jto;CrowdLevel"/>
        <rdfs:label xml:lang="en">Current Crowd Level</rdfs:label>
        <rdfs:label xml:lang="ar">مستوى الازدحام الحالي</rdfs:label>
        <rdfs:comment xml:lang="en">Current real-time crowd density.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;PredictedCrowdLevel">
        <rdfs:subClassOf rdf:resource="&jto;CrowdLevel"/>
        <rdfs:label xml:lang="en">Predicted Crowd Level</rdfs:label>
        <rdfs:label xml:lang="ar">مستوى الازدحام المتوقع</rdfs:label>
        <rdfs:comment xml:lang="en">Predicted crowd levels based on historical patterns.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;HistoricalPattern">
        <rdfs:subClassOf rdf:resource="&jto;CrowdLevel"/>
        <rdfs:label xml:lang="en">Historical Pattern</rdfs:label>
        <rdfs:label xml:lang="ar">نمط تاريخي</rdfs:label>
        <rdfs:comment xml:lang="en">Historical crowd patterns by day, time, and season.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Real-Time Availability                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;RealTimeAvailability">
        <rdfs:subClassOf rdf:resource="&jto;RealTimeData"/>
