        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;baseFare">
        <rdfs:label xml:lang="en">base fare</rdfs:label>
        <rdfs:label xml:lang="ar">الأجرة الأساسية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TransportService"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;operatingHoursStart">
