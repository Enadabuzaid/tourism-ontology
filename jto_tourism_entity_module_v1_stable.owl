        <jto:seasonalAvailability>Monday, Wednesday, Thursday</jto:seasonalAvailability>
        <jto:requiresBooking rdf:datatype="&xsd;boolean">true</jto:requiresBooking>
        <rdfs:comment xml:lang="en">Walk through the candlelit Siq to the Treasury, a magical nighttime experience.</rdfs:comment>
        <rdfs:comment xml:lang="ar">السير عبر السيق المضاء بالشموع إلى الخزنة، تجربة ليلية ساحرة.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;AmmanFoodTour">
        <rdf:type rdf:resource="&jto;FoodTour"/>
        <rdfs:label xml:lang="en">Amman Downtown Food Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة طعام وسط البلد عمان</rdfs:label>
        <jto:locatedIn rdf:resource="&jto;Amman"/>
        <jto:activityDuration rdf:datatype="&xsd;decimal">3.0</jto:activityDuration>
        <jto:activityPrice rdf:datatype="&xsd;decimal">50.00</jto:activityPrice>
        <jto:isGuided rdf:datatype="&xsd;boolean">true</jto:isGuided>
        <jto:isSuitableForChildren rdf:datatype="&xsd;boolean">true</jto:isSuitableForChildren>
        <rdfs:comment xml:lang="en">Guided walking tour sampling street food, falafel, hummus, and local sweets.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Wildlife Activities                                                          -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="&jto;DanaBirdWatching">
        <rdf:type rdf:resource="&jto;BirdWatching"/>
        <rdfs:label xml:lang="en">Dana Bird Watching</rdfs:label>
        <rdfs:label xml:lang="ar">مراقبة الطيور في ضانا</rdfs:label>
        <jto:availableAt rdf:resource="&jto;DanaBiosphere"/>
        <jto:activityDuration rdf:datatype="&xsd;decimal">4.0</jto:activityDuration>
        <jto:activityPrice rdf:datatype="&xsd;decimal">35.00</jto:activityPrice>
        <jto:isGuided rdf:datatype="&xsd;boolean">true</jto:isGuided>
        <jto:seasonalAvailability>March to May (migration season)</jto:seasonalAvailability>
        <rdfs:comment xml:lang="en">Observe over 200 bird species in Dana Biosphere Reserve.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 4: SERVICE HIERARCHY                                                  -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Service (Root Class)                                                         -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Service">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة</rdfs:label>
        <rdfs:comment xml:lang="en">Support services available to tourists in Jordan including transport, guides, financial, and communication services.</rdfs:comment>
        <rdfs:comment xml:lang="ar">خدمات الدعم المتاحة للسياح في الأردن بما في ذلك النقل والمرشدين والخدمات المالية والاتصالات.</rdfs:comment>
        <jto:cqReference>CQ-099</jto:cqReference>
        <owl:equivalentClass rdf:resource="&schema;Service"/>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- TRANSPORT SERVICE HIERARCHY                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;TransportService">
        <rdfs:subClassOf rdf:resource="&jto;Service"/>
        <rdfs:label xml:lang="en">Transport Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة النقل</rdfs:label>
        <jto:altLabelAR>خدمات المواصلات</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Transportation services for tourists including public transport, taxis, and car rentals.</rdfs:comment>
        <jto:cqReference>CQ-099, CQ-101, CQ-105</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Public Transport                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;PublicTransport">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Public Transport</rdfs:label>
        <rdfs:label xml:lang="ar">النقل العام</rdfs:label>
        <jto:altLabelAR>المواصلات العامة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Government or privately operated public transportation.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BusService">
        <rdfs:subClassOf rdf:resource="&jto;PublicTransport"/>
        <rdfs:label xml:lang="en">Bus Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة الحافلات</rdfs:label>
        <jto:altLabelAR>خدمة الباصات</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Bus transportation services between cities and within cities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;JETTBusService">
        <rdfs:subClassOf rdf:resource="&jto;BusService"/>
        <rdfs:label xml:lang="en">JETT Bus Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة حافلات جت</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan Express Tourist Transportation - premium intercity bus service.</rdfs:comment>
        <rdfs:comment xml:lang="ar">شركة الأردن السريعة للنقل السياحي - خدمة حافلات فاخرة بين المدن.</rdfs:comment>
        <jto:cqReference>CQ-101</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;LocalBusService">
        <rdfs:subClassOf rdf:resource="&jto;BusService"/>
        <rdfs:label xml:lang="en">Local Bus Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة الحافلات المحلية</rdfs:label>
        <rdfs:comment xml:lang="en">Local public buses operating within cities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;FerryService">
        <rdfs:subClassOf rdf:resource="&jto;PublicTransport"/>
        <rdfs:label xml:lang="en">Ferry Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة العبّارة</rdfs:label>
        <rdfs:comment xml:lang="en">Maritime ferry transportation service.</rdfs:comment>
        <jto:cqReference>CQ-292</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;AqabaNuweibaFerry">
        <rdfs:subClassOf rdf:resource="&jto;FerryService"/>
        <rdfs:label xml:lang="en">Aqaba-Nuweiba Ferry</rdfs:label>
        <rdfs:label xml:lang="ar">عبّارة العقبة-نويبع</rdfs:label>
        <rdfs:comment xml:lang="en">Ferry service connecting Aqaba, Jordan to Nuweiba, Egypt across the Gulf of Aqaba.</rdfs:comment>
        <rdfs:comment xml:lang="ar">خدمة العبّارة التي تربط العقبة بالأردن مع نويبع بمصر عبر خليج العقبة.</rdfs:comment>
        <jto:cqReference>CQ-292</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Taxi Service                                                                 -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;TaxiService">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Taxi Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة التاكسي</rdfs:label>
        <jto:altLabelAR>خدمة سيارات الأجرة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Taxi transportation services.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;TaxiService"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;RegularTaxi">
        <rdfs:subClassOf rdf:resource="&jto;TaxiService"/>
        <rdfs:label xml:lang="en">Regular Taxi</rdfs:label>
        <rdfs:label xml:lang="ar">تاكسي عادي</rdfs:label>
        <jto:altLabelAR>سيارة أجرة صفراء</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Standard yellow metered taxi service.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;WomenTaxi">
        <rdfs:subClassOf rdf:resource="&jto;TaxiService"/>
        <rdfs:label xml:lang="en">Women Taxi</rdfs:label>
        <rdfs:label xml:lang="ar">تاكسي للنساء</rdfs:label>
        <jto:altLabelEN>Pink Taxi</jto:altLabelEN>
        <jto:altLabelAR>تاكسي وردي</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Taxi service operated by women for women passengers.</rdfs:comment>
        <rdfs:comment xml:lang="ar">خدمة تاكسي تديرها نساء للراكبات من النساء.</rdfs:comment>
        <jto:cqReference>CQ-234</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;AirportTaxi">
        <rdfs:subClassOf rdf:resource="&jto;TaxiService"/>
        <rdfs:label xml:lang="en">Airport Taxi</rdfs:label>
        <rdfs:label xml:lang="ar">تاكسي المطار</rdfs:label>
        <rdfs:comment xml:lang="en">Official taxi service from Queen Alia International Airport.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Ride Share Service                                                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;RideShareService">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Ride Share Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة مشاركة الركوب</rdfs:label>
        <jto:altLabelAR>تطبيقات النقل</jto:altLabelAR>
        <rdfs:comment xml:lang="en">App-based ride-hailing transportation services.</rdfs:comment>
        <jto:cqReference>CQ-102</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;UberService">
        <rdfs:subClassOf rdf:resource="&jto;RideShareService"/>
        <rdfs:label xml:lang="en">Uber</rdfs:label>
        <rdfs:label xml:lang="ar">أوبر</rdfs:label>
        <rdfs:comment xml:lang="en">Uber ride-hailing service operating in Jordan.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;CareemService">
        <rdfs:subClassOf rdf:resource="&jto;RideShareService"/>
        <rdfs:label xml:lang="en">Careem</rdfs:label>
        <rdfs:label xml:lang="ar">كريم</rdfs:label>
        <rdfs:comment xml:lang="en">Careem ride-hailing service, popular in the Middle East.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Shuttle and Car Rental                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;ShuttleService">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Shuttle Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة النقل المكوكي</rdfs:label>
        <jto:altLabelAR>شاتل</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Scheduled shuttle service between hotels and attractions.</rdfs:comment>
        <jto:cqReference>CQ-103</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CarRentalService">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Car Rental Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة تأجير السيارات</rdfs:label>
        <rdfs:comment xml:lang="en">Vehicle rental services for self-drive tourism.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;AutoRental"/>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Animal Transport                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;AnimalTransport">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Animal Transport</rdfs:label>
        <rdfs:label xml:lang="ar">النقل بالحيوانات</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional animal-based transportation at tourist sites.</rdfs:comment>
        <jto:cqReference>CQ-105</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HorseRideService">
        <rdfs:subClassOf rdf:resource="&jto;AnimalTransport"/>
        <rdfs:label xml:lang="en">Horse Ride Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة ركوب الخيل</rdfs:label>
        <rdfs:comment xml:lang="en">Horse riding service, available at Petra for Treasury access.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DonkeyRideService">
        <rdfs:subClassOf rdf:resource="&jto;AnimalTransport"/>
        <rdfs:label xml:lang="en">Donkey Ride Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة ركوب الحمير</rdfs:label>
        <rdfs:comment xml:lang="en">Donkey riding service for steep paths at Petra.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;CamelRideService">
        <rdfs:subClassOf rdf:resource="&jto;AnimalTransport"/>
        <rdfs:label xml:lang="en">Camel Ride Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة ركوب الجمال</rdfs:label>
        <rdfs:comment xml:lang="en">Camel riding service for desert tours.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Luxury Transport                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;LuxuryTransport">
        <rdfs:subClassOf rdf:resource="&jto;TransportService"/>
        <rdfs:label xml:lang="en">Luxury Transport</rdfs:label>
        <rdfs:label xml:lang="ar">النقل الفاخر</rdfs:label>
        <rdfs:comment xml:lang="en">Premium transportation options for luxury travelers.</rdfs:comment>
        <jto:cqReference>CQ-211, CQ-215</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CharterFlight">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryTransport"/>
        <rdfs:label xml:lang="en">Charter Flight</rdfs:label>
        <rdfs:label xml:lang="ar">رحلة طيران خاصة</rdfs:label>
        <jto:altLabelAR>طيران مستأجر</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Private charter flight services.</rdfs:comment>
        <jto:cqReference>CQ-211</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;LuxuryTrain">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryTransport"/>
        <rdfs:label xml:lang="en">Luxury Train</rdfs:label>
        <rdfs:label xml:lang="ar">قطار فاخر</rdfs:label>
        <rdfs:comment xml:lang="en">Premium train services, including potential Hejaz Railway experiences.</rdfs:comment>
        <jto:cqReference>CQ-215</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;PrivateCar">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryTransport"/>
        <rdfs:label xml:lang="en">Private Car Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة السيارة الخاصة</rdfs:label>
        <rdfs:comment xml:lang="en">Chauffeur-driven private car service.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;HelicopterTour">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryTransport"/>
        <rdfs:label xml:lang="en">Helicopter Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة بالمروحية</rdfs:label>
        <rdfs:comment xml:lang="en">Scenic helicopter tours over attractions.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- GUIDE SERVICE HIERARCHY                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;GuideService">
        <rdfs:subClassOf rdf:resource="&jto;Service"/>
