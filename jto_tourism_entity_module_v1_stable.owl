        <rdfs:label xml:lang="ar">آداب دينية</rdfs:label>
        <rdfs:comment xml:lang="en">Behavioral expectations related to religious sites and practices.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;MosqueEtiquette">
