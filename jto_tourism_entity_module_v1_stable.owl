        <rdfs:label xml:lang="ar">صرافة</rdfs:label>
        <jto:altLabelAR>تبديل عملات</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Currency exchange service for foreign currency.</rdfs:comment>
        <jto:cqReference>CQ-150</jto:cqReference>
