    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasMobilityOption">
        <rdfs:label xml:lang="en">has mobility option</rdfs:label>
        <rdfs:label xml:lang="ar">لديه خيار تنقل</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="&jto;hasAccessibilityFeature"/>
        <rdfs:range rdf:resource="&jto;MobilityOption"/>
        <jto:cqReference>CQ-226</jto:cqReference>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasSuitability">
        <rdfs:label xml:lang="en">has suitability</rdfs:label>
        <rdfs:label xml:lang="ar">لديه ملاءمة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;SuitabilityFeature"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasRealTimeData">
        <rdfs:label xml:lang="en">has real-time data</rdfs:label>
        <rdfs:label xml:lang="ar">لديه بيانات فورية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;RealTimeData"/>
        <jto:cqReference>CQ-296</jto:cqReference>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasCrowdLevel">
        <rdfs:label xml:lang="en">has crowd level</rdfs:label>
        <rdfs:label xml:lang="ar">لديه مستوى ازدحام</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="&jto;hasRealTimeData"/>
        <rdfs:range rdf:resource="&jto;CrowdLevel"/>
        <jto:cqReference>CQ-300</jto:cqReference>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasWeatherData">
        <rdfs:label xml:lang="en">has weather data</rdfs:label>
        <rdfs:label xml:lang="ar">لديه بيانات طقس</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;WeatherData"/>
        <jto:cqReference>CQ-297</jto:cqReference>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasPrediction">
        <rdfs:label xml:lang="en">has prediction</rdfs:label>
        <rdfs:label xml:lang="ar">لديه توقع</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;PredictionModel"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasLightPollutionLevel">
        <rdfs:label xml:lang="en">has light pollution level</rdfs:label>
        <rdfs:label xml:lang="ar">لديه مستوى تلوث ضوئي</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;LightPollutionLevel"/>
        <jto:cqReference>CQ-276</jto:cqReference>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasPricing">
        <rdfs:label xml:lang="en">has pricing</rdfs:label>
        <rdfs:label xml:lang="ar">لديه تسعير</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;Pricing"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasObservation">
        <rdfs:label xml:lang="en">has observation</rdfs:label>
        <rdfs:label xml:lang="ar">لديه ملاحظة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;Observation"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasForecast">
        <rdfs:label xml:lang="en">has forecast</rdfs:label>
        <rdfs:label xml:lang="ar">لديه توقع</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&jto;ForecastPoint"/>
    </owl:ObjectProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 7 &amp; 8 DATA PROPERTIES                                                 -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:DatatypeProperty rdf:about="&jto;isWheelchairAccessible">
        <rdfs:label xml:lang="en">is wheelchair accessible</rdfs:label>
        <rdfs:label xml:lang="ar">ملائم للكراسي المتحركة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
        <jto:cqReference>CQ-005, CQ-076</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isFamilyFriendly">
        <rdfs:label xml:lang="en">is family friendly</rdfs:label>
        <rdfs:label xml:lang="ar">مناسب للعائلات</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
        <jto:cqReference>CQ-004</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;minimumAge">
        <rdfs:label xml:lang="en">minimum age</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأدنى للعمر</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Activity"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-116</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;childDiscountPercentage">
        <rdfs:label xml:lang="en">child discount percentage</rdfs:label>
        <rdfs:label xml:lang="ar">نسبة خصم الأطفال</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <jto:cqReference>CQ-117</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;paceLevel">
        <rdfs:label xml:lang="en">pace level</rdfs:label>
        <rdfs:label xml:lang="ar">مستوى الوتيرة</rdfs:label>
        <rdfs:comment xml:lang="en">Tour pace: slow, moderate, fast</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Activity"/>
        <rdfs:range rdf:resource="&xsd;string"/>
        <jto:cqReference>CQ-227</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;currentWaitMinutes">
        <rdfs:label xml:lang="en">current wait time (minutes)</rdfs:label>
        <rdfs:label xml:lang="ar">وقت الانتظار الحالي (دقائق)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-296</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;crowdLevelValue">
        <rdfs:label xml:lang="en">crowd level value</rdfs:label>
        <rdfs:label xml:lang="ar">قيمة مستوى الازدحام</rdfs:label>
        <rdfs:comment xml:lang="en">Crowd level: 1 (empty) to 5 (very crowded)</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-300</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;temperatureCelsius">
        <rdfs:label xml:lang="en">temperature (Celsius)</rdfs:label>
        <rdfs:label xml:lang="ar">درجة الحرارة (مئوية)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;WeatherForecast"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;precipitationChance">
        <rdfs:label xml:lang="en">precipitation chance</rdfs:label>
        <rdfs:label xml:lang="ar">احتمالية الأمطار</rdfs:label>
        <rdfs:domain rdf:resource="&jto;WeatherForecast"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;bortleScale">
        <rdfs:label xml:lang="en">Bortle scale</rdfs:label>
        <rdfs:label xml:lang="ar">مقياس بورتل</rdfs:label>
        <rdfs:comment xml:lang="en">Light pollution scale 1-9 for stargazing</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-276</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;dailyBudgetJOD">
        <rdfs:label xml:lang="en">daily budget (JOD)</rdfs:label>
        <rdfs:label xml:lang="ar">الميزانية اليومية (دينار)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;BudgetCategory"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <jto:cqReference>CQ-088</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;exchangeRateToUSD">
        <rdfs:label xml:lang="en">exchange rate to USD</rdfs:label>
        <rdfs:label xml:lang="ar">سعر الصرف مقابل الدولار</rdfs:label>
        <rdfs:domain rdf:resource="&jto;ExchangeRate"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <jto:cqReference>CQ-146</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;groupDiscountMinSize">
        <rdfs:label xml:lang="en">group discount minimum size</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأدنى لحجم المجموعة للخصم</rdfs:label>
        <rdfs:domain rdf:resource="&jto;GroupDiscount"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-237</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;groupDiscountPercentage">
        <rdfs:label xml:lang="en">group discount percentage</rdfs:label>
        <rdfs:label xml:lang="ar">نسبة خصم المجموعات</rdfs:label>
        <rdfs:domain rdf:resource="&jto;GroupDiscount"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <jto:cqReference>CQ-237</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;annualVisitorCount">
        <rdfs:label xml:lang="en">annual visitor count</rdfs:label>
        <rdfs:label xml:lang="ar">عدد الزوار السنوي</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <jto:cqReference>CQ-097</jto:cqReference>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;observationTimestamp">
        <rdfs:label xml:lang="en">observation timestamp</rdfs:label>
        <rdfs:label xml:lang="ar">وقت الملاحظة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Observation"/>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;observationValue">
        <rdfs:label xml:lang="en">observation value</rdfs:label>
        <rdfs:label xml:lang="ar">قيمة الملاحظة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Observation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;forecastConfidence">
        <rdfs:label xml:lang="en">forecast confidence</rdfs:label>
        <rdfs:label xml:lang="ar">ثقة التوقع</rdfs:label>
        <rdfs:comment xml:lang="en">Confidence level of forecast (0-1)</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;ForecastPoint"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;modelVersion">
        <rdfs:label xml:lang="en">model version</rdfs:label>
        <rdfs:label xml:lang="ar">إصدار النموذج</rdfs:label>
        <rdfs:domain rdf:resource="&jto;PredictionModel"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;lastTrainingDate">
        <rdfs:label xml:lang="en">last training date</rdfs:label>
        <rdfs:label xml:lang="ar">تاريخ آخر تدريب</rdfs:label>
        <rdfs:domain rdf:resource="&jto;PredictionModel"/>
        <rdfs:range rdf:resource="&xsd;date"/>
    </owl:DatatypeProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 7 &amp; 8 INDIVIDUALS                                                     -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- Accessibility Individuals -->
    <owl:NamedIndividual rdf:about="&jto;PetraVisitorCenterAccessibility">
        <rdf:type rdf:resource="&jto;WheelchairAccessible"/>
        <rdfs:label xml:lang="en">Petra Visitor Center Accessibility</rdfs:label>
        <rdfs:label xml:lang="ar">إمكانية الوصول لمركز زوار البتراء</rdfs:label>
        <jto:isWheelchairAccessible rdf:datatype="&xsd;boolean">true</jto:isWheelchairAccessible>
        <rdfs:comment xml:lang="en">Petra Visitor Center is wheelchair accessible with ramps and accessible restrooms.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PetraHorseCarriage">
        <rdf:type rdf:resource="&jto;HorseCarriage"/>
        <rdfs:label xml:lang="en">Petra Horse Carriage Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة عربات الخيل في البتراء</rdfs:label>
        <rdfs:comment xml:lang="en">Horse-drawn carriage from entrance to Treasury for visitors with limited mobility.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;PetraDonkeyService">
        <rdf:type rdf:resource="&jto;DonkeyRide"/>
        <rdfs:label xml:lang="en">Petra Donkey Ride Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة ركوب الحمار في البتراء</rdfs:label>
        <rdfs:comment xml:lang="en">Donkey rides available for steep climbs to Monastery and High Place of Sacrifice.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;WadiRumAccessibleJeepTour">
        <rdf:type rdf:resource="&jto;WheelchairJeepTour"/>
        <rdfs:label xml:lang="en">Wadi Rum Accessible Jeep Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة جيب ملائمة للكراسي المتحركة في وادي رم</rdfs:label>
        <rdfs:comment xml:lang="en">Some camps offer jeep tours that can accommodate wheelchair users with assistance.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanMuseumAccessibility">
        <rdf:type rdf:resource="&jto;AccessibleMuseum"/>
        <rdfs:label xml:lang="en">Jordan Museum Accessibility</rdfs:label>
        <rdfs:label xml:lang="ar">إمكانية الوصول لمتحف الأردن</rdfs:label>
        <jto:isWheelchairAccessible rdf:datatype="&xsd;boolean">true</jto:isWheelchairAccessible>
        <rdfs:comment xml:lang="en">Jordan Museum has elevators, wheelchair ramps, accessible restrooms, and audio guides.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DeadSeaAccessibleBeach">
        <rdf:type rdf:resource="&jto;AdaptedSwimming"/>
        <rdfs:label xml:lang="en">Dead Sea Accessible Beach</rdfs:label>
        <rdfs:label xml:lang="ar">شاطئ البحر الميت الملائم لذوي الاحتياجات</rdfs:label>
        <rdfs:comment xml:lang="en">Some Dead Sea resorts offer beach wheelchairs and assisted entry to the water.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Budget Category Individuals -->
    <owl:NamedIndividual rdf:about="&jto;JordanBudgetTravel">
        <rdf:type rdf:resource="&jto;BudgetTraveler"/>
        <rdfs:label xml:lang="en">Jordan Budget Travel</rdfs:label>
        <rdfs:label xml:lang="ar">السفر الاقتصادي في الأردن</rdfs:label>
        <jto:dailyBudgetJOD rdf:datatype="&xsd;decimal">40</jto:dailyBudgetJOD>
        <rdfs:comment xml:lang="en">Budget travel in Jordan: 30-50 JOD/day. Hostels, street food, public transport.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanMidRangeTravel">
        <rdf:type rdf:resource="&jto;MidRangeTraveler"/>
        <rdfs:label xml:lang="en">Jordan Mid-Range Travel</rdfs:label>
        <rdfs:label xml:lang="ar">السفر متوسط الميزانية في الأردن</rdfs:label>
        <jto:dailyBudgetJOD rdf:datatype="&xsd;decimal">115</jto:dailyBudgetJOD>
        <rdfs:comment xml:lang="en">Mid-range travel: 80-150 JOD/day. 3-star hotels, restaurant meals, private tours.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanLuxuryTravel">
        <rdf:type rdf:resource="&jto;LuxuryTraveler"/>
        <rdfs:label xml:lang="en">Jordan Luxury Travel</rdfs:label>
        <rdfs:label xml:lang="ar">السفر الفاخر في الأردن</rdfs:label>
        <jto:dailyBudgetJOD rdf:datatype="&xsd;decimal">300</jto:dailyBudgetJOD>
        <rdfs:comment xml:lang="en">Luxury travel: 200+ JOD/day. 5-star hotels, fine dining, private guides.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Exchange Rate Individual -->
    <owl:NamedIndividual rdf:about="&jto;JODExchangeRate">
        <rdf:type rdf:resource="&jto;ExchangeRate"/>
        <rdfs:label xml:lang="en">JOD Exchange Rate</rdfs:label>
        <rdfs:label xml:lang="ar">سعر صرف الدينار الأردني</rdfs:label>
        <jto:exchangeRateToUSD rdf:datatype="&xsd;decimal">1.41</jto:exchangeRateToUSD>
        <rdfs:comment xml:lang="en">Jordanian Dinar is pegged to USD at approximately 1 JOD = 1.41 USD.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Light Pollution Individuals -->
    <owl:NamedIndividual rdf:about="&jto;WadiRumDarkSky">
        <rdf:type rdf:resource="&jto;DarkSkyZone"/>
        <rdfs:label xml:lang="en">Wadi Rum Dark Sky</rdfs:label>
        <rdfs:label xml:lang="ar">سماء وادي رم المظلمة</rdfs:label>
        <jto:bortleScale rdf:datatype="&xsd;integer">2</jto:bortleScale>
        <rdfs:comment xml:lang="en">Wadi Rum is one of the best stargazing locations in Jordan with minimal light pollution.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DanaReserveDarkSky">
        <rdf:type rdf:resource="&jto;LowPollution"/>
        <rdfs:label xml:lang="en">Dana Reserve Dark Sky</rdfs:label>
        <rdfs:label xml:lang="ar">سماء محمية ضانا المظلمة</rdfs:label>
        <jto:bortleScale rdf:datatype="&xsd;integer">3</jto:bortleScale>
        <rdfs:comment xml:lang="en">Dana Biosphere Reserve offers good stargazing with low light pollution.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Weather Alert Individuals -->
    <owl:NamedIndividual rdf:about="&jto;WadiMujibFlashFloodRisk">
        <rdf:type rdf:resource="&jto;FlashFlood"/>
        <rdfs:label xml:lang="en">Wadi Mujib Flash Flood Risk</rdfs:label>
        <rdfs:label xml:lang="ar">خطر السيول في وادي الموجب</rdfs:label>
        <rdfs:comment xml:lang="en">Wadi Mujib closes during rain due to flash flood danger. Always check conditions before visiting.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DesertSandstormWarning">
        <rdf:type rdf:resource="&jto;SandStorm"/>
        <rdfs:label xml:lang="en">Desert Sandstorm Warning</rdfs:label>
        <rdfs:label xml:lang="ar">تحذير عاصفة رملية صحراوية</rdfs:label>
        <rdfs:comment xml:lang="en">Sandstorms can occur in spring/autumn. Check weather before desert tours.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;SummerHeatAdvisory">
        <rdf:type rdf:resource="&jto;HeatWave"/>
        <rdfs:label xml:lang="en">Summer Heat Advisory</rdfs:label>
        <rdfs:label xml:lang="ar">تحذير حرارة الصيف</rdfs:label>
        <rdfs:comment xml:lang="en">Summer temperatures can exceed 40°C in desert areas. Early morning visits recommended.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Visitor Statistics Individuals -->
    <owl:NamedIndividual rdf:about="&jto;PetraVisitorStats">
        <rdf:type rdf:resource="&jto;AnnualVisitors"/>
        <rdfs:label xml:lang="en">Petra Visitor Statistics</rdfs:label>
        <rdfs:label xml:lang="ar">إحصائيات زوار البتراء</rdfs:label>
        <jto:annualVisitorCount rdf:datatype="&xsd;integer">1100000</jto:annualVisitorCount>
        <rdfs:comment xml:lang="en">Petra receives approximately 1.1 million visitors annually (pre-pandemic peak).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JerashVisitorStats">
        <rdf:type rdf:resource="&jto;AnnualVisitors"/>
        <rdfs:label xml:lang="en">Jerash Visitor Statistics</rdfs:label>
        <rdfs:label xml:lang="ar">إحصائيات زوار جرش</rdfs:label>
        <jto:annualVisitorCount rdf:datatype="&xsd;integer">350000</jto:annualVisitorCount>
        <rdfs:comment xml:lang="en">Jerash receives approximately 350,000 visitors annually.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Group Discount Individual -->
    <owl:NamedIndividual rdf:about="&jto;PetraGroupDiscount">
        <rdf:type rdf:resource="&jto;GroupDiscount"/>
        <rdfs:label xml:lang="en">Petra Group Discount</rdfs:label>
        <rdfs:label xml:lang="ar">خصم المجموعات للبتراء</rdfs:label>
        <jto:groupDiscountMinSize rdf:datatype="&xsd;integer">10</jto:groupDiscountMinSize>
        <jto:groupDiscountPercentage rdf:datatype="&xsd;decimal">10</jto:groupDiscountPercentage>
        <rdfs:comment xml:lang="en">Groups of 10+ may receive discounted entry fees at Petra.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Moon Phase Individuals for Stargazing -->
    <owl:NamedIndividual rdf:about="&jto;NewMoonStargazing">
        <rdf:type rdf:resource="&jto;NewMoon"/>
        <rdfs:label xml:lang="en">New Moon Stargazing</rdfs:label>
        <rdfs:label xml:lang="ar">مراقبة النجوم في المحاق</rdfs:label>
        <rdfs:comment xml:lang="en">Best stargazing conditions during new moon phase.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ════════════════════════════════════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- MODULE 9: AGENT HIERARCHY (People &amp; Organizations)                               -->
    <!-- CQ-065, CQ-114, CQ-116-120, CQ-132, CQ-159, CQ-170, CQ-197, CQ-201, CQ-203,      -->
    <!-- CQ-226-235, CQ-246, CQ-251-258, CQ-271                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════  -->
    <!-- ════════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────────── -->
    <!-- Agent (Root Class)                                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Agent">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Agent</rdfs:label>
        <rdfs:label xml:lang="ar">فاعل</rdfs:label>
        <rdfs:comment xml:lang="en">People and organizations involved in tourism activities.</rdfs:comment>
    </owl:Class>

