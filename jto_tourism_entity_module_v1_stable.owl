    </owl:Class>

    <owl:Class rdf:about="&jto;DesertYogaRetreat">
        <rdfs:subClassOf rdf:resource="&jto;Yoga"/>
        <rdfs:label xml:lang="en">Desert Yoga Retreat</rdfs:label>
        <rdfs:label xml:lang="ar">معتكف يوغا صحراوي</rdfs:label>
        <rdfs:comment xml:lang="en">Multi-day yoga experience in the desert environment.</rdfs:comment>
        <jto:cqReference>CQ-078</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Meditation">
