    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- ACCOMMODATION OBJECT PROPERTIES                                              -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:ObjectProperty rdf:about="&jto;offersAmenity">
        <rdfs:label xml:lang="en">offers amenity</rdfs:label>
        <rdfs:label xml:lang="ar">يوفر مرفق</rdfs:label>
        <rdfs:comment xml:lang="en">Links accommodation to amenities it provides.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&jto;Amenity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasRoomType">
        <rdfs:label xml:lang="en">has room type</rdfs:label>
        <rdfs:label xml:lang="ar">لديه نوع غرفة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&jto;RoomType"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;managedBy">
        <rdfs:label xml:lang="en">managed by</rdfs:label>
        <rdfs:label xml:lang="ar">يدار بواسطة</rdfs:label>
        <rdfs:comment xml:lang="en">Links accommodation to its management company or owner.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;nearAttraction">
        <rdfs:label xml:lang="en">near attraction</rdfs:label>
        <rdfs:label xml:lang="ar">بالقرب من معلم</rdfs:label>
        <rdfs:comment xml:lang="en">Links accommodation to nearby tourist attractions.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&jto;Attraction"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;suitableForTravelerType">
        <rdfs:label xml:lang="en">suitable for traveler type</rdfs:label>
        <rdfs:label xml:lang="ar">مناسب لنوع المسافر</rdfs:label>
        <rdfs:comment xml:lang="en">Links accommodation to types of travelers it caters to.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
    </owl:ObjectProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- ACCOMMODATION DATA PROPERTIES                                                -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:DatatypeProperty rdf:about="&jto;starRating">
        <rdfs:label xml:lang="en">star rating</rdfs:label>
        <rdfs:label xml:lang="ar">تصنيف النجوم</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
        <rdfs:comment xml:lang="en">Hotel star rating from 1 to 5.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;pricePerNight">
        <rdfs:label xml:lang="en">price per night</rdfs:label>
        <rdfs:label xml:lang="ar">سعر الليلة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <rdfs:comment xml:lang="en">Average price per night in JOD.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;minPricePerNight">
        <rdfs:label xml:lang="en">minimum price per night</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأدنى لسعر الليلة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;maxPricePerNight">
        <rdfs:label xml:lang="en">maximum price per night</rdfs:label>
        <rdfs:label xml:lang="ar">الحد الأقصى لسعر الليلة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;numberOfRooms">
        <rdfs:label xml:lang="en">number of rooms</rdfs:label>
        <rdfs:label xml:lang="ar">عدد الغرف</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;checkInTime">
        <rdfs:label xml:lang="en">check-in time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت تسجيل الوصول</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;checkOutTime">
        <rdfs:label xml:lang="en">check-out time</rdfs:label>
        <rdfs:label xml:lang="ar">وقت تسجيل المغادرة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;time"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;userRating">
        <rdfs:label xml:lang="en">user rating</rdfs:label>
        <rdfs:label xml:lang="ar">تقييم المستخدمين</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <rdfs:comment xml:lang="en">Average user rating from 0.0 to 5.0.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;reviewCount">
        <rdfs:label xml:lang="en">review count</rdfs:label>
        <rdfs:label xml:lang="ar">عدد التقييمات</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isWheelchairAccessible">
        <rdfs:label xml:lang="en">is wheelchair accessible</rdfs:label>
        <rdfs:label xml:lang="ar">متاح للكراسي المتحركة</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Accommodation"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isFamilyFriendly">
