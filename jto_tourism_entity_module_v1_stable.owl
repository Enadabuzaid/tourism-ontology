    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 3: ACTIVITY HIERARCHY                                                 -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Activity (Root Class)                                                        -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Activity">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Activity</rdfs:label>
        <rdfs:label xml:lang="ar">نشاط</rdfs:label>
        <jto:altLabelAR>فعالية</jto:altLabelAR>
        <rdfs:comment xml:lang="en">A tourism activity or experience that visitors can participate in during their trip to Jordan.</rdfs:comment>
        <rdfs:comment xml:lang="ar">نشاط سياحي أو تجربة يمكن للزوار المشاركة فيها خلال رحلتهم إلى الأردن.</rdfs:comment>
        <jto:cqReference>CQ-010, CQ-050</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Adventure Activity Hierarchy                                                 -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;AdventureActivity">
        <rdfs:subClassOf rdf:resource="&jto;Activity"/>
        <rdfs:label xml:lang="en">Adventure Activity</rdfs:label>
        <rdfs:label xml:lang="ar">نشاط مغامرة</rdfs:label>
        <jto:altLabelAR>أنشطة المغامرات</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Outdoor activities involving physical challenge, risk, or excitement.</rdfs:comment>
        <jto:cqReference>CQ-051, CQ-108</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Hiking">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Hiking</rdfs:label>
        <rdfs:label xml:lang="ar">المشي لمسافات طويلة</rdfs:label>
        <jto:altLabelAR>هايكنج</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Walking activity on trails through nature, ranging from easy to challenging.</rdfs:comment>
        <jto:cqReference>CQ-052, CQ-111</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DayHike">
        <rdfs:subClassOf rdf:resource="&jto;Hiking"/>
        <rdfs:label xml:lang="en">Day Hike</rdfs:label>
        <rdfs:label xml:lang="ar">نزهة يومية</rdfs:label>
        <rdfs:comment xml:lang="en">Hiking activity completed within a single day.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;MultiDayTrek">
        <rdfs:subClassOf rdf:resource="&jto;Hiking"/>
        <rdfs:label xml:lang="en">Multi-Day Trek</rdfs:label>
        <rdfs:label xml:lang="ar">رحلة مشي متعددة الأيام</rdfs:label>
        <rdfs:comment xml:lang="en">Extended hiking trip spanning multiple days with overnight camping.</rdfs:comment>
        <jto:cqReference>CQ-113</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;GuidedHike">
        <rdfs:subClassOf rdf:resource="&jto;Hiking"/>
        <rdfs:label xml:lang="en">Guided Hike</rdfs:label>
        <rdfs:label xml:lang="ar">نزهة مع مرشد</rdfs:label>
        <rdfs:comment xml:lang="en">Hiking activity led by a professional guide.</rdfs:comment>
        <jto:cqReference>CQ-114</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;RockClimbing">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Rock Climbing</rdfs:label>
        <rdfs:label xml:lang="ar">تسلق الصخور</rdfs:label>
        <rdfs:comment xml:lang="en">Climbing natural rock formations, popular in Wadi Rum.</rdfs:comment>
        <jto:cqReference>CQ-053</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Bouldering">
        <rdfs:subClassOf rdf:resource="&jto;RockClimbing"/>
        <rdfs:label xml:lang="en">Bouldering</rdfs:label>
        <rdfs:label xml:lang="ar">تسلق الصخور الصغيرة</rdfs:label>
        <rdfs:comment xml:lang="en">Climbing short rock formations without ropes.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Canyoning">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Canyoning</rdfs:label>
        <rdfs:label xml:lang="ar">استكشاف الأودية</rdfs:label>
        <jto:altLabelEN>Canyoneering</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Exploring canyons using techniques like rappelling, swimming, and climbing.</rdfs:comment>
        <jto:cqReference>CQ-054, CQ-112</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WetCanyoning">
        <rdfs:subClassOf rdf:resource="&jto;Canyoning"/>
        <rdfs:label xml:lang="en">Wet Canyoning</rdfs:label>
        <rdfs:label xml:lang="ar">استكشاف الأودية المائية</rdfs:label>
        <rdfs:comment xml:lang="en">Canyoning through water-filled gorges, popular at Wadi Mujib.</rdfs:comment>
        <jto:cqReference>CQ-055</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DryCanyoning">
        <rdfs:subClassOf rdf:resource="&jto;Canyoning"/>
        <rdfs:label xml:lang="en">Dry Canyoning</rdfs:label>
        <rdfs:label xml:lang="ar">استكشاف الأودية الجافة</rdfs:label>
        <rdfs:comment xml:lang="en">Canyoning in dry canyons without significant water.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Rappelling">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Rappelling</rdfs:label>
        <rdfs:label xml:lang="ar">الهبوط بالحبال</rdfs:label>
        <jto:altLabelEN>Abseiling</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Descending steep rock faces using ropes.</rdfs:comment>
        <jto:cqReference>CQ-056</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ZipLining">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Zip Lining</rdfs:label>
        <rdfs:label xml:lang="ar">الانزلاق على الحبال</rdfs:label>
        <jto:altLabelAR>زيب لاين</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Sliding along a cable from a high point, available at several locations in Jordan.</rdfs:comment>
        <jto:cqReference>CQ-057</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Paragliding">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Paragliding</rdfs:label>
        <rdfs:label xml:lang="ar">الطيران الشراعي</rdfs:label>
        <rdfs:comment xml:lang="en">Flying with a paraglider, available at locations like Dead Sea cliffs.</rdfs:comment>
        <jto:cqReference>CQ-058</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HotAirBallooning">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Hot Air Ballooning</rdfs:label>
        <rdfs:label xml:lang="ar">ركوب المنطاد</rdfs:label>
        <rdfs:comment xml:lang="en">Scenic flights in hot air balloons over Wadi Rum desert.</rdfs:comment>
        <jto:cqReference>CQ-059, CQ-280</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Sandboarding">
        <rdfs:subClassOf rdf:resource="&jto;AdventureActivity"/>
        <rdfs:label xml:lang="en">Sandboarding</rdfs:label>
        <rdfs:label xml:lang="ar">التزلج على الرمال</rdfs:label>
        <rdfs:comment xml:lang="en">Sliding down sand dunes on a board, popular in Wadi Rum.</rdfs:comment>
        <jto:cqReference>CQ-060</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Water Activity Hierarchy                                                     -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;WaterActivity">
        <rdfs:subClassOf rdf:resource="&jto;Activity"/>
        <rdfs:label xml:lang="en">Water Activity</rdfs:label>
        <rdfs:label xml:lang="ar">نشاط مائي</rdfs:label>
        <rdfs:comment xml:lang="en">Activities involving water, including sea sports, swimming, and floating.</rdfs:comment>
        <jto:cqReference>CQ-061</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaFloating">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Dead Sea Floating</rdfs:label>
        <rdfs:label xml:lang="ar">الطفو في البحر الميت</rdfs:label>
        <rdfs:comment xml:lang="en">The unique experience of floating in the highly saline Dead Sea water.</rdfs:comment>
        <rdfs:comment xml:lang="ar">تجربة فريدة للطفو في مياه البحر الميت عالية الملوحة.</rdfs:comment>
        <jto:cqReference>CQ-062, CQ-200</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ScubaDiving">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Scuba Diving</rdfs:label>
        <rdfs:label xml:lang="ar">الغوص</rdfs:label>
        <jto:altLabelAR>غطس سكوبا</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Underwater diving using breathing equipment, excellent in Aqaba's Red Sea.</rdfs:comment>
        <jto:cqReference>CQ-063, CQ-115</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BeginnerDiving">
        <rdfs:subClassOf rdf:resource="&jto;ScubaDiving"/>
        <rdfs:label xml:lang="en">Beginner Diving</rdfs:label>
        <rdfs:label xml:lang="ar">غوص للمبتدئين</rdfs:label>
        <rdfs:comment xml:lang="en">Introductory diving course for first-time divers.</rdfs:comment>
        <jto:cqReference>CQ-116</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CertifiedDiving">
        <rdfs:subClassOf rdf:resource="&jto;ScubaDiving"/>
        <rdfs:label xml:lang="en">Certified Diving</rdfs:label>
        <rdfs:label xml:lang="ar">غوص معتمد</rdfs:label>
        <rdfs:comment xml:lang="en">Diving for certified divers with PADI or equivalent certification.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;WreckDiving">
        <rdfs:subClassOf rdf:resource="&jto;ScubaDiving"/>
        <rdfs:label xml:lang="en">Wreck Diving</rdfs:label>
        <rdfs:label xml:lang="ar">غوص على الحطام</rdfs:label>
        <rdfs:comment xml:lang="en">Diving to explore sunken ships and aircraft, including the famous tank in Aqaba.</rdfs:comment>
        <jto:cqReference>CQ-117</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Snorkeling">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Snorkeling</rdfs:label>
        <rdfs:label xml:lang="ar">السنوركلينج</rdfs:label>
        <jto:altLabelAR>الغطس السطحي</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Swimming with mask and snorkel to observe marine life near the surface.</rdfs:comment>
        <jto:cqReference>CQ-064</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;GlassBottomBoat">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Glass Bottom Boat</rdfs:label>
        <rdfs:label xml:lang="ar">قارب بقاع زجاجي</rdfs:label>
        <rdfs:comment xml:lang="en">Boat tour with transparent bottom for viewing underwater life without getting wet.</rdfs:comment>
        <jto:cqReference>CQ-065</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Kayaking">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Kayaking</rdfs:label>
        <rdfs:label xml:lang="ar">التجديف بالكاياك</rdfs:label>
        <rdfs:comment xml:lang="en">Paddling in a kayak, available on the Dead Sea and in Aqaba.</rdfs:comment>
        <jto:cqReference>CQ-066</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;JetSki">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Jet Ski</rdfs:label>
        <rdfs:label xml:lang="ar">جت سكي</rdfs:label>
        <rdfs:comment xml:lang="en">Riding personal watercraft, available in Aqaba.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Paddleboarding">
        <rdfs:subClassOf rdf:resource="&jto;WaterActivity"/>
        <rdfs:label xml:lang="en">Paddleboarding</rdfs:label>
        <rdfs:label xml:lang="ar">التجديف واقفاً</rdfs:label>
        <jto:altLabelEN>SUP</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Standing and paddling on a large board, available in Aqaba.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Desert Activity Hierarchy                                                    -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;DesertActivity">
        <rdfs:subClassOf rdf:resource="&jto;Activity"/>
