        <jto:cqReference>CQ-074, CQ-202</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaSaltScrub">
        <rdfs:subClassOf rdf:resource="&jto;SpaTreatment"/>
