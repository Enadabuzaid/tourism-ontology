        <rdfs:label xml:lang="en">sells craft</rdfs:label>
        <rdfs:label xml:lang="ar">يبيع حرفة</rdfs:label>
        <rdfs:comment xml:lang="en">Links a shop to traditional crafts it sells.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;ShoppingVenue"/>
        <rdfs:range rdf:resource="&jto;TraditionalCraft"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;usesCookingMethod">
        <rdfs:label xml:lang="en">uses cooking method</rdfs:label>
        <rdfs:label xml:lang="ar">يستخدم طريقة طهي</rdfs:label>
        <rdfs:comment xml:lang="en">Links a dish to its cooking method.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;TraditionalDish"/>
        <rdfs:range rdf:resource="&jto;CookingMethod"/>
    </owl:ObjectProperty>

