<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY jto "http://www.jordantourism.org/ontology#" >
    <!ENTITY geo "http://www.opengis.net/ont/geosparql#" >
    <!ENTITY time "http://www.w3.org/2006/time#" >
    <!ENTITY schema "http://schema.org/" >
    <!ENTITY skos "http://www.w3.org/2004/02/skos/core#" >
    <!ENTITY prov "http://www.w3.org/ns/prov#" >
    <!ENTITY dc "http://purl.org/dc/elements/1.1/" >
    <!ENTITY dcterms "http://purl.org/dc/terms/" >
]>

<rdf:RDF xmlns="http://www.jordantourism.org/ontology#"
     xml:base="http://www.jordantourism.org/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:jto="http://www.jordantourism.org/ontology#"
     xmlns:geo="http://www.opengis.net/ont/geosparql#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:schema="http://schema.org/"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dcterms="http://purl.org/dc/terms/">

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- ONTOLOGY DECLARATION                                                         -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    
    <owl:Ontology rdf:about="http://www.jordantourism.org/ontology/v1-archive">
        <dc:title xml:lang="en">Jordan Tourism Ontology (JTO) - TourismEntity Module</dc:title>
        <dc:title xml:lang="ar">أنطولوجيا السياحة الأردنية - وحدة الكيانات السياحية</dc:title>
        <dc:description xml:lang="en">This module defines the core TourismEntity classes including Place, Event, and Route hierarchies for the Jordan Tourism Ontology. It covers competency questions CQ-001 to CQ-300 related to tourism entities.</dc:description>
        <dc:description xml:lang="ar">هذه الوحدة تحدد فئات الكيانات السياحية الأساسية بما في ذلك التسلسلات الهرمية للأماكن والأحداث والمسارات لأنطولوجيا السياحة الأردنية.</dc:description>
        <dc:creator>Enad Abu Zaid</dc:creator>
        <dcterms:created rdf:datatype="&xsd;date">2026-01-17</dcterms:created>
        <dcterms:modified rdf:datatype="&xsd;date">2026-01-17</dcterms:modified>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <rdfs:comment xml:lang="en">Module: TourismEntity (Place + Event + Route)</rdfs:comment>
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <owl:imports rdf:resource="http://www.w3.org/2006/time"/>
    </owl:Ontology>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- ANNOTATION PROPERTIES                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    
    <owl:AnnotationProperty rdf:about="&jto;altLabelAR">
        <rdfs:label xml:lang="en">Arabic Alternative Label</rdfs:label>
        <rdfs:label xml:lang="ar">التسمية البديلة بالعربية</rdfs:label>
        <rdfs:comment xml:lang="en">Alternative name in Arabic for entity disambiguation</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="&skos;altLabel"/>
    </owl:AnnotationProperty>
    
    <owl:AnnotationProperty rdf:about="&jto;altLabelEN">
        <rdfs:label xml:lang="en">English Alternative Label</rdfs:label>
        <rdfs:label xml:lang="ar">التسمية البديلة بالإنجليزية</rdfs:label>
        <rdfs:comment xml:lang="en">Alternative name in English for entity disambiguation</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="&skos;altLabel"/>
    </owl:AnnotationProperty>
    
    <owl:AnnotationProperty rdf:about="&jto;cqReference">
        <rdfs:label xml:lang="en">Competency Question Reference</rdfs:label>
        <rdfs:comment xml:lang="en">References the competency question(s) this class addresses</rdfs:comment>
    </owl:AnnotationProperty>

    <owl:AnnotationProperty rdf:about="&jto;wikidataID">
        <rdfs:label xml:lang="en">Wikidata ID</rdfs:label>
        <rdfs:comment xml:lang="en">Links to Wikidata entity for disambiguation</rdfs:comment>
    </owl:AnnotationProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- TOP-LEVEL CLASS: TourismEntity                                               -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    
    <owl:Class rdf:about="&jto;TourismEntity">
        <rdfs:label xml:lang="en">Tourism Entity</rdfs:label>
        <rdfs:label xml:lang="ar">كيان سياحي</rdfs:label>
        <rdfs:comment xml:lang="en">Abstract superclass for all tourism-related entities in Jordan including places, events, and routes.</rdfs:comment>
        <rdfs:comment xml:lang="ar">الفئة الأساسية المجردة لجميع الكيانات المتعلقة بالسياحة في الأردن بما في ذلك الأماكن والأحداث والمسارات.</rdfs:comment>
        <jto:cqReference>CQ-001 to CQ-300</jto:cqReference>
    </owl:Class>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- 1.1 PLACE HIERARCHY                                                          -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Place (Root of spatial tourism entities)                                     -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    
    <owl:Class rdf:about="&jto;Place">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:subClassOf rdf:resource="&geo;Feature"/>
        <rdfs:label xml:lang="en">Place</rdfs:label>
        <rdfs:label xml:lang="ar">مكان</rdfs:label>
        <rdfs:comment xml:lang="en">A spatial entity representing any location relevant to tourism in Jordan.</rdfs:comment>
        <rdfs:comment xml:lang="ar">كيان مكاني يمثل أي موقع ذي صلة بالسياحة في الأردن.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Place"/>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Destination Hierarchy                                                        -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    
    <owl:Class rdf:about="&jto;Destination">
        <rdfs:subClassOf rdf:resource="&jto;Place"/>
        <rdfs:label xml:lang="en">Destination</rdfs:label>
        <rdfs:label xml:lang="ar">وجهة</rdfs:label>
        <rdfs:comment xml:lang="en">A tourism destination that travelers visit, including cities, regions, and protected areas.</rdfs:comment>
        <rdfs:comment xml:lang="ar">وجهة سياحية يزورها المسافرون، بما في ذلك المدن والمناطق والمحميات.</rdfs:comment>
        <jto:cqReference>CQ-001, CQ-002, CQ-003</jto:cqReference>
    </owl:Class>

    <!-- City -->
    <owl:Class rdf:about="&jto;City">
        <rdfs:subClassOf rdf:resource="&jto;Destination"/>
        <rdfs:label xml:lang="en">City</rdfs:label>
        <rdfs:label xml:lang="ar">مدينة</rdfs:label>
        <rdfs:comment xml:lang="en">An urban destination in Jordan.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;City"/>
    </owl:Class>

    <!-- Specific Cities (as Classes for potential instantiation) -->
    <owl:Class rdf:about="&jto;AmmanCity">
        <rdfs:subClassOf rdf:resource="&jto;City"/>
        <rdfs:label xml:lang="en">Amman</rdfs:label>
        <rdfs:label xml:lang="ar">عمّان</rdfs:label>
        <jto:altLabelAR>عمان العاصمة</jto:altLabelAR>
        <jto:altLabelEN>Amman Capital</jto:altLabelEN>
        <rdfs:comment xml:lang="en">The capital city of Jordan, known for the Citadel and Roman Theater.</rdfs:comment>
        <rdfs:comment xml:lang="ar">عاصمة الأردن، المعروفة بالقلعة والمدرج الروماني.</rdfs:comment>
        <jto:wikidataID>Q3805</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;AqabaCity">
        <rdfs:subClassOf rdf:resource="&jto;City"/>
        <rdfs:label xml:lang="en">Aqaba</rdfs:label>
        <rdfs:label xml:lang="ar">العقبة</rdfs:label>
        <jto:altLabelAR>عقبة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Jordan's only coastal city on the Red Sea, popular for diving and beaches.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مدينة الأردن الساحلية الوحيدة على البحر الأحمر، مشهورة بالغوص والشواطئ.</rdfs:comment>
        <jto:wikidataID>Q125394</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;MadabaCity">
        <rdfs:subClassOf rdf:resource="&jto;City"/>
        <rdfs:label xml:lang="en">Madaba</rdfs:label>
        <rdfs:label xml:lang="ar">مادبا</rdfs:label>
        <jto:altLabelAR>مأدبا</jto:altLabelAR>
        <jto:altLabelEN>Madaba Mosaic City</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Known as the "City of Mosaics" for its Byzantine-era mosaic map.</rdfs:comment>
        <rdfs:comment xml:lang="ar">تُعرف بـ "مدينة الفسيفساء" لخريطتها الفسيفسائية من العصر البيزنطي.</rdfs:comment>
        <jto:wikidataID>Q1757639</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;JerashCity">
        <rdfs:subClassOf rdf:resource="&jto;City"/>
        <rdfs:label xml:lang="en">Jerash</rdfs:label>
        <rdfs:label xml:lang="ar">جرش</rdfs:label>
        <jto:altLabelEN>Gerasa</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Ancient Roman city known for the best-preserved Roman ruins outside Italy.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مدينة رومانية قديمة معروفة بأفضل الآثار الرومانية المحفوظة خارج إيطاليا.</rdfs:comment>
        <jto:wikidataID>Q217065</jto:wikidataID>
    </owl:Class>

    <!-- Region -->
    <owl:Class rdf:about="&jto;Region">
        <rdfs:subClassOf rdf:resource="&jto;Destination"/>
        <rdfs:label xml:lang="en">Region</rdfs:label>
        <rdfs:label xml:lang="ar">منطقة</rdfs:label>
        <rdfs:comment xml:lang="en">A geographical region that serves as a tourism destination.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaRegion">
        <rdfs:subClassOf rdf:resource="&jto;Region"/>
        <rdfs:label xml:lang="en">Dead Sea Region</rdfs:label>
        <rdfs:label xml:lang="ar">منطقة البحر الميت</rdfs:label>
        <jto:altLabelAR>البحر الميت</jto:altLabelAR>
        <rdfs:comment xml:lang="en">The lowest point on Earth, famous for wellness tourism and unique floating experience.</rdfs:comment>
        <rdfs:comment xml:lang="ar">أخفض نقطة على الأرض، مشهورة بالسياحة العلاجية وتجربة الطفو الفريدة.</rdfs:comment>
        <jto:cqReference>CQ-051</jto:cqReference>
        <jto:wikidataID>Q43359</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;WadiRumRegion">
        <rdfs:subClassOf rdf:resource="&jto;Region"/>
        <rdfs:label xml:lang="en">Wadi Rum</rdfs:label>
        <rdfs:label xml:lang="ar">وادي رم</rdfs:label>
        <jto:altLabelAR>الوادي القمري</jto:altLabelAR>
        <jto:altLabelEN>Valley of the Moon</jto:altLabelEN>
        <rdfs:comment xml:lang="en">UNESCO World Heritage desert landscape known for camping, stargazing, and film locations.</rdfs:comment>
        <rdfs:comment xml:lang="ar">المناظر الصحراوية المدرجة في قائمة التراث العالمي لليونسكو، معروفة بالتخييم ومراقبة النجوم ومواقع التصوير.</rdfs:comment>
        <jto:cqReference>CQ-109</jto:cqReference>
        <jto:wikidataID>Q206958</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;JordanValleyRegion">
        <rdfs:subClassOf rdf:resource="&jto;Region"/>
        <rdfs:label xml:lang="en">Jordan Valley</rdfs:label>
        <rdfs:label xml:lang="ar">غور الأردن</rdfs:label>
        <jto:altLabelAR>الأغوار</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Fertile agricultural region stretching along the Jordan River.</rdfs:comment>
    </owl:Class>

    <!-- Protected Area -->
    <owl:Class rdf:about="&jto;ProtectedArea">
        <rdfs:subClassOf rdf:resource="&jto;Destination"/>
        <rdfs:label xml:lang="en">Protected Area</rdfs:label>
        <rdfs:label xml:lang="ar">منطقة محمية</rdfs:label>
        <rdfs:comment xml:lang="en">A nature reserve or marine reserve managed for conservation and eco-tourism.</rdfs:comment>
        <jto:cqReference>CQ-082</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;NatureReserve">
        <rdfs:subClassOf rdf:resource="&jto;ProtectedArea"/>
        <rdfs:label xml:lang="en">Nature Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">محمية طبيعية</rdfs:label>
        <rdfs:comment xml:lang="en">A terrestrial protected area managed by RSCN.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DanaBiosphereReserve">
        <rdfs:subClassOf rdf:resource="&jto;NatureReserve"/>
        <rdfs:label xml:lang="en">Dana Biosphere Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">محمية ضانا للمحيط الحيوي</rdfs:label>
        <jto:altLabelAR>ضانا</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Jordan's largest nature reserve, featuring diverse ecosystems and eco-lodges.</rdfs:comment>
        <jto:wikidataID>Q1158968</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;WadiMujibReserve">
        <rdfs:subClassOf rdf:resource="&jto;NatureReserve"/>
        <rdfs:label xml:lang="en">Wadi Mujib Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">محمية وادي الموجب</rdfs:label>
        <jto:altLabelAR>الموجب</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Known as Jordan's Grand Canyon, famous for canyoning and water activities.</rdfs:comment>
        <jto:wikidataID>Q2542014</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;AzraqWetlandReserve">
        <rdfs:subClassOf rdf:resource="&jto;NatureReserve"/>
        <rdfs:label xml:lang="en">Azraq Wetland Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">محمية الأزرق المائية</rdfs:label>
        <jto:altLabelAR>الأزرق</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Unique wetland oasis in the eastern desert, important for migratory birds.</rdfs:comment>
        <jto:wikidataID>Q4832827</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;MarineReserve">
        <rdfs:subClassOf rdf:resource="&jto;ProtectedArea"/>
        <rdfs:label xml:lang="en">Marine Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">محمية بحرية</rdfs:label>
        <rdfs:comment xml:lang="en">A marine protected area for coral reef and underwater conservation.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;AqabaMarineReserve">
        <rdfs:subClassOf rdf:resource="&jto;MarineReserve"/>
        <rdfs:label xml:lang="en">Aqaba Marine Reserve</rdfs:label>
        <rdfs:label xml:lang="ar">المحمية البحرية في العقبة</rdfs:label>
        <rdfs:comment xml:lang="en">Red Sea marine park protecting coral reefs and dive sites.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Attraction Hierarchy                                                         -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    
    <owl:Class rdf:about="&jto;Attraction">
        <rdfs:subClassOf rdf:resource="&jto;Place"/>
        <rdfs:label xml:lang="en">Attraction</rdfs:label>
        <rdfs:label xml:lang="ar">معلم سياحي</rdfs:label>
        <jto:altLabelAR>مَعْلَم</jto:altLabelAR>
        <rdfs:comment xml:lang="en">A point of interest that tourists visit, including cultural, heritage, natural, and religious sites.</rdfs:comment>
        <rdfs:comment xml:lang="ar">نقطة اهتمام يزورها السياح، بما في ذلك المواقع الثقافية والتراثية والطبيعية والدينية.</rdfs:comment>
        <jto:cqReference>CQ-001 to CQ-010</jto:cqReference>
        <owl:equivalentClass rdf:resource="&schema;TouristAttraction"/>
    </owl:Class>

    <!-- Cultural Site -->
    <owl:Class rdf:about="&jto;CulturalSite">
        <rdfs:subClassOf rdf:resource="&jto;Attraction"/>
        <rdfs:label xml:lang="en">Cultural Site</rdfs:label>
        <rdfs:label xml:lang="ar">موقع ثقافي</rdfs:label>
        <rdfs:comment xml:lang="en">An attraction showcasing cultural heritage including museums, galleries, and cultural centers.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Museum">
        <rdfs:subClassOf rdf:resource="&jto;CulturalSite"/>
        <rdfs:label xml:lang="en">Museum</rdfs:label>
        <rdfs:label xml:lang="ar">متحف</rdfs:label>
        <rdfs:comment xml:lang="en">A building housing collections of historical, artistic, or scientific interest.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Museum"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;JordanMuseum">
        <rdfs:subClassOf rdf:resource="&jto;Museum"/>
        <rdfs:label xml:lang="en">Jordan Museum</rdfs:label>
        <rdfs:label xml:lang="ar">متحف الأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Jordan's national museum in Amman, housing the Dead Sea Scrolls.</rdfs:comment>
        <jto:wikidataID>Q6276238</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChildrensMuseum">
        <rdfs:subClassOf rdf:resource="&jto;Museum"/>
        <rdfs:label xml:lang="en">Children's Museum</rdfs:label>
        <rdfs:label xml:lang="ar">متحف الأطفال</rdfs:label>
        <rdfs:comment xml:lang="en">Interactive museum designed for children and families.</rdfs:comment>
        <jto:cqReference>CQ-120</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArchaeologicalMuseum">
        <rdfs:subClassOf rdf:resource="&jto;Museum"/>
        <rdfs:label xml:lang="en">Archaeological Museum</rdfs:label>
        <rdfs:label xml:lang="ar">متحف آثار</rdfs:label>
        <rdfs:comment xml:lang="en">Museum focusing on archaeological artifacts and history.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ArtGallery">
        <rdfs:subClassOf rdf:resource="&jto;CulturalSite"/>
        <rdfs:label xml:lang="en">Art Gallery</rdfs:label>
        <rdfs:label xml:lang="ar">معرض فني</rdfs:label>
        <jto:cqReference>CQ-178</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CulturalCenter">
        <rdfs:subClassOf rdf:resource="&jto;CulturalSite"/>
        <rdfs:label xml:lang="en">Cultural Center</rdfs:label>
        <rdfs:label xml:lang="ar">مركز ثقافي</rdfs:label>
    </owl:Class>

    <!-- Heritage Site -->
    <owl:Class rdf:about="&jto;HeritageSite">
        <rdfs:subClassOf rdf:resource="&jto;Attraction"/>
        <rdfs:label xml:lang="en">Heritage Site</rdfs:label>
        <rdfs:label xml:lang="ar">موقع تراثي</rdfs:label>
        <rdfs:comment xml:lang="en">A site of historical and cultural significance, including UNESCO World Heritage Sites.</rdfs:comment>
        <jto:cqReference>CQ-055, CQ-056</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;UNESCOSite">
        <rdfs:subClassOf rdf:resource="&jto;HeritageSite"/>
        <rdfs:label xml:lang="en">UNESCO World Heritage Site</rdfs:label>
        <rdfs:label xml:lang="ar">موقع تراث عالمي لليونسكو</rdfs:label>
        <rdfs:comment xml:lang="en">Site inscribed on the UNESCO World Heritage List.</rdfs:comment>
        <jto:cqReference>CQ-062</jto:cqReference>
    </owl:Class>

    <!-- Petra Hierarchy -->
    <owl:Class rdf:about="&jto;Petra">
        <rdfs:subClassOf rdf:resource="&jto;UNESCOSite"/>
        <rdfs:label xml:lang="en">Petra</rdfs:label>
        <rdfs:label xml:lang="ar">البتراء</rdfs:label>
        <jto:altLabelAR>البترا</jto:altLabelAR>
        <jto:altLabelEN>Rose City</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Ancient Nabataean city carved into rose-red cliffs, one of the New Seven Wonders of the World.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مدينة نبطية قديمة منحوتة في منحدرات وردية حمراء، واحدة من عجائب الدنيا السبع الجديدة.</rdfs:comment>
        <jto:wikidataID>Q5684</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;Treasury">
        <rdfs:subClassOf rdf:resource="&jto;Petra"/>
        <rdfs:label xml:lang="en">The Treasury</rdfs:label>
        <rdfs:label xml:lang="ar">الخزنة</rdfs:label>
        <jto:altLabelEN>Al-Khazneh</jto:altLabelEN>
        <rdfs:comment xml:lang="en">The most iconic facade in Petra, carved as a royal tomb.</rdfs:comment>
        <jto:cqReference>CQ-107</jto:cqReference>
        <jto:wikidataID>Q180619</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;Monastery">
        <rdfs:subClassOf rdf:resource="&jto;Petra"/>
        <rdfs:label xml:lang="en">The Monastery</rdfs:label>
        <rdfs:label xml:lang="ar">الدير</rdfs:label>
