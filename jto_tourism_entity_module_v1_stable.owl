    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 2: ACCOMMODATION HIERARCHY                                            -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Accommodation (Root class for lodging)                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Accommodation">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Accommodation</rdfs:label>
        <rdfs:label xml:lang="ar">إقامة</rdfs:label>
        <jto:altLabelAR>سكن</jto:altLabelAR>
        <jto:altLabelEN>Lodging</jto:altLabelEN>
        <rdfs:comment xml:lang="en">A place providing lodging for tourists including hotels, camps, hostels, and eco-lodges.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مكان يوفر السكن للسياح بما في ذلك الفنادق والمخيمات والنزل والمنتجعات البيئية.</rdfs:comment>
        <jto:cqReference>CQ-006, CQ-098</jto:cqReference>
        <owl:equivalentClass rdf:resource="&schema;LodgingBusiness"/>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Hotel Hierarchy                                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Hotel">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق</rdfs:label>
        <rdfs:comment xml:lang="en">A commercial establishment providing lodging, meals, and services.</rdfs:comment>
        <rdfs:comment xml:lang="ar">منشأة تجارية توفر السكن والوجبات والخدمات.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Hotel"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;LuxuryHotel">
        <rdfs:subClassOf rdf:resource="&jto;Hotel"/>
        <rdfs:label xml:lang="en">Luxury Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق فاخر</rdfs:label>
        <jto:altLabelAR>فندق خمس نجوم</jto:altLabelAR>
        <rdfs:comment xml:lang="en">High-end hotel with premium amenities and services, typically 5-star rated.</rdfs:comment>
        <jto:cqReference>CQ-212</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;FiveStarHotel">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryHotel"/>
        <rdfs:label xml:lang="en">Five Star Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق خمس نجوم</rdfs:label>
        <rdfs:comment xml:lang="en">Highest rated hotel category with exceptional service and amenities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BoutiqueHotel">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryHotel"/>
        <rdfs:label xml:lang="en">Boutique Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق بوتيكي</rdfs:label>
        <jto:altLabelAR>فندق صغير فاخر</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Small, stylish hotel with unique character and personalized service.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;MidRangeHotel">
        <rdfs:subClassOf rdf:resource="&jto;Hotel"/>
        <rdfs:label xml:lang="en">Mid-Range Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق متوسط</rdfs:label>
        <jto:altLabelEN>Three Star Hotel</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Moderately priced hotel with standard amenities, typically 3-4 stars.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BudgetHotel">
        <rdfs:subClassOf rdf:resource="&jto;Hotel"/>
        <rdfs:label xml:lang="en">Budget Hotel</rdfs:label>
        <rdfs:label xml:lang="ar">فندق اقتصادي</rdfs:label>
        <jto:altLabelAR>فندق رخيص</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Affordable hotel with basic amenities, typically 1-2 stars.</rdfs:comment>
        <jto:cqReference>CQ-216</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;AdultsOnlyResort">
        <rdfs:subClassOf rdf:resource="&jto;Hotel"/>
        <rdfs:label xml:lang="en">Adults Only Resort</rdfs:label>
        <rdfs:label xml:lang="ar">منتجع للبالغين فقط</rdfs:label>
        <rdfs:comment xml:lang="en">Resort or hotel that only accepts adult guests (18+).</rdfs:comment>
        <jto:cqReference>CQ-162</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Resort Hierarchy                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Resort">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Resort</rdfs:label>
        <rdfs:label xml:lang="ar">منتجع</rdfs:label>
        <rdfs:comment xml:lang="en">Self-contained destination with recreation, entertainment, and accommodation facilities.</rdfs:comment>
        <rdfs:comment xml:lang="ar">وجهة متكاملة مع مرافق الترفيه والإقامة.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Resort"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaResort">
        <rdfs:subClassOf rdf:resource="&jto;Resort"/>
        <rdfs:label xml:lang="en">Dead Sea Resort</rdfs:label>
        <rdfs:label xml:lang="ar">منتجع البحر الميت</rdfs:label>
        <rdfs:comment xml:lang="en">Resort located at the Dead Sea offering wellness and spa treatments using Dead Sea minerals.</rdfs:comment>
        <rdfs:comment xml:lang="ar">منتجع يقع على البحر الميت يقدم علاجات السبا والعافية باستخدام معادن البحر الميت.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BeachResort">
        <rdfs:subClassOf rdf:resource="&jto;Resort"/>
        <rdfs:label xml:lang="en">Beach Resort</rdfs:label>
        <rdfs:label xml:lang="ar">منتجع شاطئي</rdfs:label>
        <rdfs:comment xml:lang="en">Resort located on a beach, typically in Aqaba on the Red Sea.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;SpaResort">
        <rdfs:subClassOf rdf:resource="&jto;Resort"/>
        <rdfs:label xml:lang="en">Spa Resort</rdfs:label>
        <rdfs:label xml:lang="ar">منتجع سبا</rdfs:label>
        <jto:altLabelAR>منتجع صحي</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Resort focused on health, wellness, and spa treatments.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Camp Hierarchy                                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Camp">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Camp</rdfs:label>
        <rdfs:label xml:lang="ar">مخيم</rdfs:label>
        <rdfs:comment xml:lang="en">Outdoor accommodation typically in tents, popular in Wadi Rum and desert areas.</rdfs:comment>
        <rdfs:comment xml:lang="ar">إقامة في الهواء الطلق عادة في الخيام، شائعة في وادي رم والمناطق الصحراوية.</rdfs:comment>
        <jto:cqReference>CQ-109</jto:cqReference>
        <owl:equivalentClass rdf:resource="&schema;Campground"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;BedouinCamp">
        <rdfs:subClassOf rdf:resource="&jto;Camp"/>
        <rdfs:label xml:lang="en">Bedouin Camp</rdfs:label>
        <rdfs:label xml:lang="ar">مخيم بدوي</rdfs:label>
        <jto:altLabelAR>خيمة بدوية</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Traditional Bedouin-style camp offering authentic desert experience with local hospitality.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مخيم بأسلوب بدوي تقليدي يقدم تجربة صحراوية أصيلة مع كرم الضيافة المحلي.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;LuxuryCamp">
        <rdfs:subClassOf rdf:resource="&jto;Camp"/>
        <rdfs:label xml:lang="en">Luxury Camp</rdfs:label>
        <rdfs:label xml:lang="ar">مخيم فاخر</rdfs:label>
        <jto:altLabelEN>Glamping</jto:altLabelEN>
        <rdfs:comment xml:lang="en">High-end camping experience with luxury amenities (glamping).</rdfs:comment>
        <jto:cqReference>CQ-214</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BubbleTent">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryCamp"/>
        <rdfs:label xml:lang="en">Bubble Tent</rdfs:label>
        <rdfs:label xml:lang="ar">خيمة فقاعية</rdfs:label>
        <jto:altLabelAR>قبة شفافة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Transparent dome tent for stargazing while sleeping, popular in Wadi Rum.</rdfs:comment>
        <rdfs:comment xml:lang="ar">خيمة شفافة على شكل قبة لمشاهدة النجوم أثناء النوم، شائعة في وادي رم.</rdfs:comment>
        <jto:cqReference>CQ-214</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;GlampingTent">
        <rdfs:subClassOf rdf:resource="&jto;LuxuryCamp"/>
        <rdfs:label xml:lang="en">Glamping Tent</rdfs:label>
        <rdfs:label xml:lang="ar">خيمة فخمة</rdfs:label>
        <rdfs:comment xml:lang="en">Glamorous camping tent with hotel-like amenities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BasicCamp">
        <rdfs:subClassOf rdf:resource="&jto;Camp"/>
        <rdfs:label xml:lang="en">Basic Camp</rdfs:label>
        <rdfs:label xml:lang="ar">مخيم أساسي</rdfs:label>
        <rdfs:comment xml:lang="en">Simple camping with basic facilities and shared amenities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;StargazingCamp">
        <rdfs:subClassOf rdf:resource="&jto;Camp"/>
        <rdfs:label xml:lang="en">Stargazing Camp</rdfs:label>
        <rdfs:label xml:lang="ar">مخيم مراقبة النجوم</rdfs:label>
        <rdfs:comment xml:lang="en">Camp specifically designed for astronomical observation with minimal light pollution.</rdfs:comment>
        <jto:cqReference>CQ-279</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WildCamping">
        <rdfs:subClassOf rdf:resource="&jto;Camp"/>
        <rdfs:label xml:lang="en">Wild Camping</rdfs:label>
        <rdfs:label xml:lang="ar">تخييم بري</rdfs:label>
        <jto:altLabelEN>Free Camping</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Camping in undesignated areas, subject to local regulations and permits.</rdfs:comment>
        <jto:cqReference>CQ-220</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Hostel Hierarchy                                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Hostel">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Hostel</rdfs:label>
        <rdfs:label xml:lang="ar">نزل</rdfs:label>
        <jto:altLabelAR>هوستل</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Budget accommodation with shared dormitory rooms, popular with backpackers.</rdfs:comment>
        <rdfs:comment xml:lang="ar">إقامة اقتصادية مع غرف مشتركة، شائعة بين المسافرين.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Hostel"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;BudgetHostel">
        <rdfs:subClassOf rdf:resource="&jto;Hostel"/>
        <rdfs:label xml:lang="en">Budget Hostel</rdfs:label>
        <rdfs:label xml:lang="ar">نزل اقتصادي</rdfs:label>
        <rdfs:comment xml:lang="en">Very affordable hostel with basic amenities.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;WomenOnlyHostel">
        <rdfs:subClassOf rdf:resource="&jto;Hostel"/>
        <rdfs:label xml:lang="en">Women Only Hostel</rdfs:label>
        <rdfs:label xml:lang="ar">نزل للنساء فقط</rdfs:label>
        <rdfs:comment xml:lang="en">Hostel that only accepts female guests, providing safe accommodation for solo female travelers.</rdfs:comment>
        <rdfs:comment xml:lang="ar">نزل يقبل الضيوف الإناث فقط، يوفر إقامة آمنة للمسافرات المنفردات.</rdfs:comment>
        <jto:cqReference>CQ-233</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- EcoLodge Hierarchy                                                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;EcoLodge">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Eco-Lodge</rdfs:label>
        <rdfs:label xml:lang="ar">نزل بيئي</rdfs:label>
        <jto:altLabelAR>منتجع صديق للبيئة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Environmentally sustainable accommodation following eco-friendly practices.</rdfs:comment>
        <rdfs:comment xml:lang="ar">إقامة مستدامة بيئياً تتبع ممارسات صديقة للبيئة.</rdfs:comment>
        <jto:cqReference>CQ-201</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;SolarPoweredLodge">
        <rdfs:subClassOf rdf:resource="&jto;EcoLodge"/>
        <rdfs:label xml:lang="en">Solar Powered Lodge</rdfs:label>
        <rdfs:label xml:lang="ar">نزل بالطاقة الشمسية</rdfs:label>
        <rdfs:comment xml:lang="en">Eco-lodge powered entirely or primarily by solar energy.</rdfs:comment>
        <jto:cqReference>CQ-204</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;ZeroWasteLodge">
        <rdfs:subClassOf rdf:resource="&jto;EcoLodge"/>
        <rdfs:label xml:lang="en">Zero Waste Lodge</rdfs:label>
        <rdfs:label xml:lang="ar">نزل بدون نفايات</rdfs:label>
        <rdfs:comment xml:lang="en">Eco-lodge committed to zero waste and sustainable practices.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Romantic Accommodation Hierarchy                                             -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;RomanticAccommodation">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Romantic Accommodation</rdfs:label>
        <rdfs:label xml:lang="ar">إقامة رومانسية</rdfs:label>
        <rdfs:comment xml:lang="en">Accommodation designed for couples, honeymoons, and romantic getaways.</rdfs:comment>
        <jto:cqReference>CQ-221</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;HoneymoonSuite">
        <rdfs:subClassOf rdf:resource="&jto;RomanticAccommodation"/>
        <rdfs:label xml:lang="en">Honeymoon Suite</rdfs:label>
        <rdfs:label xml:lang="ar">جناح شهر العسل</rdfs:label>
        <rdfs:comment xml:lang="en">Luxurious suite designed for newlyweds and romantic couples.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;PrivateVilla">
        <rdfs:subClassOf rdf:resource="&jto;RomanticAccommodation"/>
        <rdfs:label xml:lang="en">Private Villa</rdfs:label>
        <rdfs:label xml:lang="ar">فيلا خاصة</rdfs:label>
        <rdfs:comment xml:lang="en">Secluded private villa for exclusive use.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Accessible Room                                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;AccessibleRoom">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Accessible Room</rdfs:label>
        <rdfs:label xml:lang="ar">غرفة متاحة لذوي الاحتياجات الخاصة</rdfs:label>
        <jto:altLabelAR>غرفة لذوي الهمم</jto:altLabelAR>
        <jto:altLabelEN>Wheelchair Accessible Room</jto:altLabelEN>
        <rdfs:comment xml:lang="en">Accommodation designed for guests with mobility impairments or disabilities.</rdfs:comment>
        <rdfs:comment xml:lang="ar">إقامة مصممة للضيوف ذوي الإعاقات الحركية أو الاحتياجات الخاصة.</rdfs:comment>
        <jto:cqReference>CQ-229, CQ-290</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Homestay Hierarchy                                                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Homestay">
        <rdfs:subClassOf rdf:resource="&jto;Accommodation"/>
        <rdfs:label xml:lang="en">Homestay</rdfs:label>
        <rdfs:label xml:lang="ar">إقامة منزلية</rdfs:label>
        <jto:altLabelAR>الإقامة مع عائلة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Accommodation in a local family's home, offering authentic cultural experience.</rdfs:comment>
        <rdfs:comment xml:lang="ar">إقامة في منزل عائلة محلية، تقدم تجربة ثقافية أصيلة.</rdfs:comment>
        <jto:cqReference>CQ-260</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CommunityHomestay">
        <rdfs:subClassOf rdf:resource="&jto;Homestay"/>
        <rdfs:label xml:lang="en">Community Homestay</rdfs:label>
        <rdfs:label xml:lang="ar">إقامة منزلية مجتمعية</rdfs:label>
        <rdfs:comment xml:lang="en">Homestay program organized by local community for sustainable tourism.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Room Type Hierarchy (Supporting Class)                                       -->
