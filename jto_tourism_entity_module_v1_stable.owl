    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- SERVICE OBJECT PROPERTIES                                                    -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:ObjectProperty rdf:about="&jto;operatesIn">
        <rdfs:label xml:lang="en">operates in</rdfs:label>
        <rdfs:label xml:lang="ar">يعمل في</rdfs:label>
        <rdfs:comment xml:lang="en">Links a service to the location where it operates.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Service"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;servesRoute">
        <rdfs:label xml:lang="en">serves route</rdfs:label>
        <rdfs:label xml:lang="ar">يخدم المسار</rdfs:label>
        <rdfs:comment xml:lang="en">Links transport service to the route it covers.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;TransportService"/>
        <rdfs:range rdf:resource="&jto;Route"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;speaksLanguage">
        <rdfs:label xml:lang="en">speaks language</rdfs:label>
        <rdfs:label xml:lang="ar">يتحدث لغة</rdfs:label>
        <rdfs:comment xml:lang="en">Links a guide service to languages they speak.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;GuideService"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;acceptsPayment">
        <rdfs:label xml:lang="en">accepts payment</rdfs:label>
        <rdfs:label xml:lang="ar">يقبل الدفع</rdfs:label>
        <rdfs:comment xml:lang="en">Links a service to accepted payment methods.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Service"/>
        <rdfs:range rdf:resource="&jto;PaymentMethod"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;partnersWith">
        <rdfs:label xml:lang="en">partners with</rdfs:label>
        <rdfs:label xml:lang="ar">شريك مع</rdfs:label>
        <rdfs:comment xml:lang="en">Links a service provider to partner organizations.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Service"/>
        <rdfs:range rdf:resource="&jto;Service"/>
        <rdf:type rdf:resource="&owl;SymmetricProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;requiresInsurance">
        <rdfs:label xml:lang="en">requires insurance</rdfs:label>
        <rdfs:label xml:lang="ar">يتطلب تأمين</rdfs:label>
        <rdfs:comment xml:lang="en">Links an activity to required insurance type.</rdfs:comment>
        <rdfs:range rdf:resource="&jto;InsuranceService"/>
    </owl:ObjectProperty>

