        <rdfs:label xml:lang="ar">نشاط صحراوي</rdfs:label>
        <rdfs:comment xml:lang="en">Activities specific to desert environments like Wadi Rum.</rdfs:comment>
        <jto:cqReference>CQ-067, CQ-109</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;JeepTour">
        <rdfs:subClassOf rdf:resource="&jto;DesertActivity"/>
        <rdfs:label xml:lang="en">Jeep Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة بالجيب</rdfs:label>
        <jto:altLabelAR>جولة بسيارة الدفع الرباعي</jto:altLabelAR>
        <rdfs:comment xml:lang="en">4x4 vehicle tour through desert landscapes, very popular in Wadi Rum.</rdfs:comment>
        <jto:cqReference>CQ-068, CQ-118</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;SunsetJeepTour">
        <rdfs:subClassOf rdf:resource="&jto;JeepTour"/>
        <rdfs:label xml:lang="en">Sunset Jeep Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة جيب عند الغروب</rdfs:label>
        <rdfs:comment xml:lang="en">Jeep tour timed to watch the sunset from the desert.</rdfs:comment>
        <jto:cqReference>CQ-119</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;FullDayJeepTour">
        <rdfs:subClassOf rdf:resource="&jto;JeepTour"/>
        <rdfs:label xml:lang="en">Full Day Jeep Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة جيب ليوم كامل</rdfs:label>
        <rdfs:comment xml:lang="en">Comprehensive jeep tour covering major sites over a full day.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;CamelRide">
        <rdfs:subClassOf rdf:resource="&jto;DesertActivity"/>
        <rdfs:label xml:lang="en">Camel Ride</rdfs:label>
        <rdfs:label xml:lang="ar">ركوب الجمال</rdfs:label>
        <jto:altLabelAR>ركوب الإبل</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Traditional camel riding experience through the desert.</rdfs:comment>
        <rdfs:comment xml:lang="ar">تجربة ركوب الجمال التقليدية عبر الصحراء.</rdfs:comment>
        <jto:cqReference>CQ-069, CQ-120</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;SunsetCamelRide">
        <rdfs:subClassOf rdf:resource="&jto;CamelRide"/>
        <rdfs:label xml:lang="en">Sunset Camel Ride</rdfs:label>
        <rdfs:label xml:lang="ar">ركوب الجمال عند الغروب</rdfs:label>
        <rdfs:comment xml:lang="en">Camel ride timed to enjoy desert sunset views.</rdfs:comment>
        <jto:cqReference>CQ-121</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;CamelTrek">
        <rdfs:subClassOf rdf:resource="&jto;CamelRide"/>
        <rdfs:label xml:lang="en">Camel Trek</rdfs:label>
        <rdfs:label xml:lang="ar">رحلة بالجمال</rdfs:label>
        <rdfs:comment xml:lang="en">Extended camel journey lasting several hours or days.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Stargazing">
        <rdfs:subClassOf rdf:resource="&jto;DesertActivity"/>
        <rdfs:label xml:lang="en">Stargazing</rdfs:label>
        <rdfs:label xml:lang="ar">مراقبة النجوم</rdfs:label>
        <rdfs:comment xml:lang="en">Astronomical observation in the desert's dark skies.</rdfs:comment>
        <jto:cqReference>CQ-070, CQ-279</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;GuidedStargazing">
        <rdfs:subClassOf rdf:resource="&jto;Stargazing"/>
        <rdfs:label xml:lang="en">Guided Stargazing</rdfs:label>
        <rdfs:label xml:lang="ar">مراقبة النجوم مع مرشد</rdfs:label>
        <rdfs:comment xml:lang="en">Stargazing session led by an astronomy expert with telescopes.</rdfs:comment>
        <jto:cqReference>CQ-281</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BedouinExperience">
        <rdfs:subClassOf rdf:resource="&jto;DesertActivity"/>
        <rdfs:label xml:lang="en">Bedouin Experience</rdfs:label>
        <rdfs:label xml:lang="ar">تجربة بدوية</rdfs:label>
        <rdfs:comment xml:lang="en">Cultural immersion with Bedouin communities including tea, food, and traditions.</rdfs:comment>
        <jto:cqReference>CQ-071, CQ-260</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;BedouinDinner">
        <rdfs:subClassOf rdf:resource="&jto;BedouinExperience"/>
        <rdfs:label xml:lang="en">Bedouin Dinner</rdfs:label>
        <rdfs:label xml:lang="ar">عشاء بدوي</rdfs:label>
        <rdfs:comment xml:lang="en">Traditional Bedouin meal cooked in the desert, often Zarb (underground BBQ).</rdfs:comment>
        <jto:cqReference>CQ-122</jto:cqReference>
    </owl:Class>

