        <rdfs:comment xml:lang="en">Official Jordan tourism app with offline maps, attraction info, and itinerary planning.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;MapsMeApp">
        <rdf:type rdf:resource="&jto;MapsMe"/>
        <rdfs:label xml:lang="en">Maps.me</rdfs:label>
        <rdfs:label xml:lang="ar">خرائط مي</rdfs:label>
        <jto:worksOffline rdf:datatype="&xsd;boolean">true</jto:worksOffline>
        <rdfs:comment xml:lang="en">Recommended offline map app for Jordan, especially for remote areas like Wadi Rum.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Emergency Contact Individuals -->
    <owl:NamedIndividual rdf:about="&jto;JordanTouristPolice">
        <rdf:type rdf:resource="&jto;TouristPolice"/>
        <rdfs:label xml:lang="en">Jordan Tourist Police</rdfs:label>
        <rdfs:label xml:lang="ar">الشرطة السياحية الأردنية</rdfs:label>
        <jto:emergencyNumber>110</jto:emergencyNumber>
        <rdfs:comment xml:lang="en">Tourist police providing assistance to visitors. Located at major tourist sites.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;JordanEmergencyServices">
        <rdf:type rdf:resource="&jto;MedicalEmergency"/>
        <rdfs:label xml:lang="en">Jordan Emergency Services</rdfs:label>
        <rdfs:label xml:lang="ar">خدمات الطوارئ الأردنية</rdfs:label>
        <jto:emergencyNumber>911</jto:emergencyNumber>
        <rdfs:comment xml:lang="en">National emergency number for police, ambulance, and fire.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Safety Guidance Individuals -->
    <owl:NamedIndividual rdf:about="&jto;DeadSeaFloatingSafety">
        <rdf:type rdf:resource="&jto;FloatingSafety"/>
        <rdfs:label xml:lang="en">Dead Sea Floating Safety</rdfs:label>
        <rdfs:label xml:lang="ar">سلامة الطفو في البحر الميت</rdfs:label>
        <jto:safetyTip>Never put your face in the water. Rinse immediately if water contacts eyes. Maximum 20 minutes per session. Stay hydrated.</jto:safetyTip>
        <rdfs:comment xml:lang="en">Essential safety guidelines for Dead Sea floating experience.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&jto;DesertHikingSafety">
        <rdf:type rdf:resource="&jto;DesertSafety"/>
        <rdfs:label xml:lang="en">Desert Hiking Safety</rdfs:label>
        <rdfs:label xml:lang="ar">سلامة المشي في الصحراء</rdfs:label>
        <jto:safetyTip>Carry 3+ liters of water per person. Start early morning. Inform someone of your route. Wear sun protection and sturdy footwear.</jto:safetyTip>
        <rdfs:comment xml:lang="en">Safety guidelines for desert hiking and activities.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Cooking School Individual -->
    <owl:NamedIndividual rdf:about="&jto;BeitSittiAmman">
        <rdf:type rdf:resource="&jto;BeitSitti"/>
        <rdfs:label xml:lang="en">Beit Sitti Cooking School</rdfs:label>
        <rdfs:label xml:lang="ar">مدرسة بيت ستي للطبخ</rdfs:label>
        <rdfs:comment xml:lang="en">Famous cooking school in Amman offering hands-on traditional Jordanian cooking classes in a family home setting.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Packing List Individuals -->
    <owl:NamedIndividual rdf:about="&jto;JordanEssentialPacking">
        <rdf:type rdf:resource="&jto;EssentialItem"/>
        <rdfs:label xml:lang="en">Jordan Essential Packing List</rdfs:label>
        <rdfs:label xml:lang="ar">قائمة الحقيبة الأساسية للأردن</rdfs:label>
        <rdfs:comment xml:lang="en">Essential items: Sunscreen SPF50+, sunglasses, hat, comfortable walking shoes, modest clothing, reusable water bottle, power adapter (Type C/G), basic first aid kit.</rdfs:comment>
    </owl:NamedIndividual>


