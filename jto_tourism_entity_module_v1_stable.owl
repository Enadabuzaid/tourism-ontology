        <rdfs:subClassOf rdf:resource="&jto;ServiceAmenity"/>
        <rdfs:label xml:lang="en">Breakfast Service</rdfs:label>
        <rdfs:label xml:lang="ar">خدمة الإفطار</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;HalalBreakfast">
        <rdfs:subClassOf rdf:resource="&jto;BreakfastService"/>
        <rdfs:label xml:lang="en">Halal Breakfast</rdfs:label>
        <rdfs:label xml:lang="ar">إفطار حلال</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;BuffetBreakfast">
        <rdfs:subClassOf rdf:resource="&jto;BreakfastService"/>
        <rdfs:label xml:lang="en">Buffet Breakfast</rdfs:label>
        <rdfs:label xml:lang="ar">إفطار بوفيه</rdfs:label>
    </owl:Class>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- 1.2 EVENT HIERARCHY                                                          -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;Event">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Event</rdfs:label>
        <rdfs:label xml:lang="ar">حدث</rdfs:label>
        <rdfs:comment xml:lang="en">A tourism-related event including festivals, holidays, and special tours.</rdfs:comment>
        <rdfs:comment xml:lang="ar">حدث متعلق بالسياحة بما في ذلك المهرجانات والأعياد والجولات الخاصة.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;Event"/>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Festival Hierarchy                                                           -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Festival">
        <rdfs:subClassOf rdf:resource="&jto;Event"/>
        <rdfs:label xml:lang="en">Festival</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان</rdfs:label>
        <rdfs:comment xml:lang="en">A celebration event featuring cultural, artistic, or culinary activities.</rdfs:comment>
        <jto:cqReference>CQ-094</jto:cqReference>
        <owl:equivalentClass rdf:resource="&schema;Festival"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;CulturalFestival">
        <rdfs:subClassOf rdf:resource="&jto;Festival"/>
        <rdfs:label xml:lang="en">Cultural Festival</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان ثقافي</rdfs:label>
        <rdfs:comment xml:lang="en">A festival celebrating cultural heritage, traditions, and arts.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;JerashFestival">
        <rdfs:subClassOf rdf:resource="&jto;CulturalFestival"/>
        <rdfs:label xml:lang="en">Jerash Festival of Culture and Arts</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان جرش للثقافة والفنون</rdfs:label>
        <jto:altLabelAR>مهرجان جرش</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Annual cultural festival held in the ancient Roman ruins of Jerash, featuring music, dance, and theater.</rdfs:comment>
        <rdfs:comment xml:lang="ar">مهرجان ثقافي سنوي يُقام في الآثار الرومانية القديمة في جرش، يضم الموسيقى والرقص والمسرح.</rdfs:comment>
        <jto:wikidataID>Q3854313</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;FuheisFestival">
        <rdfs:subClassOf rdf:resource="&jto;CulturalFestival"/>
        <rdfs:label xml:lang="en">Fuheis Festival</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان الفحيص</rdfs:label>
        <rdfs:comment xml:lang="en">Annual summer festival in Fuheis town celebrating local culture and arts.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;MusicFestival">
        <rdfs:subClassOf rdf:resource="&jto;Festival"/>
        <rdfs:label xml:lang="en">Music Festival</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان موسيقي</rdfs:label>
        <owl:equivalentClass rdf:resource="&schema;MusicEvent"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;FoodFestival">
        <rdfs:subClassOf rdf:resource="&jto;Festival"/>
        <rdfs:label xml:lang="en">Food Festival</rdfs:label>
        <rdfs:label xml:lang="ar">مهرجان طعام</rdfs:label>
        <rdfs:comment xml:lang="en">Festival celebrating culinary traditions and local cuisine.</rdfs:comment>
        <owl:equivalentClass rdf:resource="&schema;FoodEvent"/>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Religious Holiday Hierarchy                                                  -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;ReligiousHoliday">
        <rdfs:subClassOf rdf:resource="&jto;Event"/>
        <rdfs:label xml:lang="en">Religious Holiday</rdfs:label>
        <rdfs:label xml:lang="ar">عطلة دينية</rdfs:label>
        <rdfs:comment xml:lang="en">A holiday observed for religious purposes that affects tourism services and availability.</rdfs:comment>
        <jto:cqReference>CQ-095, CQ-096</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;IslamicHoliday">
        <rdfs:subClassOf rdf:resource="&jto;ReligiousHoliday"/>
        <rdfs:label xml:lang="en">Islamic Holiday</rdfs:label>
        <rdfs:label xml:lang="ar">عيد إسلامي</rdfs:label>
        <rdfs:comment xml:lang="en">A holiday in the Islamic calendar that affects business hours and services.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;Ramadan">
        <rdfs:subClassOf rdf:resource="&jto;IslamicHoliday"/>
        <rdfs:label xml:lang="en">Ramadan</rdfs:label>
        <rdfs:label xml:lang="ar">رمضان</rdfs:label>
        <jto:altLabelAR>شهر رمضان المبارك</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Holy month of fasting when many restaurants are closed during daylight hours and attraction hours may vary.</rdfs:comment>
        <rdfs:comment xml:lang="ar">شهر الصيام المقدس حيث تغلق العديد من المطاعم خلال ساعات النهار وقد تتغير ساعات المعالم السياحية.</rdfs:comment>
        <jto:cqReference>CQ-007</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;EidAlFitr">
        <rdfs:subClassOf rdf:resource="&jto;IslamicHoliday"/>
        <rdfs:label xml:lang="en">Eid al-Fitr</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الفطر</rdfs:label>
        <jto:altLabelAR>العيد الصغير</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Festival of Breaking the Fast marking the end of Ramadan.</rdfs:comment>
        <jto:cqReference>CQ-095</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;EidAlAdha">
        <rdfs:subClassOf rdf:resource="&jto;IslamicHoliday"/>
        <rdfs:label xml:lang="en">Eid al-Adha</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الأضحى</rdfs:label>
        <jto:altLabelAR>العيد الكبير</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Festival of the Sacrifice, one of the most significant Islamic holidays.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;ChristianHoliday">
        <rdfs:subClassOf rdf:resource="&jto;ReligiousHoliday"/>
        <rdfs:label xml:lang="en">Christian Holiday</rdfs:label>
        <rdfs:label xml:lang="ar">عيد مسيحي</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;Christmas">
        <rdfs:subClassOf rdf:resource="&jto;ChristianHoliday"/>
        <rdfs:label xml:lang="en">Christmas</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الميلاد</rdfs:label>
        <jto:altLabelAR>الكريسماس</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Christian holiday celebrated in Jordan, particularly in Madaba and other Christian communities.</rdfs:comment>
        <jto:cqReference>CQ-096</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;Easter">
        <rdfs:subClassOf rdf:resource="&jto;ChristianHoliday"/>
        <rdfs:label xml:lang="en">Easter</rdfs:label>
        <rdfs:label xml:lang="ar">عيد الفصح</rdfs:label>
        <rdfs:comment xml:lang="en">Christian holiday significant for pilgrims visiting biblical sites in Jordan.</rdfs:comment>
    </owl:Class>

