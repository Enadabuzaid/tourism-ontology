        <rdfs:label xml:lang="ar">الحفاظ على الشعاب المرجانية</rdfs:label>
        <rdfs:comment xml:lang="en">Coral reef protection activities in Aqaba's Red Sea.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Sports Event Hierarchy                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;SportsEvent">
        <rdfs:subClassOf rdf:resource="&jto;Event"/>
        <rdfs:label xml:lang="en">Sports Event</rdfs:label>
        <rdfs:label xml:lang="ar">حدث رياضي</rdfs:label>
        <owl:equivalentClass rdf:resource="&schema;SportsEvent"/>
    </owl:Class>

    <owl:Class rdf:about="&jto;IronmanEvent">
        <rdfs:subClassOf rdf:resource="&jto;SportsEvent"/>
        <rdfs:label xml:lang="en">Ironman Event</rdfs:label>
        <rdfs:label xml:lang="ar">سباق أيرون مان</rdfs:label>
        <rdfs:comment xml:lang="en">Triathlon competition held in Aqaba.</rdfs:comment>
        <jto:cqReference>CQ-175</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Special Tour Hierarchy                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;SpecialTour">
        <rdfs:subClassOf rdf:resource="&jto;Event"/>
        <rdfs:label xml:lang="en">Special Tour</rdfs:label>
        <rdfs:label xml:lang="ar">جولة خاصة</rdfs:label>
        <rdfs:comment xml:lang="en">Unique scheduled tour experience at specific times or with special arrangements.</rdfs:comment>
        <jto:cqReference>CQ-066, CQ-115</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;PetraByNight">
        <rdfs:subClassOf rdf:resource="&jto;SpecialTour"/>
        <rdfs:label xml:lang="en">Petra by Night</rdfs:label>
        <rdfs:label xml:lang="ar">البتراء ليلاً</rdfs:label>
        <jto:altLabelAR>جولة البتراء الليلية</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Evening candlelit walk through the Siq to the Treasury, held Monday, Wednesday, and Thursday nights.</rdfs:comment>
        <rdfs:comment xml:lang="ar">جولة مشي على ضوء الشموع عبر السيق إلى الخزنة، تُقام ليالي الاثنين والأربعاء والخميس.</rdfs:comment>
    </owl:Class>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- 1.3 ROUTE & TRANSPORTATION HIERARCHY                                         -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <owl:Class rdf:about="&jto;Route">
        <rdfs:subClassOf rdf:resource="&jto;TourismEntity"/>
        <rdfs:label xml:lang="en">Route</rdfs:label>
        <rdfs:label xml:lang="ar">طريق</rdfs:label>
        <rdfs:comment xml:lang="en">A path or way for traveling between destinations, including highways, trails, and transport routes.</rdfs:comment>
        <jto:cqReference>CQ-099, CQ-138</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Highway Hierarchy                                                            -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Highway">
        <rdfs:subClassOf rdf:resource="&jto;Route"/>
        <rdfs:label xml:lang="en">Highway</rdfs:label>
        <rdfs:label xml:lang="ar">طريق سريع</rdfs:label>
        <rdfs:comment xml:lang="en">A major road route connecting tourism destinations in Jordan.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DesertHighway">
        <rdfs:subClassOf rdf:resource="&jto;Highway"/>
        <rdfs:label xml:lang="en">Desert Highway</rdfs:label>
        <rdfs:label xml:lang="ar">الطريق الصحراوي</rdfs:label>
        <jto:altLabelAR>طريق الصحراء</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Fastest route from Amman to Aqaba (4 hours), modern highway through the eastern desert.</rdfs:comment>
        <rdfs:comment xml:lang="ar">أسرع طريق من عمان إلى العقبة (4 ساعات)، طريق سريع حديث عبر الصحراء الشرقية.</rdfs:comment>
        <jto:cqReference>CQ-138</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;KingsHighway">
        <rdfs:subClassOf rdf:resource="&jto;Highway"/>
        <rdfs:label xml:lang="en">King's Highway</rdfs:label>
        <rdfs:label xml:lang="ar">الطريق الملوكي</rdfs:label>
        <jto:altLabelAR>طريق الملوك</jto:altLabelAR>
        <rdfs:comment xml:lang="en">Ancient scenic route passing through Madaba, Kerak, and Petra with numerous attractions. More scenic but takes 5-6 hours.</rdfs:comment>
        <rdfs:comment xml:lang="ar">طريق قديم خلاب يمر عبر مادبا والكرك والبتراء مع العديد من المعالم السياحية. أكثر جمالاً لكنه يستغرق 5-6 ساعات.</rdfs:comment>
        <jto:cqReference>CQ-138</jto:cqReference>
        <jto:wikidataID>Q1364962</jto:wikidataID>
    </owl:Class>

    <owl:Class rdf:about="&jto;DeadSeaHighway">
        <rdfs:subClassOf rdf:resource="&jto;Highway"/>
        <rdfs:label xml:lang="en">Dead Sea Highway</rdfs:label>
        <rdfs:label xml:lang="ar">طريق البحر الميت</rdfs:label>
        <rdfs:comment xml:lang="en">Route along the Dead Sea connecting Amman to Aqaba via the Jordan Valley.</rdfs:comment>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Hiking Trail Hierarchy                                                       -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;HikingTrail">
        <rdfs:subClassOf rdf:resource="&jto;Route"/>
        <rdfs:label xml:lang="en">Hiking Trail</rdfs:label>
        <rdfs:label xml:lang="ar">مسار المشي</rdfs:label>
        <jto:altLabelAR>درب المشي لمسافات طويلة</jto:altLabelAR>
        <rdfs:comment xml:lang="en">A path designed for hiking and trekking activities.</rdfs:comment>
        <jto:cqReference>CQ-083</jto:cqReference>
    </owl:Class>

    <owl:Class rdf:about="&jto;WetCanyonTrail">
        <rdfs:subClassOf rdf:resource="&jto;HikingTrail"/>
        <rdfs:label xml:lang="en">Wet Canyon Trail</rdfs:label>
        <rdfs:label xml:lang="ar">مسار الوادي المائي</rdfs:label>
        <rdfs:comment xml:lang="en">Trail involving water hiking and canyoning, like Wadi Mujib Siq Trail.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;DryTrail">
        <rdfs:subClassOf rdf:resource="&jto;HikingTrail"/>
        <rdfs:label xml:lang="en">Dry Trail</rdfs:label>
        <rdfs:label xml:lang="ar">مسار جاف</rdfs:label>
        <rdfs:comment xml:lang="en">Standard hiking trail without water crossing.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;PilgrimageRoute">
        <rdfs:subClassOf rdf:resource="&jto;HikingTrail"/>
        <rdfs:label xml:lang="en">Pilgrimage Route</rdfs:label>
        <rdfs:label xml:lang="ar">طريق الحج</rdfs:label>
        <rdfs:comment xml:lang="en">A trail connecting religious and biblical sites for pilgrims.</rdfs:comment>
        <jto:cqReference>CQ-159</jto:cqReference>
    </owl:Class>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Transport Route Hierarchy                                                    -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;TransportRoute">
        <rdfs:subClassOf rdf:resource="&jto;Route"/>
        <rdfs:label xml:lang="en">Transport Route</rdfs:label>
        <rdfs:label xml:lang="ar">طريق نقل</rdfs:label>
        <rdfs:comment xml:lang="en">A route served by public or private transportation.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="&jto;BusRoute">
        <rdfs:subClassOf rdf:resource="&jto;TransportRoute"/>
        <rdfs:label xml:lang="en">Bus Route</rdfs:label>
        <rdfs:label xml:lang="ar">خط الحافلات</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="&jto;FerryRoute">
        <rdfs:subClassOf rdf:resource="&jto;TransportRoute"/>
        <rdfs:label xml:lang="en">Ferry Route</rdfs:label>
        <rdfs:label xml:lang="ar">خط العبّارة</rdfs:label>
        <rdfs:comment xml:lang="en">Water route connecting Aqaba to Nuweiba (Egypt) and Taba.</rdfs:comment>
        <jto:cqReference>CQ-292</jto:cqReference>
    </owl:Class>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- OBJECT PROPERTIES                                                            -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Spatial Object Properties                                                    -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:ObjectProperty rdf:about="&jto;locatedIn">
        <rdfs:label xml:lang="en">located in</rdfs:label>
        <rdfs:label xml:lang="ar">يقع في</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that an entity is located within a destination or region.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;Destination"/>
        <owl:inverseOf rdf:resource="&jto;contains"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;contains">
        <rdfs:label xml:lang="en">contains</rdfs:label>
        <rdfs:label xml:lang="ar">يحتوي على</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Destination"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;near">
        <rdfs:label xml:lang="en">near</rdfs:label>
        <rdfs:label xml:lang="ar">بالقرب من</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates proximity between two places (typically within walking distance).</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;Place"/>
        <rdf:type rdf:resource="&owl;SymmetricProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;hasGeometry">
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
        <rdfs:label xml:lang="ar">لديه هندسة</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="&geo;hasGeometry"/>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&geo;Geometry"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;connects">
        <rdfs:label xml:lang="en">connects</rdfs:label>
        <rdfs:label xml:lang="ar">يربط</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that a route connects two or more places.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Event-Related Object Properties                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:ObjectProperty rdf:about="&jto;hasEvent">
        <rdfs:label xml:lang="en">has event</rdfs:label>
        <rdfs:label xml:lang="ar">لديه حدث</rdfs:label>
        <rdfs:comment xml:lang="en">Links a place to events that occur there.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;Event"/>
        <owl:inverseOf rdf:resource="&jto;occursAt"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;occursAt">
        <rdfs:label xml:lang="en">occurs at</rdfs:label>
        <rdfs:label xml:lang="ar">يحدث في</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Event"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;occursDuring">
        <rdfs:label xml:lang="en">occurs during</rdfs:label>
        <rdfs:label xml:lang="ar">يحدث خلال</rdfs:label>
        <rdfs:comment xml:lang="en">Links an event to a time interval or season.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Event"/>
        <rdfs:range rdf:resource="&time;TemporalEntity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;affectedByHoliday">
        <rdfs:label xml:lang="en">affected by holiday</rdfs:label>
        <rdfs:label xml:lang="ar">يتأثر بالعطلة</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that a place's services or hours are affected by a religious holiday.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&jto;ReligiousHoliday"/>
    </owl:ObjectProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Route-Related Object Properties                                              -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:ObjectProperty rdf:about="&jto;passesThrough">
        <rdfs:label xml:lang="en">passes through</rdfs:label>
        <rdfs:label xml:lang="ar">يمر عبر</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that a route passes through a place.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;startsFrom">
        <rdfs:label xml:lang="en">starts from</rdfs:label>
        <rdfs:label xml:lang="ar">يبدأ من</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;endsAt">
        <rdfs:label xml:lang="en">ends at</rdfs:label>
        <rdfs:label xml:lang="ar">ينتهي عند</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&jto;Place"/>
    </owl:ObjectProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Heritage & Film Object Properties                                            -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:ObjectProperty rdf:about="&jto;featuredInFilm">
        <rdfs:label xml:lang="en">featured in film</rdfs:label>
        <rdfs:label xml:lang="ar">ظهر في فيلم</rdfs:label>
        <rdfs:comment xml:lang="en">Links a film location to the movie it appeared in.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;FilmLocation"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;partOfSite">
        <rdfs:label xml:lang="en">part of site</rdfs:label>
        <rdfs:label xml:lang="ar">جزء من الموقع</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that a specific feature is part of a larger heritage site.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Attraction"/>
        <rdfs:range rdf:resource="&jto;HeritageSite"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&jto;sameAs">
        <rdfs:label xml:lang="en">same as</rdfs:label>
        <rdfs:label xml:lang="ar">نفس</rdfs:label>
        <rdfs:comment xml:lang="en">Links to equivalent entity in external knowledge bases (Wikidata, DBpedia).</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="&owl;sameAs"/>
    </owl:ObjectProperty>

    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- DATA PROPERTIES                                                              -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Name & Label Properties                                                      -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;officialName">
        <rdfs:label xml:lang="en">official name</rdfs:label>
        <rdfs:label xml:lang="ar">الاسم الرسمي</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <!--
            Values for jto:officialName in this module are language-tagged literals
            (e.g., "Amman"@en, "عمّان"@ar). OWL reasoners treat those values as
            rdf:langString, which is NOT the same as xsd:string. Using rdf:langString
            here prevents ontology inconsistency while preserving multilingual data.
        -->
        <rdfs:range rdf:resource="&rdf;langString"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;nickname">
        <rdfs:label xml:lang="en">nickname</rdfs:label>
        <rdfs:label xml:lang="ar">لقب</rdfs:label>
        <rdfs:comment xml:lang="en">Common nickname or alias for entity disambiguation.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <!-- See note on jto:officialName above (multilingual language-tagged literals). -->
        <rdfs:range rdf:resource="&rdf;langString"/>
    </owl:DatatypeProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Spatial Data Properties                                                      -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;latitude">
        <rdfs:label xml:lang="en">latitude</rdfs:label>
        <rdfs:label xml:lang="ar">خط العرض</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <rdfs:subPropertyOf rdf:resource="&schema;latitude"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;longitude">
        <rdfs:label xml:lang="en">longitude</rdfs:label>
        <rdfs:label xml:lang="ar">خط الطول</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
        <rdfs:subPropertyOf rdf:resource="&schema;longitude"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;altitude">
        <rdfs:label xml:lang="en">altitude</rdfs:label>
        <rdfs:label xml:lang="ar">الارتفاع</rdfs:label>
        <rdfs:comment xml:lang="en">Elevation above sea level in meters.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;wktLiteral">
        <rdfs:label xml:lang="en">WKT literal</rdfs:label>
        <rdfs:comment xml:lang="en">Well-Known Text representation for GeoSPARQL compatibility.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;Place"/>
        <rdfs:range rdf:resource="&geo;wktLiteral"/>
    </owl:DatatypeProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Route Data Properties                                                        -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;distanceKm">
        <rdfs:label xml:lang="en">distance (km)</rdfs:label>
        <rdfs:label xml:lang="ar">المسافة (كم)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;drivingTimeMinutes">
        <rdfs:label xml:lang="en">driving time (minutes)</rdfs:label>
        <rdfs:label xml:lang="ar">وقت القيادة (دقائق)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Route"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;hikingTimeHours">
        <rdfs:label xml:lang="en">hiking time (hours)</rdfs:label>
        <rdfs:label xml:lang="ar">وقت المشي (ساعات)</rdfs:label>
        <rdfs:domain rdf:resource="&jto;HikingTrail"/>
        <rdfs:range rdf:resource="&xsd;decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;difficultyLevel">
        <rdfs:label xml:lang="en">difficulty level</rdfs:label>
        <rdfs:label xml:lang="ar">مستوى الصعوبة</rdfs:label>
        <rdfs:comment xml:lang="en">Trail difficulty: Easy, Moderate, Difficult, Expert.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;HikingTrail"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isScenic">
        <rdfs:label xml:lang="en">is scenic</rdfs:label>
        <rdfs:label xml:lang="ar">خلّاب</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Highway"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Event Data Properties                                                        -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;eventStartDate">
        <rdfs:label xml:lang="en">event start date</rdfs:label>
        <rdfs:label xml:lang="ar">تاريخ بدء الحدث</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Event"/>
        <rdfs:range rdf:resource="&xsd;date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;eventEndDate">
        <rdfs:label xml:lang="en">event end date</rdfs:label>
        <rdfs:label xml:lang="ar">تاريخ انتهاء الحدث</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Event"/>
        <rdfs:range rdf:resource="&xsd;date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isAnnual">
        <rdfs:label xml:lang="en">is annual</rdfs:label>
        <rdfs:label xml:lang="ar">سنوي</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Event"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;affectsBusinessHours">
        <rdfs:label xml:lang="en">affects business hours</rdfs:label>
        <rdfs:label xml:lang="ar">يؤثر على ساعات العمل</rdfs:label>
        <rdfs:comment xml:lang="en">Whether a holiday affects attraction/restaurant hours.</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;ReligiousHoliday"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Place-Specific Data Properties                                               -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;unescoInscriptionYear">
        <rdfs:label xml:lang="en">UNESCO inscription year</rdfs:label>
        <rdfs:label xml:lang="ar">سنة الإدراج في اليونسكو</rdfs:label>
        <rdfs:domain rdf:resource="&jto;UNESCOSite"/>
        <rdfs:range rdf:resource="&xsd;gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;borteScale">
        <rdfs:label xml:lang="en">Bortle scale</rdfs:label>
        <rdfs:label xml:lang="ar">مقياس بورتل</rdfs:label>
        <rdfs:comment xml:lang="en">Light pollution rating (1=darkest to 9=brightest).</rdfs:comment>
        <rdfs:domain rdf:resource="&jto;StargazingSite"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;historicalPeriod">
        <rdfs:label xml:lang="en">historical period</rdfs:label>
        <rdfs:label xml:lang="ar">الفترة التاريخية</rdfs:label>
        <rdfs:domain rdf:resource="&jto;ArchaeologicalSite"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;isOpenToNonMuslims">
        <rdfs:label xml:lang="en">is open to non-Muslims</rdfs:label>
        <rdfs:label xml:lang="ar">مفتوح لغير المسلمين</rdfs:label>
        <rdfs:domain rdf:resource="&jto;Mosque"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Provenance Data Properties                                                   -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:DatatypeProperty rdf:about="&jto;lastUpdated">
        <rdfs:label xml:lang="en">last updated</rdfs:label>
        <rdfs:label xml:lang="ar">آخر تحديث</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="&dcterms;modified"/>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&jto;sourceURL">
        <rdfs:label xml:lang="en">source URL</rdfs:label>
        <rdfs:label xml:lang="ar">رابط المصدر</rdfs:label>
        <rdfs:domain rdf:resource="&jto;TourismEntity"/>
        <rdfs:range rdf:resource="&xsd;anyURI"/>
    </owl:DatatypeProperty>

