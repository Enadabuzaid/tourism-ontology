    <!-- ════════════════════════════════════════════════════════════════════════════ -->
    <!-- MODULE 5: FACILITY HIERARCHY                                                 -->
    <!-- ════════════════════════════════════════════════════════════════════════════ -->

    <!-- ─────────────────────────────────────────────────────────────────────────── -->
    <!-- Facility (Root Class)                                                        -->
    <!-- ─────────────────────────────────────────────────────────────────────────── -->

    <owl:Class rdf:about="&jto;Facility">
