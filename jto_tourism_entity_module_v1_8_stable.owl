    <jto:hagglingExpected rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:hagglingExpected>
    <jto:settingType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">traditional souks and markets</jto:settingType>
    <jto:notes rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Haggling is common in traditional markets (souks) but not in fixed-price shops. Start at 50-60% of asking price. Be friendly and respectful.</jto:notes>
    <rdfs:label xml:lang="en">Jordan Market Shopping Etiquette</rdfs:label>
    <rdfs:label xml:lang="ar">آداب التسوق في أسواق الأردن</rdfs:label>
  </rdf:Description>

