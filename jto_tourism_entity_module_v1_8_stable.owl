    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#HospitalityCustom"/>
    <jto:culturalTip>It's polite to bring a small gift when visiting a Jordanian home.</jto:culturalTip>
    <jto:etiquetteDescription>Jordanians are known for exceptional hospitality. Accept offered coffee/tea as refusal may offend. Remove shoes when entering homes.</jto:etiquetteDescription>
    <rdfs:comment xml:lang="en">Hospitality is central to Jordanian culture. Accept offered tea/coffee (at least one cup). Remove shoes when entering homes. Bring small gifts when visiting. Refuse food/drink politely 2-3 times before accepting.</rdfs:comment>
    <rdfs:label xml:lang="en">Jordanian Hospitality</rdfs:label>
    <rdfs:label xml:lang="ar">الضيافة الأردنية</rdfs:label>
    <jto:officialName xml:lang="en">Jordanian Hospitality</jto:officialName>
