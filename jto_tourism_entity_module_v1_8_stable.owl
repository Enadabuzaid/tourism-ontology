  <!-- CQ-039: Wadi Rum December -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#SeasonalAdviceWadiRumDecember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#SeasonalAdvice"/>
    <jto:forLocation rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#WadiRum"/>
    <jto:forMonth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</jto:forMonth>
    <jto:recommendation rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Good for stargazing and desert camping. Cold nights — bring warm layers. Very few tourists compared to peak season.</jto:recommendation>
    <jto:weatherConditions rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cold days (15°C), very cold nights (0-5°C). Clear skies ideal for astronomy.</jto:weatherConditions>
    <rdfs:label xml:lang="en">Wadi Rum December Seasonal Advice</rdfs:label>
    <rdfs:label xml:lang="ar">نصائح موسم ديسمبر لوادي رم</rdfs:label>
  </rdf:Description>

  <!-- CQ-040: Best time Dead Sea -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BestTimeDeadSea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
