    <jto:halalFood rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:halalFood>
    <jto:petFriendly rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</jto:petFriendly>
