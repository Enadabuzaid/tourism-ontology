  <!-- ========== OWL ONTOLOGY DECLARATION ========== -->
  <owl:Ontology rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism">
    <owl:versionIRI rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism/1.5"/>
    <owl:versionInfo>1.5</owl:versionInfo>
    <dc:title xml:lang="en">Jordan Tourism Ontology (JTO)</dc:title>
    <dc:title xml:lang="ar">أنطولوجيا السياحة الأردنية</dc:title>
    <dc:creator>Enad Abuzaid</dc:creator>
    <dc:description xml:lang="en">An OWL ontology for Jordan tourism entities, covering attractions, accommodation, transport, cultural practices, accessibility, and BI forecasting.</dc:description>
    <rdfs:comment xml:lang="en">JTO v1.5 — Jordan Tourism Ontology with seed individuals for CQ-001 to CQ-030 plus GeoSPARQL geometries.</rdfs:comment>
  </owl:Ontology>

  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#PrivateDining">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#LuxuryService"/>
    <jto:cqReference>CQ-213</jto:cqReference>
    <rdfs:comment xml:lang="en">Private dining experience at exclusive locations.</rdfs:comment>
    <rdfs:label xml:lang="en">Private Dining</rdfs:label>
    <rdfs:label xml:lang="ar">طعام خاص</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#fridayClosureStart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
    <rdfs:comment xml:lang="en">Start time of Friday prayer closure.</rdfs:comment>
    <rdfs:label xml:lang="en">Friday closure start</rdfs:label>
    <rdfs:label xml:lang="ar">بداية إغلاق الجمعة</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#LotsCave">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BiblicalSite"/>
    <jto:cqReference>CQ-158</jto:cqReference>
    <rdfs:comment xml:lang="en">Biblical site near the Dead Sea associated with the story of Lot.</rdfs:comment>
    <rdfs:label xml:lang="en">Lot's Cave</rdfs:label>
    <rdfs:label xml:lang="ar">مغارة لوط</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BedouinGuide">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#Guide"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#GuideService"/>
    <jto:cqReference>CQ-114</jto:cqReference>
    <rdfs:comment xml:lang="en">Bedouin guide with deep knowledge of desert terrain and traditions.</rdfs:comment>
    <rdfs:comment xml:lang="en">Bedouin guide, especially for desert tours in Wadi Rum.</rdfs:comment>
    <rdfs:comment xml:lang="ar">مرشد بدوي ذو معرفة عميقة بالتضاريس الصحراوية والتقاليد.</rdfs:comment>
    <rdfs:label xml:lang="en">Bedouin Guide</rdfs:label>
    <rdfs:label xml:lang="ar">مرشد بدوي</rdfs:label>
  </rdf:Description>
