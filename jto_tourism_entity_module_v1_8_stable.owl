  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BeitSittiCookingClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#CookingClass"/>
    <jto:locatedIn rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#Amman"/>
    <jto:activityDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4.0</jto:activityDuration>
    <jto:activityPrice rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">65.00</jto:activityPrice>
    <jto:difficultyLevel>Easy</jto:difficultyLevel>
    <jto:isSuitableForChildren rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:isSuitableForChildren>
    <jto:requiresBooking rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:requiresBooking>
    <rdfs:comment xml:lang="en">Famous cooking class in Amman where local grandmothers teach traditional recipes.</rdfs:comment>
    <rdfs:label xml:lang="en">Beit Sitti Cooking Class</rdfs:label>
    <rdfs:label xml:lang="ar">دورة الطبخ في بيت ستي</rdfs:label>
    <jto:officialName xml:lang="en">Beit Sitti Cooking Class</jto:officialName>
    <jto:officialName xml:lang="ar">دورة الطبخ في بيت ستي</jto:officialName>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#LawrenceOfArabiaMovie">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#LawrenceOfArabia"/>
    <jto:filmedIn rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#WadiRum"/>
    <jto:movieYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1962</jto:movieYear>
    <rdfs:comment xml:lang="en">David Lean's epic filmed extensively in Wadi Rum and Aqaba.</rdfs:comment>
    <rdfs:label xml:lang="en">Lawrence of Arabia (1962)</rdfs:label>
    <rdfs:label xml:lang="ar">لورنس العرب (1962)</rdfs:label>
    <jto:officialName xml:lang="en">Lawrence of Arabia (1962)</jto:officialName>
    <jto:officialName xml:lang="ar">لورنس العرب (1962)</jto:officialName>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#accessibilityNotes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#TourismEntity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">accessibilityNotes</rdfs:label>
    <rdfs:comment xml:lang="en">Additional accessibility information.</rdfs:comment>
    <jto:cqReference>CQ-005</jto:cqReference>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#MadabaCity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#City"/>
    <jto:altLabelAR>مأدبا</jto:altLabelAR>
    <jto:altLabelEN>Madaba Mosaic City</jto:altLabelEN>
    <jto:wikidataID>Q1757639</jto:wikidataID>
    <rdfs:comment xml:lang="en">Known as the "City of Mosaics" for its Byzantine-era mosaic map.</rdfs:comment>
    <rdfs:comment xml:lang="ar">تُعرف بـ "مدينة الفسيفساء" لخريطتها الفسيفسائية من العصر البيزنطي.</rdfs:comment>
    <rdfs:label xml:lang="en">Madaba</rdfs:label>
    <rdfs:label xml:lang="ar">مادبا</rdfs:label>
    <jto:officialName xml:lang="en">Madaba</jto:officialName>
    <jto:officialName xml:lang="ar">مادبا</jto:officialName>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#FamilySuitability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
