  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#MansafDish">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#Mansaf"/>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q693198"/>
    <jto:culturalTip>Traditionally eaten with the right hand. The host may offer choice pieces to honored guests.</jto:culturalTip>
    <jto:dishDescription>Jordan's national dish - lamb cooked in fermented dried yogurt (jameed) served over rice and flatbread.</jto:dishDescription>
    <jto:isVegetarian rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</jto:isVegetarian>
