    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#RamadanEtiquette"/>
    <jto:culturalTip>Ramadan is a special time to experience Jordan - consider attending an iftar meal.</jto:culturalTip>
    <jto:etiquetteDescription>During Ramadan, avoid eating, drinking, or smoking in public during fasting hours. Many restaurants close until iftar. Attractions may have reduced hours.</jto:etiquetteDescription>
