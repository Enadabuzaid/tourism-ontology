  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BargainingInSouks">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#BargainingCustom"/>
    <jto:bargainingExpected rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:bargainingExpected>
    <rdfs:comment xml:lang="en">Bargaining expected in souks and markets. Start at 50-60% of asking price. Be friendly and patient. Walk away if price too high - often brings lower offer. Fixed prices in malls and supermarkets.</rdfs:comment>
