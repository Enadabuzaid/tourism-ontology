    <jto:avgLowTemp rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.0</jto:avgLowTemp>
    <jto:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cool and pleasant spring weather. Occasional rain possible. Ideal for hiking.</jto:description>
    <jto:snowfallPossible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</jto:snowfallPossible>
    <rdfs:label xml:lang="en">Petra Weather - March</rdfs:label>
    <rdfs:label xml:lang="ar">طقس البتراء في مارس</rdfs:label>
  </rdf:Description>

  <!-- CQ-041: Snow in Petra winter -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#WeatherPetraJanuary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
