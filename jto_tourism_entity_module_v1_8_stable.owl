  <!-- CQ-060: Jordanian greetings -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#JordanGreetingEtiquette">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#CulturalEtiquette"/>
    <jto:etiquetteType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">greeting</jto:etiquetteType>
    <jto:arabicPhrase rdf:datatype="http://www.w3.org/2001/XMLSchema#string">مرحبا / أهلاً وسهلاً / السلام عليكم</jto:arabicPhrase>
    <jto:usageContext rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use 'Marhaba' (Hello) casually. 'Ahlan wa sahlan' (Welcome) for formal. 'As-salamu alaykum' (Peace be upon you) in Islamic contexts. Handshakes common with same gender. Bow slightly as sign of respect with elders.</jto:usageContext>
    <rdfs:label xml:lang="en">Jordanian Greeting Etiquette</rdfs:label>
    <rdfs:label xml:lang="ar">آداب التحية الأردنية</rdfs:label>
  </rdf:Description>

