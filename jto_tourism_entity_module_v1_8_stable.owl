  <!-- CQ-048: Haggling etiquette -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#JordanMarketEtiquette">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
