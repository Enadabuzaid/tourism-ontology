    <rdfs:label xml:lang="ar">بطاقة جواز الأردن السياحية</rdfs:label>
  </rdf:Description>

  <!-- CQ-068: Photography rules Petra -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#PetraPhotographyRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#PhotographyRule"/>
    <jto:forAttraction rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#PetraSite"/>
    <jto:photographyAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</jto:photographyAllowed>
    <jto:droneAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</jto:droneAllowed>
    <jto:restrictions rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Commercial photography requires permit from Jordan Tourism Board. Drones strictly prohibited. No photography inside the Siq narrow canyon with flash.</jto:restrictions>
    <rdfs:label xml:lang="en">Petra Photography Rules</rdfs:label>
    <rdfs:label xml:lang="ar">قواعد التصوير في البتراء</rdfs:label>
  </rdf:Description>

  <!-- CQ-069: Photography rules mosques -->
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#MosquePhotographyRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
