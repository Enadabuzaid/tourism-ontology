  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:imports rdf:resource="jto_core_shapes_v1_1.ttl"/>
    <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
    <owl:imports rdf:resource="http://www.w3.org/2006/time"/>
    <dc:creator>Enad Abu Zaid</dc:creator>
    <dc:description xml:lang="en">This module defines the core TourismEntity classes including Place, Event, and Route hierarchies for the Jordan Tourism Ontology. It covers competency questions CQ-001 to CQ-300 related to tourism entities.</dc:description>
    <dc:description xml:lang="ar">هذه الوحدة تحدد فئات الكيانات السياحية الأساسية بما في ذلك التسلسلات الهرمية للأماكن والأحداث والمسارات لأنطولوجيا السياحة الأردنية.</dc:description>
    <dc:title xml:lang="en">Jordan Tourism Ontology (JTO) - TourismEntity Module</dc:title>
    <dc:title xml:lang="ar">أنطولوجيا السياحة الأردنية - وحدة الكيانات السياحية</dc:title>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-17</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-08</dcterms:modified>
    <owl:versionIRI rdf:resource="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism/1.2"/>
    <rdfs:comment xml:lang="en">Module: TourismEntity (Place + Event + Route)</rdfs:comment>
    <owl:versionInfo>1.2</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/enadabuzaid/ontologies/2025/11/jordan-tourism#UndergroundBBQ">
